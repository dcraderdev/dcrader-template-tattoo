---
import { Picture, getImage } from 'astro:assets';
import { studio } from '../../data/v3';
import { resolveImage } from '../../data/imageMap';
import PortfolioCarouselHero from '../../components/tattoo/PortfolioCarouselHero.astro';
import '../../styles/global.css';
const heroImg = resolveImage(studio.heroImage);
const heroWidths = [768, 1280, 1920];
const heroSrcset = (await Promise.all(
  heroWidths.map(async (w) => {
    const img = await getImage({ src: heroImg, width: w, format: 'webp' });
    return `${img.src} ${w}w`;
  })
)).join(', ');
const heroPreload = await getImage({ src: heroImg, width: 1920, format: 'webp' });
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title>{studio.name} — Japanese Irezumi · {studio.city}</title>
  <meta name="description" content={studio.description}/>
  <link rel="canonical" href={Astro.url.href}/>
  <meta property="og:title" content={`${studio.name} — Japanese Irezumi`}/>
  <meta property="og:description" content={studio.description}/>
  <meta property="og:image" content="/og-image.png"/>
  <meta property="og:url" content={Astro.url.href}/>
  <meta property="og:type" content="website"/>
  <meta name="twitter:card" content="summary_large_image"/>
  <meta name="twitter:title" content={`${studio.name} — Japanese Irezumi`}/>
  <meta name="twitter:description" content={studio.description}/>
  <meta name="twitter:image" content="/og-image.png"/>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@300;400;500;700&family=Cormorant:ital,wght@0,300;0,400;0,600;1,300;1,400;1,600&display=swap" rel="stylesheet"/>
  <link rel="preload" as="image" fetchpriority="high" type="image/webp" href={heroPreload.src} imagesrcset={heroSrcset} imagesizes="100vw"/>
  <style>
    :root{--bg:#060606;--surf:#0E0E0E;--surf2:#161616;--gold:#B8974A;--gold2:#D4AE68;--red:#9B1324;--cream:#EAD8B4;--gray:#6A6050;}
    *{box-sizing:border-box;margin:0;padding:0;}
    html{scroll-behavior:smooth;}
    body{background:var(--bg);color:var(--cream);font-family:'Cormorant',Georgia,serif;}

    /* NAV */
    nav{background:rgba(6,6,6,0.95);border-bottom:1px solid rgba(184,151,74,0.15);position:sticky;top:34px;z-index:100;backdrop-filter:blur(8px);}
    .nav-inner{max-width:1200px;margin:0 auto;padding:0 2rem;display:flex;align-items:center;justify-content:space-between;min-height:70px;}
    .nav-logo{text-decoration:none;display:flex;align-items:baseline;gap:0.75rem;}
    .nav-jp{font-family:'Noto Serif JP',serif;font-size:1.3rem;font-weight:400;color:var(--gold);}
    .nav-en{font-family:'Cormorant',serif;font-size:0.75rem;font-weight:300;letter-spacing:0.3em;text-transform:uppercase;color:rgba(234,216,180,0.5);}
    .nav-links{display:flex;list-style:none;gap:0;align-items:center;}
    nav a{font-family:'Cormorant',serif;font-size:0.85rem;letter-spacing:0.1em;color:var(--gray);text-decoration:none;padding:0.4rem 0.85rem;display:block;transition:color 0.2s;}
    nav a:hover,nav a:focus-visible{color:var(--gold);}
    .nav-book-btn{background:var(--red)!important;color:var(--cream)!important;font-family:'Noto Serif JP',serif!important;font-size:0.75rem!important;letter-spacing:0.08em!important;}

    /* HERO — full-bleed with Japanese vertical text element */
    .hero{position:relative;min-height:100vh;display:flex;align-items:center;overflow:hidden;}
    .hero-bg{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;filter:brightness(0.35) saturate(0.7);}
    .hero-fade{position:absolute;inset:0;background:linear-gradient(to right,rgba(6,6,6,0.92) 45%,rgba(6,6,6,0.2) 100%);}
    .hero-vertical{position:absolute;right:2rem;top:50%;transform:translateY(-50%);writing-mode:vertical-rl;font-family:'Noto Serif JP',serif;font-size:0.8rem;font-weight:300;letter-spacing:0.3em;color:rgba(184,151,74,0.25);user-select:none;}
    .hero-content{position:relative;max-width:1200px;margin:0 auto;padding:4rem 2rem;width:100%;}
    .hero-tag{font-family:'Noto Serif JP',serif;font-size:0.7rem;letter-spacing:0.2em;color:rgba(184,151,74,0.6);margin-bottom:2rem;display:block;}
    .hero-h1{font-family:'Noto Serif JP',serif;font-size:clamp(3.5rem,7vw,6.5rem);font-weight:700;color:var(--cream);line-height:1;margin-bottom:0.5rem;}
    .hero-h1-en{font-family:'Cormorant',serif;font-style:italic;font-size:clamp(1.5rem,3vw,2.5rem);font-weight:300;color:var(--gold);display:block;margin-top:0.75rem;letter-spacing:0.05em;}
    .hero-stroke{display:block;width:80px;height:3px;background:linear-gradient(to right,var(--red),var(--gold));margin:2rem 0;}
    .hero-desc{font-family:'Cormorant',serif;font-style:italic;font-size:clamp(1rem,1.8vw,1.3rem);color:rgba(234,216,180,0.7);max-width:500px;line-height:1.75;margin-bottom:3rem;}
    .hero-ctas{display:flex;gap:1rem;flex-wrap:wrap;}
    .btn-red{background:var(--red);color:var(--cream);font-family:'Noto Serif JP',serif;font-size:0.8rem;letter-spacing:0.1em;text-decoration:none;padding:0.9rem 2rem;border:1px solid var(--red);transition:background 0.2s;}
    .btn-red:hover,.btn-red:focus-visible{background:#7A0F1C;}
    .btn-gold{background:transparent;color:var(--gold);font-family:'Cormorant',serif;font-style:italic;font-size:1rem;letter-spacing:0.05em;text-decoration:none;padding:0.9rem 2rem;border:1px solid rgba(184,151,74,0.4);transition:all 0.2s;}
    .btn-gold:hover,.btn-gold:focus-visible{border-color:var(--gold);background:rgba(184,151,74,0.08);}

    /* TRADITION STATEMENT — full-width interstitial */
    .tradition{background:var(--red);padding:3.5rem 2rem;text-align:center;}
    .tradition blockquote{font-family:'Cormorant',serif;font-style:italic;font-size:clamp(1.2rem,2.5vw,2rem);color:var(--cream);max-width:800px;margin:0 auto;line-height:1.6;}
    .tradition cite{display:block;margin-top:1rem;font-family:'Noto Serif JP',serif;font-size:0.7rem;letter-spacing:0.25em;color:rgba(234,216,180,0.6);font-style:normal;}

    /* LINEAGE PLAQUE */
    .lineage{background:var(--surf);border-top:1px solid rgba(184,151,74,0.15);border-bottom:1px solid rgba(184,151,74,0.15);}
    .lineage-inner{max-width:1200px;margin:0 auto;padding:3.5rem 2rem;display:grid;grid-template-columns:1fr auto 1fr auto 1fr;gap:2rem;align-items:center;}
    .lineage-col{display:flex;flex-direction:column;align-items:center;text-align:center;gap:0.6rem;max-width:300px;margin:0 auto;}
    .lineage-kanji{font-family:'Noto Serif JP',serif;font-size:clamp(2.5rem,4.5vw,4rem);font-weight:700;color:var(--gold);letter-spacing:0.05em;line-height:1;}
    .lineage-jp{font-family:'Noto Serif JP',serif;font-size:0.7rem;letter-spacing:0.2em;color:var(--red);}
    .lineage-en{font-family:'Cormorant',serif;font-style:italic;font-size:0.95rem;color:var(--gray);line-height:1.6;}
    .lineage-divider{width:1px;height:80px;background:linear-gradient(to bottom,transparent,rgba(184,151,74,0.4),transparent);}
    @media(max-width:820px){.lineage-inner{grid-template-columns:1fr;gap:2.5rem;}.lineage-divider{width:60px;height:1px;background:linear-gradient(to right,transparent,rgba(184,151,74,0.4),transparent);}}

    /* SECTIONS */
    .section{padding:6rem 2rem;}
    .section-inner{max-width:1200px;margin:0 auto;}
    .eyebrow{font-family:'Noto Serif JP',serif;font-size:0.65rem;letter-spacing:0.3em;color:var(--red);margin-bottom:0.5rem;display:block;}
    .section-h{font-family:'Cormorant',serif;font-size:clamp(2rem,4vw,3.5rem);font-weight:600;color:var(--cream);line-height:1.05;}
    .section-h-jp{font-family:'Noto Serif JP',serif;font-size:0.9rem;font-weight:300;color:rgba(184,151,74,0.5);letter-spacing:0.15em;display:block;margin-bottom:0.25rem;}
    .gold-stroke{width:50px;height:2px;background:linear-gradient(to right,var(--red),var(--gold));margin:1.25rem 0 2.5rem;}

    /* ARTISTS — full-width vertical panels */
    .artist-bg{background:var(--surf);}
    .artist-panels{display:grid;gap:1px;background:rgba(184,151,74,0.1);}
    .artist-panel{display:grid;grid-template-columns:380px 1fr;min-height:400px;background:var(--bg);}
    .artist-panel:nth-child(even){grid-template-columns:1fr 380px;}
    .artist-panel:nth-child(even) .artist-panel-photo{order:2;}
    .artist-panel:nth-child(even) .artist-panel-info{order:1;}
    .artist-panel-photo{overflow:hidden;position:relative;}
    .artist-panel-photo img{width:100%;height:100%;object-fit:cover;object-position:top;display:block;filter:sepia(15%) contrast(1.1);transition:filter 0.5s;}
    .artist-panel:hover .artist-panel-photo img{filter:sepia(0%) contrast(1.1);}
    .artist-panel-info{padding:3rem;display:flex;flex-direction:column;justify-content:center;position:relative;}
    .artist-panel-num{font-family:'Noto Serif JP',serif;font-size:3.5rem;font-weight:700;color:rgba(184,151,74,0.06);position:absolute;top:2rem;right:2rem;line-height:1;}
    .artist-panel-h{font-family:'Cormorant',serif;font-size:1.8rem;font-weight:600;color:var(--cream);margin-bottom:0.25rem;}
    .artist-panel-spec{font-family:'Noto Serif JP',serif;font-size:0.65rem;letter-spacing:0.2em;color:var(--gold);margin-bottom:1.25rem;}
    .artist-panel-bio{font-family:'Cormorant',serif;font-style:italic;font-size:1rem;color:var(--gray);line-height:1.8;margin-bottom:1.25rem;}
    .artist-panel-handle{font-size:0.8rem;color:rgba(184,151,74,0.5);}
    .artist-tags{display:flex;gap:0.4rem;flex-wrap:wrap;margin-top:0.75rem;}
    .tag{background:rgba(155,19,36,0.15);color:var(--red);border:1px solid rgba(155,19,36,0.25);font-family:'Noto Serif JP',serif;font-size:0.6rem;letter-spacing:0.08em;padding:0.2rem 0.5rem;}
    .years{display:inline-block;background:rgba(184,151,74,0.1);border:1px solid rgba(184,151,74,0.2);color:var(--gold);font-family:'Noto Serif JP',serif;font-size:0.62rem;letter-spacing:0.1em;padding:0.2rem 0.6rem;margin-top:0.5rem;}
    @media(max-width:768px){.artist-panel{grid-template-columns:1fr;min-height:auto;}.artist-panel:nth-child(even){grid-template-columns:1fr;}.artist-panel-photo{height:280px;}.artist-panel:nth-child(even) .artist-panel-photo{order:1;}.artist-panel:nth-child(even) .artist-panel-info{order:2;}}

    /* GALLERY — vertical full-width sequence */
    .gallery-bg{background:var(--bg);}
    .vertical-gallery{display:grid;gap:3px;margin-top:2rem;}
    .vg-item{position:relative;overflow:hidden;}
    .vg-item img{width:100%;display:block;aspect-ratio:16/7;object-fit:cover;object-position:center;filter:sepia(10%) contrast(1.1);transition:filter 0.5s,transform 0.6s;}
    .vg-item:hover img{filter:sepia(0%) contrast(1.15);transform:scale(1.02);}
    .vg-overlay{position:absolute;inset:0;background:linear-gradient(to right,rgba(6,6,6,0.75) 0%,transparent 55%);display:flex;align-items:flex-end;padding:2rem;}
    .vg-caption{color:var(--cream);}
    .vg-caption-style{font-family:'Noto Serif JP',serif;font-size:0.6rem;letter-spacing:0.2em;color:var(--gold);margin-bottom:0.25rem;}
    .vg-caption-desc{font-family:'Cormorant',serif;font-style:italic;font-size:1.1rem;color:var(--cream);}
    .vg-caption-artist{font-family:'Cormorant',serif;font-size:0.8rem;color:var(--gray);}

    /* JOURNEY — booking process flowchart */
    .journey-bg{background:linear-gradient(180deg,var(--bg) 0%,var(--surf) 100%);border-top:1px solid rgba(184,151,74,0.12);border-bottom:1px solid rgba(184,151,74,0.12);}
    .journey-head{text-align:center;max-width:720px;margin:0 auto 3.5rem;}
    .journey-head .section-h-jp{margin-bottom:0.5rem;}
    .journey-head .gold-stroke{margin-left:auto;margin-right:auto;}
    .journey-intro{font-family:'Cormorant',serif;font-style:italic;font-size:1.05rem;color:var(--gray);line-height:1.8;margin-top:1rem;}
    .journey-flow{display:grid;grid-template-columns:repeat(5,1fr);gap:0;position:relative;margin-top:2rem;}
    @media(max-width:900px){.journey-flow{grid-template-columns:1fr;}}
    .journey-step{position:relative;padding:2.25rem 1.25rem 2rem;text-align:center;border-right:1px solid rgba(184,151,74,0.12);}
    .journey-step:last-child{border-right:none;}
    @media(max-width:900px){.journey-step{border-right:none;border-bottom:1px solid rgba(184,151,74,0.12);}.journey-step:last-child{border-bottom:none;}}
    .journey-step::before{content:'';position:absolute;top:50%;right:-9px;width:18px;height:18px;background:var(--bg);border:1px solid var(--gold);transform:translateY(-50%) rotate(45deg);z-index:2;}
    .journey-step:last-child::before{display:none;}
    @media(max-width:900px){.journey-step::before{display:none;}}
    .journey-kanji{font-family:'Noto Serif JP',serif;font-size:2.2rem;font-weight:700;color:var(--red);line-height:1;margin-bottom:0.4rem;}
    .journey-num{font-family:'Cormorant',serif;font-style:italic;font-size:0.7rem;letter-spacing:0.25em;text-transform:uppercase;color:var(--gold);margin-bottom:1rem;}
    .journey-title{font-family:'Cormorant',serif;font-size:1.2rem;font-weight:600;color:var(--cream);margin-bottom:0.5rem;}
    .journey-romaji{font-family:'Noto Serif JP',serif;font-size:0.7rem;letter-spacing:0.15em;color:rgba(184,151,74,0.55);margin-bottom:0.85rem;}
    .journey-body{font-family:'Cormorant',serif;font-style:italic;font-size:0.92rem;color:var(--gray);line-height:1.7;}

    /* AFTERCARE */
    .ac-bg{background:var(--surf);}
    .ac-scroll{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:rgba(184,151,74,0.1);margin-top:2rem;}
    @media(max-width:640px){.ac-scroll{grid-template-columns:1fr;}}
    .ac-card{background:var(--bg);padding:2.5rem;}
    .ac-num-jp{font-family:'Noto Serif JP',serif;font-size:2.5rem;font-weight:700;color:rgba(184,151,74,0.12);line-height:1;margin-bottom:0.75rem;}
    .ac-title{font-family:'Cormorant',serif;font-size:1.15rem;font-weight:600;color:var(--gold);margin-bottom:0.6rem;}
    .ac-body{font-family:'Cormorant',serif;font-style:italic;font-size:0.95rem;color:var(--gray);line-height:1.8;}

    /* BOOKING */
    .bk-bg{background:linear-gradient(135deg,var(--surf2) 0%,var(--bg) 100%);border-top:1px solid rgba(184,151,74,0.15);}
    .bk-grid{display:grid;grid-template-columns:1fr 1fr;gap:4rem;}
    @media(max-width:768px){.bk-grid{grid-template-columns:1fr;}}
    .bk-info p{font-family:'Cormorant',serif;font-style:italic;font-size:1rem;color:var(--gray);line-height:1.8;margin-bottom:1rem;}
    .price-box{border:1px solid rgba(184,151,74,0.15);background:rgba(184,151,74,0.04);padding:1.5rem;margin-top:1.5rem;}
    .price-row{display:flex;justify-content:space-between;font-family:'Cormorant',serif;font-size:0.95rem;color:var(--gray);padding:0.45rem 0;border-bottom:1px solid rgba(184,151,74,0.08);}
    .price-row:last-child{border-bottom:none;}
    .price-row strong{color:var(--gold);}
    .bk-form{display:grid;gap:1.25rem;}
    .fl{display:block;font-family:'Noto Serif JP',serif;font-size:0.6rem;letter-spacing:0.2em;color:var(--gold);margin-bottom:0.3rem;}
    .fi{width:100%;background:rgba(255,255,255,0.03);border:1px solid rgba(184,151,74,0.2);color:var(--cream);padding:0.7rem 0.9rem;font-family:'Cormorant',serif;font-size:0.95rem;outline:none;transition:border-color 0.2s;}
    .fi:focus{border-color:var(--gold);}
    .fi::placeholder{color:rgba(234,216,180,0.2);}
    .fi option{background:var(--surf);}
    .fr{display:grid;grid-template-columns:1fr 1fr;gap:1rem;}
    .fs{background:var(--red);color:var(--cream);font-family:'Noto Serif JP',serif;font-size:0.78rem;letter-spacing:0.1em;border:none;cursor:pointer;padding:0.9rem 2rem;width:100%;transition:background 0.2s;}
    .fs:hover,.fs:focus-visible{background:#7A0F1C;}

    /* FAQ */
    .faq-outer{border:1px solid rgba(184,151,74,0.12);margin-top:2rem;}
    details{border-bottom:1px solid rgba(184,151,74,0.08);}
    details:last-child{border-bottom:none;}
    summary{padding:1.25rem 1.5rem;cursor:pointer;display:flex;justify-content:space-between;align-items:center;list-style:none;font-family:'Cormorant',serif;font-size:1.05rem;font-weight:600;color:var(--cream);}
    summary::-webkit-details-marker{display:none;}
    summary::after{content:'鯉';font-family:'Noto Serif JP',serif;font-size:0.8rem;color:rgba(184,151,74,0.35);flex-shrink:0;transition:transform 0.3s;}
    details[open] summary::after{transform:rotate(360deg);color:var(--gold);}
    summary:hover{background:rgba(184,151,74,0.03);}
    .faq-ans{padding:0 1.5rem 1.25rem;font-family:'Cormorant',serif;font-style:italic;font-size:0.95rem;color:var(--gray);line-height:1.8;}

    /* LOCATION */
    .loc-bg{background:var(--surf);}
    .loc-grid{display:grid;grid-template-columns:1fr 1fr;gap:3rem;}
    @media(max-width:700px){.loc-grid{grid-template-columns:1fr;}}
    .hours-tbl{width:100%;border-collapse:collapse;margin-top:1.5rem;}
    .hours-tbl tr{border-bottom:1px solid rgba(184,151,74,0.1);}
    .hours-tbl td{padding:0.65rem 0;font-family:'Cormorant',serif;font-size:1rem;color:var(--gray);}
    .hours-tbl td:first-child{color:var(--cream);font-family:'Noto Serif JP',serif;font-size:0.85rem;}
    .hours-tbl .closed{color:#2a2010;font-style:italic;}
    .c-stack{margin-top:1.5rem;display:grid;gap:0.9rem;}
    .c-row{display:flex;gap:0.75rem;font-family:'Cormorant',serif;font-size:1rem;color:var(--gray);}
    .c-row a{color:var(--gold);text-decoration:none;}

    /* IG */
    .ig-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:3px;margin-top:2rem;}
    @media(min-width:640px){.ig-grid{grid-template-columns:repeat(6,1fr);}}
    .ig-cell{aspect-ratio:1;overflow:hidden;}
    .ig-cell img{width:100%;height:100%;object-fit:cover;display:block;filter:sepia(15%) contrast(1.05);transition:transform 0.4s,filter 0.3s;}
    .ig-cell a:hover img{transform:scale(1.07);filter:sepia(0%);}
    .ig-cell a{display:block;height:100%;}
    .ig-cell a:focus-visible{outline:1px solid var(--gold);outline-offset:2px;}
    .ig-cta{text-align:center;margin-top:2rem;}
    .ig-cta a{font-family:'Cormorant',serif;font-style:italic;font-size:1rem;color:var(--gold);text-decoration:none;border-bottom:1px solid rgba(184,151,74,0.3);padding-bottom:2px;}

    /* FOOTER */
    footer{background:#030303;border-top:1px solid var(--red);padding:3.5rem 2rem;text-align:center;}
    .foot-jp{font-family:'Noto Serif JP',serif;font-size:2rem;font-weight:700;color:var(--gold);margin-bottom:0.25rem;}
    .foot-en{font-family:'Cormorant',serif;font-style:italic;font-size:1rem;color:rgba(234,216,180,0.4);letter-spacing:0.15em;margin-bottom:0.75rem;}
    .foot-quote{font-family:'Cormorant',serif;font-style:italic;font-size:0.9rem;color:rgba(184,151,74,0.3);max-width:500px;margin:0 auto 1.5rem;}
    .foot-nav{display:flex;justify-content:center;gap:0;list-style:none;flex-wrap:wrap;margin-bottom:1.25rem;}
    .foot-nav a{font-family:'Cormorant',serif;font-size:0.85rem;color:rgba(184,151,74,0.25);text-decoration:none;padding:0.3rem 0.9rem;transition:color 0.2s;}
    .foot-nav a:hover{color:var(--gold);}
    .foot-copy{font-family:'Noto Serif JP',serif;font-size:0.62rem;color:#1a1008;letter-spacing:0.1em;}
    .sr-only{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0}
    @media(max-width:480px){.fr{grid-template-columns:1fr;}}
  </style>
  <script src="/template-topheader.js" defer></script>
</head>
<body>

<nav aria-label="Main navigation">
  <div class="nav-inner">
    <a class="nav-logo" href="/dcrader-template-tattoo/v3-japanese-irezumi" aria-label="Ryūboku Tattoo home">
      <span class="nav-jp">龍墨</span>
      <span class="nav-en">Ryūboku Tattoo</span>
    </a>
    <ul class="nav-links" role="list">
      <li><a href="#artists">Artists</a></li>
      <li><a href="#portfolio">Portfolio</a></li>
      <li><a href="#aftercare">Aftercare</a></li>
      <li><a href="#faq">FAQ</a></li>
      <li><a href="#location">Location</a></li>
      <li><a href="#booking" class="nav-book-btn">予約</a></li>
    </ul>
  </div>
</nav>

<!-- HERO — portfolio carousel -->
<PortfolioCarouselHero studio={studio} />

<!-- TRADITION INTERSTITIAL -->
<div class="tradition" role="note">
  <blockquote>
    "A true horishi does not pick up the needle until they have spent five years watching, cleaning, and learning. The art lives in that patience."
    <cite>— Studio Philosophy, Ryūboku Tattoo</cite>
  </blockquote>
</div>

<!-- LINEAGE PLAQUE — kanji-numbered counts -->
<aside class="lineage" aria-label="The studio's lineage at a glance">
  <div class="lineage-inner">
    <div class="lineage-col">
      <span class="lineage-kanji" aria-hidden="true">弐拾弐</span>
      <span class="lineage-jp">伝承年</span>
      <span class="lineage-en">Years of horishi lineage carried from Yokohama to San Diego — twenty-two</span>
    </div>
    <div class="lineage-divider" aria-hidden="true"></div>
    <div class="lineage-col">
      <span class="lineage-kanji" aria-hidden="true">陸</span>
      <span class="lineage-jp">進行中の総身彫</span>
      <span class="lineage-en">Full-body suits currently in progress — six, three in their final year</span>
    </div>
    <div class="lineage-divider" aria-hidden="true"></div>
    <div class="lineage-col">
      <span class="lineage-kanji" aria-hidden="true">手彫</span>
      <span class="lineage-jp">手彫りに応じる</span>
      <span class="lineage-en">Tebori — by-hand work — offered for back pieces and full suits, by request only</span>
    </div>
  </div>
</aside>

<!-- ARTISTS -->
<section id="artists" class="section artist-bg" aria-labelledby="artists-h">
  <div class="section-inner">
    <span class="eyebrow">彫師 — Our Horishi</span>
    <span class="section-h-jp">師匠の技</span>
    <h2 class="section-h" id="artists-h">Masters of the Form</h2>
    <div class="gold-stroke" aria-hidden="true"></div>
  </div>
  <div class="artist-panels" role="list">
    {studio.artists.map((a, i) => (
      <article class="artist-panel" role="listitem" aria-label={`Artist: ${a.name}`}>
        <div class="artist-panel-photo">
          <Picture formats={['avif','webp']} src={resolveImage(a.image)} alt={`Portrait of ${a.name}`} loading="lazy" decoding="async" widths={[380, 600, 800]} sizes="(min-width: 768px) 380px, 100vw" width={800} height={840} />
        </div>
        <div class="artist-panel-info">
          <div class="artist-panel-num" aria-hidden="true">{i+1}</div>
          <h3 class="artist-panel-h">{a.name}</h3>
          <p class="artist-panel-spec">{a.specialty}</p>
          <p class="artist-panel-bio">{a.bio}</p>
          <p class="artist-panel-handle">{a.handle}</p>
          <div class="artist-tags" aria-label={`Styles: ${a.styles.join(', ')}`}>
            {a.styles.map(s => <span class="tag">{s}</span>)}
          </div>
          <p class="years">{a.yearsExp} 年 / {a.yearsExp} Years</p>
        </div>
      </article>
    ))}
  </div>
</section>

<!-- GALLERY — vertical sequence -->
<section id="portfolio" class="section gallery-bg" aria-labelledby="gallery-h">
  <div class="section-inner">
    <span class="eyebrow">作品集 — Portfolio</span>
    <span class="section-h-jp">伝統の形</span>
    <h2 class="section-h" id="gallery-h">Works in the Traditional Form</h2>
    <div class="gold-stroke" aria-hidden="true"></div>
  </div>
  <div class="vertical-gallery" role="list" aria-label="Portfolio gallery">
    {studio.gallery.slice(0,6).map(item => (
      <figure class="vg-item" role="listitem">
        <Picture formats={['avif','webp']} src={resolveImage(item.image)} alt={item.alt} loading="lazy" decoding="async" widths={[800, 1280, 1600]} sizes="100vw" width={1600} height={700} />
        <div class="vg-overlay" aria-hidden="true">
          <figcaption class="vg-caption">
            <p class="vg-caption-style">{item.style}</p>
            <p class="vg-caption-desc">{item.alt.split('–')[0].trim()}</p>
            <p class="vg-caption-artist">— {item.artist}</p>
          </figcaption>
        </div>
      </figure>
    ))}
  </div>
</section>

<!-- JOURNEY — five-step booking flow -->
<section id="journey" class="section journey-bg" aria-labelledby="journey-h">
  <div class="section-inner">
    <div class="journey-head">
      <span class="eyebrow">道 — The Path</span>
      <span class="section-h-jp">予約の流れ</span>
      <h2 class="section-h" id="journey-h">From First Letter to Final Session</h2>
      <div class="gold-stroke" aria-hidden="true"></div>
      <p class="journey-intro">A traditional irezumi is not booked the way a flash piece is booked. We move slowly, with intention. Most pieces take months from inquiry to first needle — and years to complete.</p>
    </div>
    <ol class="journey-flow" role="list" aria-label="Five-step booking process">
      <li class="journey-step" role="listitem">
        <div class="journey-kanji" aria-hidden="true">壱</div>
        <div class="journey-num">Step One</div>
        <h3 class="journey-title">Inquiry Letter</h3>
        <div class="journey-romaji">問い合わせ · Toiawase</div>
        <p class="journey-body">Write to us — not a form, a letter. Tell us the motif you carry, the placement you imagine, and why now. We read every word before we reply.</p>
      </li>
      <li class="journey-step" role="listitem">
        <div class="journey-kanji" aria-hidden="true">弐</div>
        <div class="journey-num">Step Two</div>
        <h3 class="journey-title">Consultation</h3>
        <div class="journey-romaji">相談 · Sōdan</div>
        <p class="journey-body">In-person at the studio. We discuss lineage, traditional symbolism, and which horishi suits your piece. Tea is served. No needles are touched.</p>
      </li>
      <li class="journey-step" role="listitem">
        <div class="journey-kanji" aria-hidden="true">参</div>
        <div class="journey-num">Step Three</div>
        <h3 class="journey-title">Design &amp; Deposit</h3>
        <div class="journey-romaji">下絵 · Shitae</div>
        <p class="journey-body">A ${studio.depositAmount} commitment secures your spot in the calendar. Your shitae — the master sketch — is drawn over six to ten weeks, never rushed.</p>
      </li>
      <li class="journey-step" role="listitem">
        <div class="journey-kanji" aria-hidden="true">四</div>
        <div class="journey-num">Step Four</div>
        <h3 class="journey-title">The Sessions</h3>
        <div class="journey-romaji">彫り · Hori</div>
        <p class="journey-body">Outlines first across one or two sittings, then colour and shading in three- to five-hour blocks spaced weeks apart. A back piece may take a year. A full suit, several.</p>
      </li>
      <li class="journey-step" role="listitem">
        <div class="journey-kanji" aria-hidden="true">五</div>
        <div class="journey-num">Step Five</div>
        <h3 class="journey-title">Healing &amp; Honour</h3>
        <div class="journey-romaji">癒し · Iyashi</div>
        <p class="journey-body">Aftercare is the apprentice's lesson and the client's discipline. When the work is fully settled, we photograph it for the studio archive — with your permission.</p>
      </li>
    </ol>
  </div>
</section>

<!-- AFTERCARE -->
<section id="aftercare" class="section ac-bg" aria-labelledby="aftercare-h">
  <div class="section-inner">
    <span class="eyebrow">アフターケア — Aftercare</span>
    <span class="section-h-jp">作品を守る</span>
    <h2 class="section-h" id="aftercare-h">Honoring the Work</h2>
    <div class="gold-stroke" aria-hidden="true"></div>
    <p style="font-family:'Cormorant',serif;font-style:italic;font-size:1rem;color:var(--gray);max-width:560px;line-height:1.8;margin-bottom:0.5rem;">Each healing session is as important as the session itself. Irezumi demands respect at every stage.</p>
    <div class="ac-scroll" role="list">
      {studio.aftercare.map(step => (
        <div class="ac-card" role="listitem">
          <div class="ac-num-jp" aria-hidden="true">0{step.step}</div>
          <h3 class="ac-title">{step.title}</h3>
          <p class="ac-body">{step.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- BOOKING -->
<section id="booking" class="section bk-bg" aria-labelledby="booking-h">
  <div class="section-inner">
    <div class="bk-grid">
      <div class="bk-info">
        <span class="eyebrow">予約 — Begin</span>
        <span class="section-h-jp">旅を始める</span>
        <h2 class="section-h" id="booking-h">Request a Consultation</h2>
        <div class="gold-stroke" aria-hidden="true"></div>
        <p>Irezumi is a conversation between artist and skin that can last years. Before we begin, we speak. Describe your vision below and your horishi will respond within 72 hours.</p>
        <p>A ${studio.depositAmount} deposit reserves your consultation and is applied toward your first session.</p>
        <div class="price-box">
          <div class="price-row"><span>Shop Minimum</span><strong>${studio.minimumCharge}</strong></div>
          <div class="price-row"><span>Hourly Rate</span><strong>${studio.hourlyRate}/hr</strong></div>
          <div class="price-row"><span>Booking Deposit</span><strong>${studio.depositAmount}</strong></div>
          <div class="price-row"><span>Full Suits</span><strong>Custom quote</strong></div>
        </div>
      </div>
      <form class="bk-form" action="#" method="post" aria-label="Booking request form" novalidate>
        <div><label class="fl" for="bn">Full Name *</label><input class="fi" type="text" id="bn" name="name" placeholder="Your name" required autocomplete="name"/></div>
        <div class="fr">
          <div><label class="fl" for="be">Email *</label><input class="fi" type="email" id="be" name="email" placeholder="you@email.com" required/></div>
          <div><label class="fl" for="bp">Phone</label><input class="fi" type="tel" id="bp" name="phone" placeholder="Optional"/></div>
        </div>
        <div><label class="fl" for="ba">Preferred Horishi</label>
          <select class="fi" id="ba" name="artist">
            <option value="">No preference</option>
            {studio.artists.map(a => <option value={a.name}>{a.name}</option>)}
          </select>
        </div>
        <div><label class="fl" for="bsc">Project Scope</label>
          <select class="fi" id="bsc" name="scope">
            <option>Single piece</option><option>Half sleeve</option><option>Full sleeve</option><option>Back piece</option><option>Full body suit</option>
          </select>
        </div>
        <div class="fr">
          <div><label class="fl" for="bpl">Placement</label><input class="fi" type="text" id="bpl" name="placement" placeholder="e.g. full sleeve"/></div>
          <div><label class="fl" for="bdt">Availability</label><input class="fi" type="text" id="bdt" name="dates" placeholder="e.g. monthly sessions"/></div>
        </div>
        <div><label class="fl" for="bd">Describe your vision *</label><textarea class="fi" id="bd" name="description" rows="5" placeholder="Motifs, themes, scale, color or black/grey, existing work to consider..." required></textarea></div>
        <button class="fs" type="submit">Request Consultation + ${studio.depositAmount} Deposit</button>
      </form>
    </div>
  </div>
</section>

<!-- FAQ -->
<section id="faq" class="section" aria-labelledby="faq-h">
  <div class="section-inner" style="max-width:800px;">
    <span class="eyebrow">よくある質問 — FAQ</span>
    <h2 class="section-h" id="faq-h">Questions &amp; Answers</h2>
    <div class="gold-stroke" aria-hidden="true"></div>
    <div class="faq-outer">
      {studio.faqs.map(f => (
        <details>
          <summary>{f.question}</summary>
          <div class="faq-ans"><p>{f.answer}</p></div>
        </details>
      ))}
    </div>
  </div>
</section>

<!-- LOCATION -->
<section id="location" class="section loc-bg" aria-labelledby="loc-h">
  <div class="section-inner">
    <div class="loc-grid">
      <div>
        <span class="eyebrow">場所 — Location</span>
        <h2 class="section-h" id="loc-h">Find the Studio</h2>
        <div class="gold-stroke" aria-hidden="true"></div>
        <div class="c-stack">
          <div class="c-row"><span aria-hidden="true">龍</span><div><p>{studio.address}</p><p>{studio.city}</p><a href={studio.mapUrl} target="_blank" rel="noopener noreferrer" style="font-size:0.75rem;letter-spacing:0.15em;text-transform:uppercase;margin-top:0.3rem;display:inline-block;">Directions</a></div></div>
          <div class="c-row"><span aria-hidden="true">電</span><a href={`tel:${studio.phone}`}>{studio.phone}</a></div>
          <div class="c-row"><span aria-hidden="true">✉</span><a href={`mailto:${studio.email}`}>{studio.email}</a></div>
          <div class="c-row"><span aria-hidden="true">📸</span><a href={`https://instagram.com/${studio.instagram.replace('@','')}`} target="_blank" rel="noopener noreferrer">{studio.instagram}</a></div>
        </div>
      </div>
      <div>
        <span class="eyebrow" style="display:block;margin-bottom:0.5rem;">営業時間 — Hours</span>
        <table class="hours-tbl" aria-label="Studio hours">
          <tbody>
            {studio.hours.map(h => (
              <tr>
                <td>{h.day}</td>
                <td class={h.open==='Closed'?'closed':''}>{h.open==='Closed'?'定休日':` ${h.open} – ${h.close}`}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>

<!-- INSTAGRAM -->
<section id="instagram" class="section" aria-labelledby="ig-h">
  <div class="section-inner">
    <span class="eyebrow">Instagram</span>
    <h2 class="section-h" id="ig-h">Follow the Journey</h2>
    <div class="gold-stroke" aria-hidden="true"></div>
    <div class="ig-grid" role="list" aria-label="Instagram posts">
      {studio.igPosts.map(p => (
        <div class="ig-cell" role="listitem">
          <a href={p.link} aria-label={`Instagram: ${p.alt}`} target="_blank" rel="noopener noreferrer">
            <Picture formats={['avif','webp']} src={resolveImage(p.image)} alt={p.alt} loading="lazy" decoding="async" widths={[200, 400]} sizes="(min-width: 640px) 16vw, 33vw" width={400} height={400} />
          </a>
        </div>
      ))}
    </div>
    <div class="ig-cta"><a href={`https://instagram.com/${studio.instagram.replace('@','')}`} target="_blank" rel="noopener noreferrer">{studio.instagram}</a></div>
  </div>
</section>

<!-- FOOTER -->
<footer>
  <p class="foot-jp">龍墨</p>
  <p class="foot-en">Ryūboku Tattoo</p>
  <p class="foot-quote">"The needle follows five years of watching. The ink follows a lifetime of understanding."</p>
  <nav aria-label="Footer navigation">
    <ul class="foot-nav" role="list">
      <li><a href="#artists">Artists</a></li>
      <li><a href="#portfolio">Portfolio</a></li>
      <li><a href="#booking">Book</a></li>
      <li><a href="#faq">FAQ</a></li>
      <li><a href="#location">Location</a></li>
    </ul>
  </nav>
  <p class="foot-copy">&copy; 2024 Ryūboku Tattoo · {studio.address}, {studio.city}</p>
  <p style="margin-top:1.25rem;font-family:'Cormorant',serif;font-size:0.75rem;letter-spacing:0.12em;color:var(--gray);">Built by <a href="https://dcrader.dev" style="color:var(--gold);text-decoration:none;">Donovan Crader · dcrader.dev</a></p>
</footer>
</body>
</html>

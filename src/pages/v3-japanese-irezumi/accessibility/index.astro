---
import { studio } from '../../../data/v3';
import '../../../styles/global.css';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title>Accessibility Statement — {studio.name}</title>
  <meta name="description" content={`Accessibility statement for ${studio.name}.`}/>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@400;500;700&family=Cormorant:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet"/>
  <style>
    :root{--bg:#060606;--gold:#D4AE68;--cream:#EAD8B4;--red:#9B1324;}
    *{box-sizing:border-box;margin:0;padding:0;}
    body{background:var(--bg);color:var(--cream);font-family:'Cormorant',Georgia,serif;line-height:1.7;}
    .skip-link{position:absolute;top:-100px;left:0;background:var(--gold);color:var(--bg);padding:0.75rem 1.25rem;font-weight:700;text-decoration:none;z-index:9999;}
    .skip-link:focus{top:0;}
    *:focus-visible{outline:3px solid var(--gold)!important;outline-offset:2px;}
    nav{background:rgba(6,6,6,0.95);border-bottom:1px solid rgba(212,174,104,0.3);padding:1rem 2rem;}
    nav a{color:var(--gold);text-decoration:none;font-family:'Noto Serif JP',serif;letter-spacing:0.1em;}
    main{max-width:760px;margin:0 auto;padding:4rem 2rem;}
    h1{font-family:'Cormorant',serif;font-size:clamp(2.5rem,5vw,4rem);color:var(--cream);margin-bottom:1rem;font-weight:600;}
    .stroke{width:60px;height:3px;background:linear-gradient(to right,var(--red),var(--gold));margin:1rem 0 2rem;}
    h2{font-family:'Noto Serif JP',serif;font-size:1.3rem;color:var(--gold);margin:2rem 0 0.75rem;letter-spacing:0.05em;}
    p{margin-bottom:1rem;font-size:1.05rem;color:#D6C6A6;}
    a{color:var(--gold);text-decoration:underline;text-underline-offset:2px;}
    a:hover,a:focus-visible{color:var(--cream);}
    .updated{font-style:italic;color:#B0A088;font-size:0.95rem;margin-top:2rem;border-top:1px solid rgba(212,174,104,0.2);padding-top:1.5rem;}
    footer{background:#030303;color:#D6C6A6;padding:2rem;text-align:center;font-size:0.85rem;border-top:1px solid var(--red);}
    footer a{color:var(--gold);text-decoration:underline;}
  </style>
</head>
<body>
<a href="#main-content" class="skip-link">Skip to main content</a>
<nav aria-label="Main navigation">
  <a href="/v3-japanese-irezumi/">&larr; Back to {studio.name}</a>
</nav>
<main id="main-content">
  <h1>Accessibility Statement</h1>
  <div class="stroke" aria-hidden="true"></div>
  <p>{studio.name} is committed to ensuring digital accessibility for people of all abilities. We strive to conform to WCAG 2.1 Level AA standards and continuously improve the user experience for everyone.</p>

  <h2>Need Help?</h2>
  <p>If you experience any difficulty accessing this website, or need accommodations, please contact us at <a href={`mailto:accessibility@ryuboku-tattoo.com`}>accessibility@ryuboku-tattoo.com</a> or <a href={`tel:${studio.phone}`}>{studio.phone}</a> and we will work to provide the information or service through alternative communication.</p>

  <h2>Our Commitment</h2>
  <p>This site is reviewed regularly. We aim to meet or exceed Web Content Accessibility Guidelines 2.1 Level AA.</p>

  <p class="updated">Last updated: 2026-05-17</p>
</main>
<footer>
  <p>&copy; 2024 {studio.name} · <a href="/v3-japanese-irezumi/">Home</a></p>
</footer>
</body>
</html>

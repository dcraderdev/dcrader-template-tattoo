---
import '../styles/global.css';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>404 — Page Not Found · Tattoo Studio Templates</title>
  <meta name="description" content="The page you're looking for has faded like an old tattoo." />
  <meta name="robots" content="noindex" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Playfair+Display:wght@700;900&display=swap" rel="stylesheet" />
  <style>
    body { background:#0f0f0f; color:#f5f5f5; font-family:'Inter',system-ui,sans-serif; margin:0; min-height:100vh; display:flex; align-items:center; justify-content:center; padding:2rem; }
    main { text-align:center; max-width:560px; }
    .eyebrow { font-size:0.7rem; letter-spacing:0.2em; text-transform:uppercase; color:#555; margin:0 0 1.5rem; }
    .headline { font-size:clamp(6rem, 22vw, 11rem); font-weight:900; margin:0 0 0.5rem; line-height:1; font-family:'Playfair Display',Georgia,serif; background:linear-gradient(135deg,#D4A017 0%,#EC4899 50%,#7C3AED 100%); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; }
    .subhead { font-size:clamp(1.5rem,3.5vw,2rem); font-weight:700; margin:0 0 1.25rem; font-family:'Playfair Display',Georgia,serif; color:#f5f5f5; }
    .body { color:#999; max-width:440px; margin:0 auto 2.5rem; line-height:1.6; font-size:1.05rem; }
    .button { display:inline-block; padding:0.95rem 2.25rem; border-radius:9999px; text-decoration:none; font-weight:600; font-size:0.95rem; letter-spacing:0.05em; text-transform:uppercase; color:#0f0f0f; background:linear-gradient(135deg,#D4A017 0%,#EC4899 50%,#7C3AED 100%); transition:transform 0.2s, box-shadow 0.2s; border:none; cursor:pointer; }
    .button:hover { transform:translateY(-2px); box-shadow:0 14px 32px rgba(124,58,237,0.35); }
    .button:focus-visible { outline:3px solid #D4A017; outline-offset:4px; }
  </style>
</head>
<body>
  <main>
    <p class="eyebrow">dcrader templates</p>
    <h1 class="headline">404</h1>
    <p class="subhead">Page not found</p>
    <p class="body">This page has faded like an old tattoo. The link may be retired or mistyped — let's get you back to the studio.</p>
    <a class="button" href="/">Back to home</a>
  </main>
</body>
</html>

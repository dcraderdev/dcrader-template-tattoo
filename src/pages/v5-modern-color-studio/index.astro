---
import { Picture, getImage } from 'astro:assets';
import { studio } from '../../data/v5';
import { resolveImage } from '../../data/imageMap';
import StyleExplorerHero from '../../components/tattoo/StyleExplorerHero.astro';
const base = import.meta.env.BASE_URL;
const heroImg = resolveImage(studio.heroImage);
const heroWidths = [600, 1000, 1600];
const heroSrcset = (await Promise.all(
  heroWidths.map(async (w) => {
    const img = await getImage({ src: heroImg, width: w, format: 'webp' });
    return `${img.src} ${w}w`;
  })
)).join(', ');
const heroPreload = await getImage({ src: heroImg, width: 1600, format: 'webp' });
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{studio.name} — {studio.tagline}</title>
  <meta name="description" content={studio.description} />
  <link rel="canonical" href={Astro.url.href} />
  <meta property="og:title" content={`${studio.name} — ${studio.tagline}`} />
  <meta property="og:description" content={studio.description} />
  <meta property="og:image" content="/og-image.png" />
  <meta property="og:url" content={Astro.url.href} />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={`${studio.name} — ${studio.tagline}`} />
  <meta name="twitter:description" content={studio.description} />
  <meta name="twitter:image" content="/og-image.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Manrope:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href={`${base}styles/global.css`} />
  <link rel="preload" as="image" fetchpriority="high" type="image/webp" href={heroPreload.src} imagesrcset={heroSrcset} imagesizes="(min-width: 1024px) 50vw, 100vw"/>
  <style>
    :root {
      --cream: #FDFAF4;
      --cream-dark: #F4F0E6;
      --ink: #1A1208;
      --ink-soft: #3D3322;
      --mid: #7A6E5E;
      --light: #B8AFA0;
      --purple: #7C3AED;
      --pink: #EC4899;
      --teal: #0D9488;
      --orange: #F59E0B;
      --yellow: #EAB308;
      --red: #EF4444;
      --blue: #3B82F6;
      --display: 'Space Grotesk', sans-serif;
      --body: 'Manrope', sans-serif;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; background: var(--cream); color: var(--ink); }
    body { font-family: var(--body); background: var(--cream); color: var(--ink); }

    /* RAINBOW GRADIENT */
    .rainbow { background: linear-gradient(90deg, var(--purple), var(--pink), var(--orange), var(--teal)); }
    .rainbow-text {
      background: linear-gradient(90deg, var(--purple), var(--pink), var(--orange));
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .rainbow-border {
      border-image: linear-gradient(90deg, var(--purple), var(--pink), var(--orange), var(--teal)) 1;
    }

    /* NAV */
    .nav {
      position: fixed; top: 34px; left: 0; right: 0; z-index: 100;
      background: var(--cream); border-bottom: 2px solid var(--ink);
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 2.5rem; height: 64px; gap: 1rem;
    }
    .nav-right { display: flex; align-items: center; gap: 0.5rem; }
    .nav-logo {
      font-family: var(--display); font-size: 1.1rem; font-weight: 700;
      color: var(--ink); text-decoration: none; letter-spacing: -0.02em;
      white-space: nowrap;
    }
    .nav-logo .dot {
      display: inline-block; width: 8px; height: 8px; border-radius: 50%;
      background: linear-gradient(135deg, var(--purple), var(--pink));
      margin-left: 2px; vertical-align: middle;
    }
    .nav-links { display: flex; gap: 0.25rem; list-style: none; }
    .nav-links a {
      font-family: var(--body); font-size: 0.85rem; font-weight: 500;
      color: var(--ink); text-decoration: none; padding: 0.4rem 0.9rem;
      border-radius: 999px; transition: background 0.2s, color 0.2s;
    }
    .nav-links a:hover, .nav-links a:focus-visible { background: var(--cream-dark); outline: none; }
    .nav-links a:focus-visible { box-shadow: 0 0 0 2px var(--ink); }
    .nav-book {
      font-family: var(--display); font-size: 0.85rem; font-weight: 700;
      color: var(--cream); background: var(--ink);
      border: none; padding: 0.6rem 1.5rem; border-radius: 999px;
      cursor: pointer; text-decoration: none; display: inline-block;
      transition: transform 0.2s;
    }
    .nav-book:hover, .nav-book:focus-visible { transform: scale(1.04); outline: 2px solid var(--purple); outline-offset: 2px; }
    @media (max-width: 760px) {
      .nav { padding: 0 1rem; height: 56px; gap: 0.5rem; }
      .nav-links { display: none; }
      .nav-logo { font-size: 0.95rem; }
      .nav-book { font-size: 0.78rem; padding: 0.5rem 1.1rem; }
    }

    /* HERO */
    .hero {
      padding-top: 98px; background: var(--cream);
      min-height: 100vh; display: flex; flex-direction: column;
    }
    .hero-main {
      display: grid; grid-template-columns: 1fr 1fr;
      flex: 1;
    }
    .hero-text {
      padding: 5rem 4rem 4rem;
      display: flex; flex-direction: column; justify-content: center;
      background: var(--cream);
    }
    .hero-eyebrow {
      font-family: var(--body); font-size: 0.75rem; font-weight: 600;
      text-transform: uppercase; letter-spacing: 0.15em;
      color: var(--mid); margin-bottom: 1.5rem;
    }
    .hero-h1 {
      font-family: var(--display); font-size: clamp(3rem, 5vw, 4.5rem);
      font-weight: 700; line-height: 1.0; letter-spacing: -0.03em;
      margin-bottom: 1.5rem; color: var(--ink);
    }
    .hero-h1 .color-line {
      display: block;
      background: linear-gradient(90deg, var(--purple), var(--pink), var(--orange));
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .hero-tagline {
      font-family: var(--body); font-size: 1.05rem; color: var(--ink-soft);
      line-height: 1.7; margin-bottom: 2.5rem; max-width: 40ch; font-weight: 400;
    }
    .hero-palette { display: flex; gap: 0.6rem 1rem; flex-wrap: wrap; align-items: center; margin-bottom: 2.5rem; }
    .palette-label {
      font-family: var(--body); font-size: 0.7rem; font-weight: 500;
      color: var(--mid); letter-spacing: 0.02em;
      width: 100%; margin-bottom: -0.15rem;
    }
    .palette-swatch {
      display: inline-flex; align-items: center; gap: 0.45rem;
      font-family: var(--body); font-size: 0.78rem; font-weight: 500;
      color: var(--ink); padding: 0.25rem 0.6rem 0.25rem 0.3rem;
      border-radius: 999px; background: rgba(0,0,0,0.04);
    }
    .palette-swatch .dot {
      width: 0.85rem; height: 0.85rem; border-radius: 50%;
      box-shadow: 0 0 0 1.5px rgba(255,255,255,0.8), 0 0 0 2.5px rgba(0,0,0,0.08);
      flex-shrink: 0;
    }
    .hero-ctas { display: flex; gap: 1rem; align-items: center; }
    .btn-big {
      font-family: var(--display); font-size: 0.95rem; font-weight: 700;
      color: var(--cream); background: var(--ink);
      border: 2px solid var(--ink); padding: 0.875rem 2rem; border-radius: 999px;
      cursor: pointer; text-decoration: none; display: inline-block;
      transition: transform 0.2s, background 0.2s;
    }
    .btn-big:hover { transform: scale(1.03); }
    .btn-ghost {
      font-family: var(--display); font-size: 0.95rem; font-weight: 600;
      color: var(--ink); background: transparent;
      border: 2px solid var(--ink); padding: 0.875rem 2rem; border-radius: 999px;
      cursor: pointer; text-decoration: none; display: inline-block;
      transition: transform 0.2s, background 0.2s;
    }
    .btn-ghost:hover { background: var(--cream-dark); transform: scale(1.03); }
    .hero-image-panel { position: relative; overflow: hidden; }
    .hero-image-panel img {
      width: 100%; height: 100%; object-fit: cover; display: block;
    }
    .hero-image-badge {
      position: absolute; top: 2rem; right: 2rem;
      background: var(--cream); border: 2px solid var(--ink);
      border-radius: 999px; padding: 0.5rem 1rem;
      font-family: var(--body); font-size: 0.7rem; font-weight: 700;
      color: var(--ink); letter-spacing: 0.05em; text-transform: uppercase;
    }
    .hero-bar {
      height: 6px;
      background: linear-gradient(90deg, var(--purple), var(--pink), var(--orange), var(--yellow), var(--teal), var(--blue));
    }

    /* CONTAINER */
    .container { max-width: 1200px; margin: 0 auto; padding: 0 2.5rem; }

    /* SECTION */
    .section { padding: 6rem 0; }
    .section-label {
      font-family: var(--body); font-size: 0.7rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.15em; color: var(--mid);
      margin-bottom: 0.75rem;
    }
    .section-h2 {
      font-family: var(--display); font-size: clamp(2rem, 3vw, 2.75rem);
      font-weight: 700; letter-spacing: -0.02em; color: var(--ink);
      margin-bottom: 1rem; line-height: 1.1;
    }
    .section-sub {
      font-family: var(--body); font-size: 1rem; color: var(--ink-soft);
      max-width: 50ch; line-height: 1.7;
    }
    .section-intro { margin-bottom: 3.5rem; }

    /* FLASH SHEET */
    .flash-section { background: var(--cream-dark); padding: 6rem 0; }
    .flash-grid {
      display: grid; grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
    }
    .flash-card {
      background: var(--cream); border-radius: 16px; overflow: hidden;
      border: 2px solid transparent;
      transition: transform 0.3s, border-color 0.3s, box-shadow 0.3s;
      position: relative;
    }
    .flash-card:nth-child(4n+1) { border-color: var(--purple); }
    .flash-card:nth-child(4n+2) { border-color: var(--pink); }
    .flash-card:nth-child(4n+3) { border-color: var(--teal); }
    .flash-card:nth-child(4n+4) { border-color: var(--orange); }
    .flash-card:hover { transform: translateY(-6px); box-shadow: 0 12px 40px rgba(0,0,0,0.12); }
    .flash-card img {
      width: 100%; aspect-ratio: 1; object-fit: cover; display: block;
    }
    .flash-card-info { padding: 0.875rem 1rem 1rem; }
    .flash-card-artist {
      font-family: var(--body); font-size: 0.65rem; font-weight: 600;
      text-transform: uppercase; letter-spacing: 0.1em; color: var(--mid);
    }
    .flash-card-style {
      font-family: var(--display); font-size: 0.9rem; font-weight: 700;
      color: var(--ink); margin-top: 0.15rem;
    }

    /* ARTISTS */
    .artists-section { padding: 6rem 0; }
    .artists-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }
    .artist-card {
      background: var(--cream); border: 2px solid var(--cream-dark);
      border-radius: 20px; overflow: hidden;
      transition: transform 0.3s, box-shadow 0.3s;
    }
    .artist-card:hover { transform: translateY(-4px); box-shadow: 0 16px 48px rgba(0,0,0,0.1); }
    .artist-card-image { position: relative; }
    .artist-card-image img {
      width: 100%; aspect-ratio: 4/3; object-fit: cover; display: block;
    }
    .artist-card-color-bar {
      height: 4px;
    }
    .artist-card:nth-child(1) .artist-card-color-bar { background: linear-gradient(90deg, var(--purple), var(--pink)); }
    .artist-card:nth-child(2) .artist-card-color-bar { background: linear-gradient(90deg, var(--teal), var(--blue)); }
    .artist-card:nth-child(3) .artist-card-color-bar { background: linear-gradient(90deg, var(--orange), var(--yellow)); }
    .artist-card-body { padding: 1.5rem; }
    .artist-card-name {
      font-family: var(--display); font-size: 1.2rem; font-weight: 700;
      color: var(--ink); margin-bottom: 0.2rem;
    }
    .artist-card-handle {
      font-family: var(--body); font-size: 0.75rem; color: var(--mid);
      font-weight: 500; display: block; margin-bottom: 0.5rem;
    }
    .artist-card-specialty {
      font-family: var(--body); font-size: 0.75rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.08em;
      margin-bottom: 1rem;
    }
    .artist-card:nth-child(1) .artist-card-specialty { color: var(--purple); }
    .artist-card:nth-child(2) .artist-card-specialty { color: var(--teal); }
    .artist-card:nth-child(3) .artist-card-specialty { color: var(--orange); }
    .artist-card-bio {
      font-family: var(--body); font-size: 0.85rem; color: var(--ink-soft);
      line-height: 1.7; font-weight: 400; margin-bottom: 1.25rem;
    }
    .artist-card-exp {
      font-family: var(--body); font-size: 0.7rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.1em; color: var(--mid);
    }
    .artist-styles { display: flex; gap: 0.4rem; flex-wrap: wrap; margin-top: 0.75rem; }
    .artist-style-tag {
      font-family: var(--body); font-size: 0.65rem; font-weight: 600;
      padding: 0.2rem 0.6rem; border-radius: 999px;
      background: var(--cream-dark); color: var(--ink-soft);
    }

    /* MANIFESTO */
    .manifesto-section {
      background: var(--ink); padding: 7rem 0; text-align: center;
    }
    .manifesto-eyebrow {
      font-family: var(--body); font-size: 0.7rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.2em; color: var(--light);
      margin-bottom: 2rem;
    }
    .manifesto-text {
      font-family: var(--display); font-size: clamp(2rem, 4vw, 3.5rem);
      font-weight: 700; line-height: 1.2; letter-spacing: -0.02em;
      max-width: 18ch; margin: 0 auto 2.5rem;
      background: linear-gradient(135deg, var(--cream) 0%, var(--pink) 40%, var(--purple) 70%, var(--teal) 100%);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .manifesto-sub {
      font-family: var(--body); font-size: 1rem; color: var(--light);
      max-width: 48ch; margin: 0 auto; line-height: 1.7; font-weight: 400;
    }

    /* ON THE TABLE — current-moment zine vignette */
    .ott-section { padding: 6rem 0; background: var(--cream-dark); border-top: 2px solid var(--ink); border-bottom: 2px solid var(--ink); position: relative; overflow: hidden; }
    .ott-section::before {
      content: ''; position: absolute; top: -30px; right: -30px;
      width: 220px; height: 220px; border-radius: 50%;
      background: radial-gradient(circle, var(--yellow) 0%, transparent 70%);
      opacity: 0.45; pointer-events: none;
    }
    .ott-section::after {
      content: ''; position: absolute; bottom: -40px; left: -40px;
      width: 260px; height: 260px; border-radius: 50%;
      background: radial-gradient(circle, var(--pink) 0%, transparent 70%);
      opacity: 0.35; pointer-events: none;
    }
    .ott-inner { position: relative; z-index: 1; }
    .ott-stamp {
      display: inline-flex; align-items: center; gap: 0.5rem;
      font-family: var(--body); font-size: 0.7rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.18em; color: var(--ink);
      background: var(--cream); border: 2px solid var(--ink);
      padding: 0.4rem 0.85rem; border-radius: 999px;
      transform: rotate(-1.5deg); margin-bottom: 1.5rem;
    }
    .ott-dot {
      width: 8px; height: 8px; border-radius: 50%;
      background: var(--pink); box-shadow: 0 0 0 2px rgba(236,72,153,0.25);
      animation: ottPulse 2.4s ease-in-out infinite;
    }
    @keyframes ottPulse { 0%,100%{transform:scale(1);} 50%{transform:scale(1.35);} }
    .ott-headline {
      font-family: var(--display); font-size: clamp(2.2rem, 5vw, 4rem);
      font-weight: 700; line-height: 1; letter-spacing: -0.03em; color: var(--ink);
      max-width: 14ch; margin-bottom: 0.85rem;
    }
    .ott-headline em {
      font-style: normal;
      background: linear-gradient(90deg, var(--purple), var(--pink), var(--orange));
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .ott-byline {
      font-family: var(--body); font-size: 1rem; color: var(--ink-soft);
      max-width: 50ch; line-height: 1.7; margin-bottom: 3rem;
    }
    .ott-grid {
      display: grid; grid-template-columns: 1.3fr 0.9fr 0.9fr;
      gap: 1.25rem; align-items: stretch;
    }
    @media(max-width:820px){ .ott-grid { grid-template-columns: 1fr; } }
    .ott-card {
      background: var(--cream); border: 2px solid var(--ink);
      border-radius: 16px; padding: 1.75rem 1.5rem;
      box-shadow: 6px 6px 0 var(--ink);
      display: flex; flex-direction: column;
    }
    .ott-card.featured {
      background: var(--ink); color: var(--cream);
      transform: rotate(-0.5deg);
    }
    .ott-card.featured .ott-card-label { color: var(--yellow); }
    .ott-card.featured .ott-card-title { color: var(--cream); }
    .ott-card.featured .ott-card-body { color: rgba(253,250,244,0.78); }
    .ott-card.tilt-r { transform: rotate(0.6deg); }
    .ott-card.tilt-l { transform: rotate(-0.9deg); }
    .ott-card-label {
      font-family: var(--body); font-size: 0.62rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.22em; color: var(--purple);
      margin-bottom: 0.5rem;
    }
    .ott-card-title {
      font-family: var(--display); font-size: 1.4rem; font-weight: 700;
      line-height: 1.15; color: var(--ink); margin-bottom: 0.85rem;
      letter-spacing: -0.01em;
    }
    .ott-card-body {
      font-family: var(--body); font-size: 0.9rem; line-height: 1.65;
      color: var(--ink-soft); flex: 1;
    }
    .ott-card-foot {
      margin-top: 1.25rem; padding-top: 1rem;
      border-top: 1px dashed rgba(26,18,8,0.35);
      font-family: var(--body); font-size: 0.7rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.12em; color: var(--mid);
      display: flex; justify-content: space-between; gap: 1rem;
    }
    .ott-card.featured .ott-card-foot { border-top-color: rgba(253,250,244,0.25); color: rgba(253,250,244,0.65); }
    .ott-swatches { display: flex; gap: 0.4rem; margin-top: 1rem; }
    .ott-swatch { width: 22px; height: 22px; border-radius: 50%; border: 2px solid var(--cream); box-shadow: 0 0 0 1px rgba(0,0,0,0.15); }

    /* AFTERCARE */
    .aftercare-section { padding: 6rem 0; }
    .aftercare-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }
    .aftercare-card {
      background: var(--cream-dark); border-radius: 16px; padding: 2rem;
      position: relative; overflow: hidden;
    }
    .aftercare-card::before {
      content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px;
    }
    .aftercare-card:nth-child(1)::before { background: var(--purple); }
    .aftercare-card:nth-child(2)::before { background: var(--pink); }
    .aftercare-card:nth-child(3)::before { background: var(--teal); }
    .aftercare-card:nth-child(4)::before { background: var(--orange); }
    .aftercare-card:nth-child(5)::before { background: var(--yellow); }
    .aftercare-card:nth-child(6)::before { background: var(--blue); }
    .aftercare-num {
      font-family: var(--display); font-size: 3rem; font-weight: 700;
      line-height: 1; color: var(--mid); margin-bottom: 1rem;
    }
    .aftercare-title {
      font-family: var(--display); font-size: 1rem; font-weight: 700;
      color: var(--ink); margin-bottom: 0.75rem;
    }
    .aftercare-body {
      font-family: var(--body); font-size: 0.875rem; color: var(--ink-soft);
      line-height: 1.7; font-weight: 400;
    }

    /* BOOKING */
    .booking-section { background: var(--cream-dark); padding: 6rem 0; }
    .booking-inner {
      display: grid; grid-template-columns: 1fr 1fr; gap: 5rem;
      align-items: start;
    }
    .booking-left {}
    .booking-price-cards { display: flex; flex-direction: column; gap: 0.75rem; margin-top: 2rem; }
    .price-card {
      background: var(--cream); border-radius: 12px; padding: 1.25rem 1.5rem;
      display: flex; justify-content: space-between; align-items: center;
      border: 2px solid transparent;
    }
    .price-card:nth-child(1) { border-color: var(--purple); }
    .price-card:nth-child(2) { border-color: var(--teal); }
    .price-card:nth-child(3) { border-color: var(--orange); }
    .price-label {
      font-family: var(--body); font-size: 0.8rem; font-weight: 600; color: var(--ink-soft);
    }
    .price-value {
      font-family: var(--display); font-size: 1.1rem; font-weight: 700; color: var(--ink);
    }
    .booking-form {
      background: var(--cream); border-radius: 20px; padding: 2.5rem;
      border: 2px solid var(--ink);
    }
    .form-title {
      font-family: var(--display); font-size: 1.3rem; font-weight: 700;
      color: var(--ink); margin-bottom: 1.75rem;
    }
    .form-group { margin-bottom: 1.25rem; }
    .form-label {
      font-family: var(--body); font-size: 0.7rem; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.1em;
      color: var(--mid); display: block; margin-bottom: 0.4rem;
    }
    .form-input {
      width: 100%; font-family: var(--body); font-size: 0.9rem; font-weight: 400;
      color: var(--ink); background: var(--cream-dark);
      border: 2px solid var(--cream-dark); border-radius: 10px;
      padding: 0.75rem 1rem; outline: none;
      transition: border-color 0.2s;
    }
    .form-input:focus { border-color: var(--ink); }
    .form-input::placeholder { color: var(--mid); }
    select.form-input { appearance: none; cursor: pointer; }
    textarea.form-input { resize: none; min-height: 100px; }
    .form-submit {
      width: 100%; margin-top: 0.5rem;
      font-family: var(--display); font-size: 0.95rem; font-weight: 700;
      letter-spacing: -0.01em; color: var(--cream); background: var(--ink);
      border: 2px solid var(--ink); border-radius: 10px;
      padding: 1rem; cursor: pointer;
      transition: transform 0.2s, background 0.2s;
    }
    .form-submit:hover { transform: scale(1.02); }

    /* FAQ */
    .faq-section { padding: 6rem 0; }
    .faq-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .faq-card {
      background: var(--cream-dark); border-radius: 16px; padding: 1.75rem;
      border: 2px solid transparent; transition: border-color 0.2s;
    }
    .faq-card:hover { border-color: var(--light); }
    .faq-q {
      font-family: var(--display); font-size: 0.95rem; font-weight: 700;
      color: var(--ink); margin-bottom: 0.75rem; line-height: 1.3;
    }
    .faq-a {
      font-family: var(--body); font-size: 0.875rem; color: var(--ink-soft);
      line-height: 1.7; font-weight: 400;
    }

    /* INSTAGRAM */
    .ig-section { background: var(--cream-dark); padding: 6rem 0; }
    .ig-handle-display {
      font-family: var(--display); font-size: clamp(2rem, 4vw, 3rem);
      font-weight: 700; letter-spacing: -0.02em;
      background: linear-gradient(90deg, var(--purple), var(--pink), var(--orange));
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text; margin-bottom: 2.5rem;
    }
    .ig-grid {
      display: grid; grid-template-columns: repeat(6, 1fr); gap: 0.75rem;
    }
    .ig-post { aspect-ratio: 1; overflow: hidden; border-radius: 12px; display: block; }
    .ig-post img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.4s; }
    .ig-post:hover img { transform: scale(1.08); }

    /* LOCATION */
    .location-section { padding: 6rem 0; }
    .location-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; }
    .hours-list { display: flex; flex-direction: column; gap: 0; }
    .hours-row {
      display: flex; justify-content: space-between;
      padding: 0.875rem 0; border-bottom: 1.5px solid var(--cream-dark);
    }
    .hours-day { font-family: var(--body); font-size: 0.85rem; font-weight: 600; color: var(--ink); }
    .hours-time { font-family: var(--body); font-size: 0.85rem; font-weight: 400; color: var(--ink-soft); }
    .hours-time.closed { color: var(--mid); font-style: italic; }
    .contact-list { display: flex; flex-direction: column; gap: 1.5rem; }
    .contact-item {}
    .contact-label { font-family: var(--body); font-size: 0.65rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--mid); margin-bottom: 0.25rem; }
    .contact-value {
      font-family: var(--body); font-size: 0.95rem; font-weight: 500;
      color: var(--ink); text-decoration: none;
    }
    .contact-value:hover { text-decoration: underline; }

    /* FOOTER */
    footer {
      background: var(--ink); padding: 3rem 2.5rem;
      display: flex; align-items: center; justify-content: space-between;
    }
    .footer-name {
      font-family: var(--display); font-size: 1rem; font-weight: 700;
      background: linear-gradient(90deg, var(--pink), var(--purple));
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .footer-tagline {
      font-family: var(--body); font-size: 0.75rem; color: var(--light);
      font-weight: 400;
    }
    .footer-copy {
      font-family: var(--body); font-size: 0.7rem; color: var(--light);
    }

    @media (max-width: 768px) {
      .hero-main { grid-template-columns: 1fr; }
      .flash-grid { grid-template-columns: repeat(2, 1fr); }
      .artists-grid { grid-template-columns: 1fr; }
      .aftercare-grid { grid-template-columns: 1fr 1fr; }
      .booking-inner { grid-template-columns: 1fr; }
      .faq-grid { grid-template-columns: 1fr; }
      .ig-grid { grid-template-columns: repeat(3, 1fr); }
      .location-grid { grid-template-columns: 1fr; }
    }
  </style>
  <script src="/template-topheader.js" defer></script>
  <style>
    html { scroll-padding-top: 40px !important; }
    body { padding-top: 36px !important; }
    body > #dcrader-topheader, body > [data-dcrader-topheader] { padding-top: 0 !important; margin-top: -36px !important; }
  </style>
</head>
<body>
  <a href="#main" class="sr-only">Skip to main content</a>

  <!-- NAV -->
  <nav class="nav" role="navigation" aria-label="Main navigation">
    <a href={`${base}v5-modern-color-studio`} class="nav-logo">
      {studio.name}<span class="dot" aria-hidden="true"></span>
    </a>
    <div class="nav-right">
      <ul class="nav-links" role="list">
        <li><a href="#gallery">Gallery</a></li>
        <li><a href="#artists">Artists</a></li>
        <li><a href="/v5-modern-color-studio/color-aftercare">Color Aftercare</a></li>
      </ul>
      <a href="#booking" class="nav-book">Book Now</a>
    </div>
  </nav>

  <!-- HERO -->
  <main id="main">
    <StyleExplorerHero studio={studio} />

    <!-- FLASH GALLERY -->
    <section class="flash-section" id="gallery" aria-labelledby="gallery-heading">
      <div class="container">
        <div class="section-intro">
          <p class="section-label">Portfolio</p>
          <h2 class="section-h2" id="gallery-heading">Flash Sheet</h2>
          <p class="section-sub">Every piece a study in color. Every artist a different palette. Pick your obsession.</p>
        </div>
        <div class="flash-grid" role="list" aria-label="Portfolio gallery">
          {studio.gallery.map(item => (
            <div class="flash-card" role="listitem">
              <Picture formats={['avif','webp']} src={resolveImage(item.image)} alt={item.alt} loading="lazy" decoding="async" widths={[300, 600]} sizes="(min-width: 1024px) 25vw, 50vw" width={600} height={600} />
              <div class="flash-card-info">
                <div class="flash-card-artist">{item.artist}</div>
                <div class="flash-card-style">{item.style}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- MANIFESTO -->
    <section class="manifesto-section" aria-labelledby="manifesto-heading">
      <div class="container" style="text-align:center;">
        <p class="manifesto-eyebrow">Our philosophy</p>
        <h2 class="manifesto-text" id="manifesto-heading">
          Black ink is a whisper. Color is a shout.
        </h2>
        <p class="manifesto-sub">
          We believe a tattoo should stop people in the street. We believe color is the language skin was made for. Every piece we make is designed to last decades and turn heads for all of them.
        </p>
      </div>
    </section>

    <!-- ARTISTS -->
    <section class="artists-section" id="artists" aria-labelledby="artists-heading">
      <div class="container">
        <div class="section-intro">
          <p class="section-label">Meet the team</p>
          <h2 class="section-h2" id="artists-heading">The Artists</h2>
          <p class="section-sub">Three obsessives. Three different color languages. One shared belief that pigment is poetry.</p>
        </div>
        <div class="artists-grid" role="list">
          {studio.artists.map(artist => (
            <article class="artist-card" role="listitem">
              <div class="artist-card-image">
                <Picture formats={['avif','webp']} src={resolveImage(artist.image)} alt={`Portrait of ${artist.name}`} loading="lazy" decoding="async" widths={[300, 600, 800]} sizes="(min-width: 1024px) 33vw, 100vw" width={800} height={600} />
              </div>
              <div class="artist-card-color-bar" aria-hidden="true"></div>
              <div class="artist-card-body">
                <h3 class="artist-card-name">{artist.name}</h3>
                <span class="artist-card-handle">{artist.handle}</span>
                <p class="artist-card-specialty">{artist.specialty}</p>
                <p class="artist-card-bio">{artist.bio}</p>
                <p class="artist-card-exp">{artist.yearsExp} years experience</p>
                <ul class="artist-styles" role="list" aria-label={`${artist.name} styles`}>
                  {artist.styles.map(s => (
                    <li class="artist-style-tag" role="listitem">{s}</li>
                  ))}
                </ul>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ON THE TABLE TODAY — current-moment vignette -->
    <section class="ott-section" id="today" aria-labelledby="ott-heading">
      <div class="container ott-inner">
        <span class="ott-stamp"><span class="ott-dot" aria-hidden="true"></span> Live from the studio · Thursday afternoon</span>
        <h2 class="ott-headline" id="ott-heading">On the table <em>right now.</em></h2>
        <p class="ott-byline">Three machines humming, one client mid-session, two more on the books before the door locks at 7. Here's exactly what's happening at Spectrum this hour — no stock photos, no stats grids.</p>
        <div class="ott-grid">
          <article class="ott-card featured" aria-label="Currently in session">
            <span class="ott-card-label">In the chair · Station 02</span>
            <h3 class="ott-card-title">Priya is four hours into a neo-traditional peony sleeve — full-color, day two of three.</h3>
            <p class="ott-card-body">Custom design built across six weeks of consultation. Today: outline finalization on the lower arm, first colour pass on the central blossom. Client brought her own playlist — early-2000s indie, loud.</p>
            <div class="ott-swatches" aria-label="Palette in use today">
              <span class="ott-swatch" style="background:#EC4899" title="Magenta"></span>
              <span class="ott-swatch" style="background:#F59E0B" title="Marigold"></span>
              <span class="ott-swatch" style="background:#7C3AED" title="Iris"></span>
              <span class="ott-swatch" style="background:#0D9488" title="Jade"></span>
              <span class="ott-swatch" style="background:#EAB308" title="Sun"></span>
            </div>
            <div class="ott-card-foot">
              <span>Hour 4 of 7</span>
              <span>Next break · 4:15</span>
            </div>
          </article>
          <article class="ott-card tilt-r" aria-label="On deck next">
            <span class="ott-card-label" style="color:var(--teal);">Next up · 5pm</span>
            <h3 class="ott-card-title">Theo's anime back-piece consult — third session, lining the kitsune.</h3>
            <p class="ott-card-body">Three-hour block reserved. Reference printed, stencil already on the light box, client texted ETA 4:45.</p>
            <div class="ott-card-foot">
              <span>Theo · Station 01</span>
              <span>Walk-in? No.</span>
            </div>
          </article>
          <article class="ott-card tilt-l" aria-label="Sketchbook in progress">
            <span class="ott-card-label" style="color:var(--orange);">On the drawing table</span>
            <h3 class="ott-card-title">Imani is finishing a watercolor hummingbird flash sheet — six pieces, posted Friday.</h3>
            <p class="ott-card-body">Drying now on the back counter. First-come on Saturday's walk-in slot — DM the studio if you want first look before they go up on the grid.</p>
            <div class="ott-card-foot">
              <span>Flash · 6 pieces</span>
              <span>Posted · Fri 10am</span>
            </div>
          </article>
        </div>
      </div>
    </section>

    <!-- AFTERCARE -->
    <section class="aftercare-section" id="aftercare" aria-labelledby="aftercare-heading">
      <div class="container">
        <div class="section-intro">
          <p class="section-label">Post-session</p>
          <h2 class="section-h2" id="aftercare-heading">Aftercare Guide</h2>
          <p class="section-sub">Color fades faster when neglected. Follow these steps and your piece will stay vivid for decades.</p>
        </div>
        <ul class="aftercare-grid" role="list">
          {studio.aftercare.map(item => (
            <li class="aftercare-card" role="listitem">
              <div class="aftercare-num" aria-hidden="true">{String(item.step).padStart(2,'0')}</div>
              <h3 class="aftercare-title">{item.title}</h3>
              <p class="aftercare-body">{item.body}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- BOOKING -->
    <section class="booking-section" id="booking" aria-labelledby="booking-heading">
      <div class="container">
        <div class="booking-inner">
          <div class="booking-left">
            <p class="section-label">Get started</p>
            <h2 class="section-h2" id="booking-heading">Ready to book?</h2>
            <p class="section-sub" style="margin-bottom:0;">Fill out the form and we'll reach out within 48 hours to schedule your consultation. Color takes planning — we'll walk you through everything.</p>
            <div class="booking-price-cards" role="list" aria-label="Pricing information">
              <div class="price-card" role="listitem">
                <span class="price-label">Shop minimum</span>
                <span class="price-value">${studio.minimumCharge}</span>
              </div>
              <div class="price-card" role="listitem">
                <span class="price-label">Hourly rate</span>
                <span class="price-value">${studio.hourlyRate}/hr</span>
              </div>
              <div class="price-card" role="listitem">
                <span class="price-label">Booking deposit</span>
                <span class="price-value">${studio.depositAmount}</span>
              </div>
            </div>
          </div>
          <div class="booking-form">
            <h3 class="form-title">Inquiry form</h3>
            <form aria-label="Booking inquiry form" novalidate>
              <div class="form-group">
                <label class="form-label" for="name">Your name</label>
                <input type="text" id="name" name="name" class="form-input" placeholder="Full name" autocomplete="name" />
              </div>
              <div class="form-group">
                <label class="form-label" for="email">Email address</label>
                <input type="email" id="email" name="email" class="form-input" placeholder="your@email.com" autocomplete="email" />
              </div>
              <div class="form-group">
                <label class="form-label" for="artist">Preferred artist</label>
                <select id="artist" name="artist" class="form-input">
                  <option value="">Any available</option>
                  {studio.artists.map(a => <option value={a.name}>{a.name}</option>)}
                </select>
              </div>
              <div class="form-group">
                <label class="form-label" for="style">Style interest</label>
                <select id="style" name="style" class="form-input">
                  <option value="">Choose a style</option>
                  <option>Neo-Traditional</option>
                  <option>New School</option>
                  <option>Illustrative</option>
                  <option>Watercolor</option>
                  <option>Japanese Color</option>
                  <option>Not sure — help me decide</option>
                </select>
              </div>
              <div class="form-group">
                <label class="form-label" for="concept">Tell us about your idea</label>
                <textarea id="concept" name="concept" class="form-input" placeholder="Describe your concept, size, placement, and any color preferences. The more detail, the better." rows={4}></textarea>
              </div>
              <button type="submit" class="form-submit">Send Inquiry</button>
            </form>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="faq-section" id="faq" aria-labelledby="faq-heading">
      <div class="container">
        <div class="section-intro">
          <p class="section-label">Questions</p>
          <h2 class="section-h2" id="faq-heading">FAQ</h2>
        </div>
        <ul class="faq-grid" role="list">
          {studio.faqs.map(faq => (
            <li class="faq-card" role="listitem">
              <h3 class="faq-q">{faq.question}</h3>
              <p class="faq-a">{faq.answer}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- INSTAGRAM -->
    <section class="ig-section" aria-labelledby="ig-heading">
      <div class="container">
        <div class="section-intro">
          <p class="section-label">Follow along</p>
          <h2 class="ig-handle-display" id="ig-heading">{studio.instagram}</h2>
        </div>
        <div class="ig-grid" role="list" aria-label="Instagram feed">
          {studio.igPosts.map(post => (
            <a href={post.link} class="ig-post" target="_blank" rel="noopener noreferrer" role="listitem" aria-label={post.alt}>
              <Picture formats={['avif','webp']} src={resolveImage(post.image)} alt={post.alt} loading="lazy" decoding="async" widths={[200, 400]} sizes="(min-width: 640px) 16vw, 33vw" width={400} height={400} />
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- LOCATION -->
    <section class="location-section" id="location" aria-labelledby="location-heading">
      <div class="container">
        <div class="section-intro">
          <p class="section-label">Find us</p>
          <h2 class="section-h2" id="location-heading">Location & Hours</h2>
        </div>
        <div class="location-grid">
          <div>
            <h3 style="font-family: var(--display); font-size: 0.85rem; font-weight: 700; color: var(--mid); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1.25rem;">Hours</h3>
            <ul class="hours-list" role="list">
              {studio.hours.map(h => (
                <li class="hours-row" role="listitem">
                  <span class="hours-day">{h.day}</span>
                  <span class={`hours-time${h.open === 'Closed' ? ' closed' : ''}`}>
                    {h.open === 'Closed' ? 'Closed' : `${h.open} – ${h.close}`}
                  </span>
                </li>
              ))}
            </ul>
          </div>
          <div>
            <h3 style="font-family: var(--display); font-size: 0.85rem; font-weight: 700; color: var(--mid); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1.25rem;">Contact</h3>
            <ul class="contact-list" role="list">
              <li class="contact-item" role="listitem">
                <div class="contact-label">Address</div>
                <a href={studio.mapUrl} class="contact-value" target="_blank" rel="noopener noreferrer">{studio.address}, {studio.city}</a>
              </li>
              <li class="contact-item" role="listitem">
                <div class="contact-label">Phone</div>
                <a href={`tel:${studio.phone}`} class="contact-value">{studio.phone}</a>
              </li>
              <li class="contact-item" role="listitem">
                <div class="contact-label">Email</div>
                <a href={`mailto:${studio.email}`} class="contact-value">{studio.email}</a>
              </li>
              <li class="contact-item" role="listitem">
                <div class="contact-label">Instagram</div>
                <span class="contact-value">{studio.instagram}</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer>
    <div>
      <div class="footer-name">{studio.name}</div>
      <div class="footer-tagline">{studio.tagline}</div>
    </div>
    <div class="footer-copy">&copy; {new Date().getFullYear()} {studio.name}. San Diego, CA. All rights reserved.</div>
    <div style="grid-column:1/-1;width:100%;text-align:center;padding-top:1.5rem;border-top:1px solid rgba(0,0,0,0.06);margin-top:1.5rem;font-family:'Space Grotesk',sans-serif;font-size:0.75rem;color:#8a7a5a;">Built by <a href="https://dcrader.dev" style="color:#7C3AED;text-decoration:none;font-weight:500;">Donovan Crader · dcrader.dev</a></div>
  </footer>
</body>
</html>

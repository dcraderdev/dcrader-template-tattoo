---
import { studio } from '../../data/v5';
import '../../styles/global.css';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{studio.name} — Modern Color Tattoo, {studio.city}</title>
  <meta name="description" content={studio.description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet" />
  <style>
    :root {
      --cream: #FFFEF7;
      --cream2: #F7F5E8;
      --dark: #1A1A2E;
      --dark2: #252540;
      --purple: #7C3AED;
      --purple-light: #A78BFA;
      --pink: #EC4899;
      --pink-light: #F9A8D4;
      --teal: #0D9488;
      --orange: #F59E0B;
      --green: #10B981;
      --red: #EF4444;
      --text: #1A1A2E;
      --text2: #4B5563;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { background: var(--cream); color: var(--text); font-family: 'Nunito', system-ui, sans-serif; }

    /* Gradient helpers */
    .grad-text { background: linear-gradient(135deg, var(--purple) 0%, var(--pink) 50%, var(--orange) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
    .grad-bg { background: linear-gradient(135deg, var(--purple) 0%, var(--pink) 100%); }
    .grad-border { border-image: linear-gradient(135deg, var(--purple), var(--pink), var(--orange)) 1; }

    /* Nav */
    .nav { background: var(--cream); border-bottom: 2px solid var(--cream2); position: sticky; top: 0; z-index: 100; }
    .nav-inner { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; display: flex; align-items: center; justify-content: space-between; min-height: 64px; flex-wrap: wrap; gap: 0.5rem; }
    .nav-logo { font-family: 'DM Serif Display', serif; font-size: 1.25rem; color: var(--dark); text-decoration: none; display: flex; align-items: center; gap: 0.5rem; }
    .nav-logo .dot { width: 8px; height: 8px; border-radius: 50%; background: linear-gradient(135deg, var(--purple), var(--pink)); display: inline-block; }
    .nav-links { display: flex; gap: 0; list-style: none; flex-wrap: wrap; }
    .nav-links a { color: var(--text2); text-decoration: none; font-size: 0.8rem; font-weight: 600; letter-spacing: 0.04em; padding: 0.5rem 0.85rem; display: block; transition: color 0.2s; }
    .nav-links a:hover, .nav-links a:focus-visible { color: var(--purple); }
    .nav-cta { background: linear-gradient(135deg, var(--purple), var(--pink)) !important; color: white !important; border-radius: 50px !important; padding: 0.5rem 1.25rem !important; font-weight: 700 !important; }
    .nav-cta:hover, .nav-cta:focus-visible { opacity: 0.9; }

    /* Hero */
    .hero { background: var(--dark); position: relative; min-height: 90vh; display: flex; align-items: center; overflow: hidden; }
    .hero-bg { position: absolute; inset: 0; background-image: linear-gradient(135deg, rgba(124,58,237,0.6) 0%, rgba(236,72,153,0.4) 50%, rgba(13,148,136,0.3) 100%), url('https://images.unsplash.com/photo-1567593810070-7a3d471af022?w=1920&q=85&auto=format&fit=crop'); background-size: cover; background-position: center; }
    .hero-blobs { position: absolute; inset: 0; overflow: hidden; pointer-events: none; }
    .blob { position: absolute; border-radius: 50%; filter: blur(80px); opacity: 0.35; }
    .blob-1 { width: 500px; height: 500px; background: var(--purple); top: -100px; right: -100px; }
    .blob-2 { width: 400px; height: 400px; background: var(--pink); bottom: -50px; left: 20%; }
    .blob-3 { width: 300px; height: 300px; background: var(--teal); top: 30%; left: -80px; }
    .hero-content { position: relative; max-width: 1200px; margin: 0 auto; padding: 4rem 1.5rem; width: 100%; }
    .hero-badge { display: inline-flex; align-items: center; gap: 0.5rem; background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.2); color: white; font-size: 0.72rem; font-weight: 700; letter-spacing: 0.06em; padding: 0.4rem 1rem; border-radius: 50px; margin-bottom: 1.5rem; }
    .hero h1 { font-family: 'DM Serif Display', serif; font-size: clamp(2.5rem, 7vw, 5.5rem); color: white; line-height: 1.05; margin-bottom: 1rem; }
    .hero h1 em { font-style: italic; background: linear-gradient(135deg, #A78BFA, #F9A8D4, #FCD34D); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
    .hero-tagline { font-size: 1rem; color: rgba(255,255,255,0.75); max-width: 520px; line-height: 1.7; margin-bottom: 2.5rem; font-weight: 400; }
    .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }
    .btn-primary { background: linear-gradient(135deg, var(--purple), var(--pink)); color: white; padding: 0.9rem 2rem; font-family: 'Nunito', sans-serif; font-size: 0.85rem; font-weight: 700; letter-spacing: 0.04em; text-decoration: none; border-radius: 50px; box-shadow: 0 4px 20px rgba(124,58,237,0.4); transition: transform 0.2s, box-shadow 0.2s; }
    .btn-primary:hover, .btn-primary:focus-visible { transform: translateY(-2px); box-shadow: 0 6px 28px rgba(124,58,237,0.5); }
    .btn-outline { background: rgba(255,255,255,0.1); backdrop-filter: blur(4px); color: white; padding: 0.9rem 2rem; font-family: 'Nunito', sans-serif; font-size: 0.85rem; font-weight: 700; text-decoration: none; border: 1px solid rgba(255,255,255,0.3); border-radius: 50px; transition: background 0.2s; }
    .btn-outline:hover, .btn-outline:focus-visible { background: rgba(255,255,255,0.2); }
    .hero-pills { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-top: 3rem; }
    .hero-pill { background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.15); color: rgba(255,255,255,0.8); font-size: 0.72rem; font-weight: 700; padding: 0.4rem 1rem; border-radius: 50px; }

    /* Section */
    .section { padding: 5rem 1.5rem; }
    .section-inner { max-width: 1200px; margin: 0 auto; }
    .section-label { font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--purple); font-weight: 800; margin-bottom: 0.5rem; display: block; }
    .section-title { font-family: 'DM Serif Display', serif; font-size: clamp(1.8rem, 3.5vw, 3rem); color: var(--dark); line-height: 1.1; margin-bottom: 0.5rem; }
    .color-rule { width: 48px; height: 4px; background: linear-gradient(to right, var(--purple), var(--pink), var(--orange)); border-radius: 2px; margin: 1rem 0 2.5rem; }

    /* Artists */
    .artists-bg { background: var(--cream2); }
    .artist-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.5rem; }
    .artist-card { background: var(--cream); border-radius: 20px; overflow: hidden; box-shadow: 0 4px 24px rgba(26,26,46,0.06); transition: transform 0.3s, box-shadow 0.3s; }
    .artist-card:hover { transform: translateY(-6px); box-shadow: 0 12px 40px rgba(26,26,46,0.12); }
    .artist-img-wrap { position: relative; height: 280px; overflow: hidden; }
    .artist-img { width: 100%; height: 100%; object-fit: cover; object-position: top; display: block; }
    .artist-color-bar { height: 4px; background: linear-gradient(to right, var(--purple), var(--pink), var(--orange)); }
    .artist-info { padding: 1.5rem; }
    .artist-name { font-family: 'DM Serif Display', serif; font-size: 1.3rem; color: var(--dark); margin-bottom: 0.2rem; }
    .artist-specialty { font-size: 0.72rem; font-weight: 800; letter-spacing: 0.1em; text-transform: uppercase; color: var(--purple); margin-bottom: 0.75rem; }
    .artist-bio { font-size: 0.875rem; color: var(--text2); line-height: 1.7; margin-bottom: 0.75rem; }
    .artist-handle { font-size: 0.78rem; color: var(--pink); font-weight: 700; }
    .style-tags { display: flex; gap: 0.4rem; flex-wrap: wrap; margin-top: 0.75rem; }
    .style-tag { background: linear-gradient(135deg, rgba(124,58,237,0.08), rgba(236,72,153,0.08)); color: var(--purple); border: 1px solid rgba(124,58,237,0.2); font-size: 0.65rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; padding: 0.2rem 0.6rem; border-radius: 50px; }
    .years-pill { display: inline-block; background: var(--teal); color: white; font-size: 0.65rem; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase; padding: 0.25rem 0.65rem; border-radius: 50px; margin-top: 0.5rem; }

    /* Gallery */
    .masonry-grid { columns: 2; column-gap: 8px; }
    @media (min-width: 640px) { .masonry-grid { columns: 3; } }
    @media (min-width: 1024px) { .masonry-grid { columns: 4; } }
    .masonry-item { break-inside: avoid; margin-bottom: 8px; position: relative; overflow: hidden; border-radius: 12px; }
    .masonry-item img { width: 100%; display: block; transition: transform 0.4s; }
    .masonry-item:hover img { transform: scale(1.05); }
    .masonry-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(26,26,46,0.8) 0%, transparent 55%); border-radius: 12px; opacity: 0; transition: opacity 0.3s; display: flex; align-items: flex-end; padding: 0.75rem; }
    .masonry-item:hover .masonry-overlay { opacity: 1; }
    .masonry-cap { color: white; font-size: 0.72rem; font-weight: 700; }

    /* Aftercare */
    .aftercare-bg { background: var(--dark); }
    .aftercare-bg .section-title { color: white; }
    .aftercare-bg .section-label { color: var(--purple-light); }
    .aftercare-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(270px, 1fr)); gap: 1.25rem; margin-top: 2.5rem; }
    .aftercare-card { background: var(--dark2); border-radius: 16px; padding: 1.75rem; border: 1px solid rgba(255,255,255,0.06); }
    .aftercare-num-wrap { width: 44px; height: 44px; border-radius: 50%; background: linear-gradient(135deg, var(--purple), var(--pink)); display: flex; align-items: center; justify-content: center; margin-bottom: 1rem; }
    .aftercare-num { font-family: 'DM Serif Display', serif; font-size: 1.1rem; color: white; }
    .aftercare-title { font-size: 0.88rem; font-weight: 800; color: white; margin-bottom: 0.5rem; }
    .aftercare-body { font-size: 0.82rem; color: rgba(255,255,255,0.55); line-height: 1.75; }

    /* Booking */
    .booking-section { background: linear-gradient(135deg, var(--cream2) 0%, var(--cream) 100%); }
    .booking-grid { display: grid; grid-template-columns: 1fr; gap: 3rem; }
    @media (min-width: 768px) { .booking-grid { grid-template-columns: 1fr 1fr; } }
    .booking-info p { font-size: 0.9rem; color: var(--text2); line-height: 1.8; margin-bottom: 1rem; }
    .booking-price-box { background: white; border-radius: 16px; padding: 1.5rem; margin-top: 1.5rem; box-shadow: 0 4px 24px rgba(26,26,46,0.06); display: grid; gap: 0.75rem; }
    .price-row { display: flex; justify-content: space-between; align-items: center; padding-bottom: 0.5rem; border-bottom: 1px solid var(--cream2); font-size: 0.88rem; }
    .price-row:last-child { border-bottom: none; padding-bottom: 0; }
    .price-label { color: var(--text2); }
    .price-val { font-weight: 800; color: var(--dark); }
    .booking-form { background: white; border-radius: 20px; padding: 2rem; box-shadow: 0 8px 32px rgba(26,26,46,0.08); display: grid; gap: 1.25rem; }
    label { display: block; font-size: 0.72rem; font-weight: 800; letter-spacing: 0.06em; text-transform: uppercase; color: var(--dark); margin-bottom: 0.35rem; }
    input, select, textarea { width: 100%; background: var(--cream2); border: 2px solid transparent; color: var(--text); padding: 0.75rem 1rem; font-family: 'Nunito', sans-serif; font-size: 0.9rem; border-radius: 10px; outline: none; transition: border-color 0.2s, background 0.2s; font-weight: 600; }
    input:focus, select:focus, textarea:focus { border-color: var(--purple); background: white; }
    input::placeholder, textarea::placeholder { color: #9CA3AF; font-weight: 400; }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .btn-submit { background: linear-gradient(135deg, var(--purple), var(--pink)); color: white; padding: 1rem 2rem; font-family: 'Nunito', sans-serif; font-size: 0.88rem; font-weight: 800; letter-spacing: 0.04em; border: none; cursor: pointer; border-radius: 50px; box-shadow: 0 4px 20px rgba(124,58,237,0.35); transition: transform 0.2s, box-shadow 0.2s; width: 100%; margin-top: 0.25rem; }
    .btn-submit:hover, .btn-submit:focus-visible { transform: translateY(-2px); box-shadow: 0 6px 28px rgba(124,58,237,0.5); }

    /* FAQ */
    .faq-bg { background: var(--cream2); }
    .faq-list { margin-top: 2rem; display: grid; gap: 0.75rem; }
    details { background: white; border-radius: 14px; box-shadow: 0 2px 12px rgba(26,26,46,0.05); overflow: hidden; }
    summary { padding: 1.25rem 1.5rem; cursor: pointer; font-family: 'Nunito', sans-serif; font-size: 0.95rem; font-weight: 700; color: var(--dark); list-style: none; display: flex; justify-content: space-between; align-items: center; gap: 1rem; }
    summary::-webkit-details-marker { display: none; }
    summary::after { content: '+'; width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, rgba(124,58,237,0.1), rgba(236,72,153,0.1)); color: var(--purple); border-radius: 50%; font-size: 1.2rem; flex-shrink: 0; transition: transform 0.2s; font-weight: 300; }
    details[open] summary::after { transform: rotate(45deg); }
    .faq-answer { padding: 0 1.5rem 1.25rem; font-size: 0.88rem; color: var(--text2); line-height: 1.75; }

    /* Location */
    .location-section { background: var(--cream); }
    .location-grid { display: grid; grid-template-columns: 1fr; gap: 3rem; }
    @media (min-width: 768px) { .location-grid { grid-template-columns: 1fr 1fr; } }
    .hours-table { width: 100%; border-collapse: collapse; margin-top: 1.5rem; }
    .hours-table tr { border-bottom: 1px solid var(--cream2); }
    .hours-table td { padding: 0.7rem 0; font-size: 0.88rem; color: var(--text2); }
    .hours-table td:first-child { color: var(--dark); font-weight: 700; }
    .hours-table .closed { color: #D1D5DB; }
    .contact-list { margin-top: 1.5rem; display: grid; gap: 1rem; }
    .contact-item { display: flex; gap: 0.75rem; align-items: flex-start; font-size: 0.88rem; }
    .contact-icon-wrap { width: 36px; height: 36px; background: linear-gradient(135deg, rgba(124,58,237,0.1), rgba(236,72,153,0.1)); border-radius: 10px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 0.9rem; }
    .contact-text { padding-top: 0.4rem; color: var(--text2); }
    .contact-text a { color: var(--purple); text-decoration: none; font-weight: 700; }

    /* Instagram */
    .ig-bg { background: var(--cream2); }
    .ig-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; margin-top: 2rem; }
    @media (min-width: 640px) { .ig-grid { grid-template-columns: repeat(6, 1fr); } }
    .ig-post { aspect-ratio: 1; overflow: hidden; border-radius: 14px; }
    .ig-post img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.4s; }
    .ig-post a:hover img { transform: scale(1.08); }
    .ig-post a { display: block; height: 100%; }
    .ig-post a:focus-visible { outline: 3px solid var(--purple); outline-offset: 2px; }
    .ig-follow { text-align: center; margin-top: 2rem; }
    .ig-follow a { display: inline-block; background: linear-gradient(135deg, var(--purple), var(--pink)); color: white; font-size: 0.82rem; font-weight: 800; letter-spacing: 0.06em; text-transform: uppercase; text-decoration: none; padding: 0.85rem 2.5rem; border-radius: 50px; box-shadow: 0 4px 20px rgba(124,58,237,0.3); transition: transform 0.2s; }
    .ig-follow a:hover, .ig-follow a:focus-visible { transform: translateY(-2px); }

    /* Footer */
    footer { background: var(--dark); padding: 3rem 1.5rem; text-align: center; }
    .footer-logo { font-family: 'DM Serif Display', serif; font-size: 1.8rem; color: white; margin-bottom: 0.25rem; }
    .footer-logo em { font-style: italic; background: linear-gradient(135deg, var(--purple-light), var(--pink-light)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
    .footer-tagline { font-size: 0.72rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(255,255,255,0.35); margin-bottom: 1.5rem; }
    .footer-links { display: flex; gap: 1.5rem; justify-content: center; flex-wrap: wrap; margin-bottom: 1.5rem; list-style: none; }
    .footer-links a { color: rgba(255,255,255,0.4); font-size: 0.75rem; text-decoration: none; font-weight: 700; letter-spacing: 0.06em; transition: color 0.2s; }
    .footer-links a:hover { color: var(--purple-light); }
    .footer-copy { font-size: 0.72rem; color: rgba(255,255,255,0.2); }
    @media (max-width: 480px) { .form-row { grid-template-columns: 1fr; } }
    .sr-only { position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0 }
  </style>
</head>
<body>

<nav class="nav" aria-label="Main navigation">
  <div class="nav-inner">
    <a href="/v5-modern-color-studio" class="nav-logo">
      <span class="dot" aria-hidden="true"></span>
      Spectrum Tattoo Co.
    </a>
    <ul class="nav-links" role="list">
      <li><a href="#portfolio">Portfolio</a></li>
      <li><a href="#artists">Artists</a></li>
      <li><a href="#aftercare">Aftercare</a></li>
      <li><a href="#faq">FAQ</a></li>
      <li><a href="#location">Visit</a></li>
      <li><a href="#booking" class="nav-cta">Book Now</a></li>
    </ul>
  </div>
</nav>

<section id="hero" aria-label="Hero — Spectrum Tattoo Co.">
  <div class="hero">
    <div class="hero-bg" role="img" aria-label={studio.heroAlt}></div>
    <div class="hero-blobs" aria-hidden="true">
      <div class="blob blob-1"></div>
      <div class="blob blob-2"></div>
      <div class="blob blob-3"></div>
    </div>
    <div class="hero-content">
      <div class="hero-badge" aria-hidden="true">
        <span>🌈</span> Walk-ins Welcome · Color Specialists · {studio.city}
      </div>
      <h1>{studio.name}<br/><em>Tattoo Co.</em></h1>
      <p class="hero-tagline">{studio.tagline}<br/><br/>Neotraditional · Watercolor · Anime · Pop Art · Color Realism</p>
      <div class="hero-actions">
        <a href="#booking" class="btn-primary">Book a Session</a>
        <a href="#portfolio" class="btn-outline">See the Work</a>
      </div>
      <div class="hero-pills" aria-label="Studio highlights">
        <span class="hero-pill">Walk-ins welcome</span>
        <span class="hero-pill">${studio.minimumCharge} minimum</span>
        <span class="hero-pill">${studio.hourlyRate}/hr</span>
        <span class="hero-pill">3 color specialists</span>
      </div>
    </div>
  </div>
</section>

<section id="artists" class="section artists-bg" aria-labelledby="artists-heading">
  <div class="section-inner">
    <span class="section-label">The Artists</span>
    <h2 class="section-title" id="artists-heading">Color is Their Language</h2>
    <div class="color-rule" aria-hidden="true"></div>
    <div class="artist-grid" role="list">
      {studio.artists.map(artist => (
        <article class="artist-card" role="listitem" aria-label={`Artist: ${artist.name}`}>
          <div class="artist-img-wrap">
            <img src={artist.image} alt={`Portrait of ${artist.name}`} class="artist-img" loading="lazy" width="400" height="280" />
          </div>
          <div class="artist-color-bar" aria-hidden="true"></div>
          <div class="artist-info">
            <h3 class="artist-name">{artist.name}</h3>
            <p class="artist-specialty">{artist.specialty}</p>
            <p class="artist-bio">{artist.bio}</p>
            <p class="artist-handle">{artist.handle}</p>
            <div class="style-tags" aria-label={`Styles: ${artist.styles.join(', ')}`}>
              {artist.styles.map(s => <span class="style-tag">{s}</span>)}
            </div>
            <p class="years-pill">{artist.yearsExp} years exp.</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<section id="portfolio" class="section" style="background:var(--cream);" aria-labelledby="gallery-heading">
  <div class="section-inner">
    <span class="section-label">Portfolio</span>
    <h2 class="section-title" id="gallery-heading">Colour <em style="font-family:'DM Serif Display',serif; font-style:italic; background:linear-gradient(135deg,var(--purple),var(--pink),var(--orange)); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;">Unleashed</em></h2>
    <div class="color-rule" aria-hidden="true"></div>
    <div class="masonry-grid" role="list" aria-label="Portfolio gallery">
      {studio.gallery.map(item => (
        <figure class="masonry-item" role="listitem">
          <img src={item.image} alt={item.alt} loading="lazy" width="600" height="500" />
          <div class="masonry-overlay" aria-hidden="true">
            <p class="masonry-cap">{item.artist} · {item.style}</p>
          </div>
          <figcaption class="sr-only">{item.alt} — {item.artist}</figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<section id="aftercare" class="section aftercare-bg" aria-labelledby="aftercare-heading">
  <div class="section-inner">
    <span class="section-label">Aftercare</span>
    <h2 class="section-title" id="aftercare-heading">Keep Your Colors Alive</h2>
    <div class="color-rule" aria-hidden="true"></div>
    <p style="color:rgba(255,255,255,0.6); max-width:560px; line-height:1.7; margin-bottom:0.5rem; font-size:0.92rem;">Vibrant color work requires diligent aftercare. Sun is your ink's enemy — SPF 50+ is now your permanent accessory.</p>
    <div class="aftercare-grid" role="list">
      {studio.aftercare.map(step => (
        <div class="aftercare-card" role="listitem">
          <div class="aftercare-num-wrap" aria-hidden="true">
            <span class="aftercare-num">{step.step}</span>
          </div>
          <h3 class="aftercare-title">{step.title}</h3>
          <p class="aftercare-body">{step.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<section id="booking" class="section booking-section" aria-labelledby="booking-heading">
  <div class="section-inner">
    <div class="booking-grid">
      <div class="booking-info">
        <span class="section-label">Book Your Session</span>
        <h2 class="section-title" id="booking-heading">Let's Create Something <em style="font-family:'DM Serif Display',serif; font-style:italic; background:linear-gradient(135deg,var(--purple),var(--pink)); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;">Vibrant</em></h2>
        <div class="color-rule" aria-hidden="true"></div>
        <p>Walk-ins welcome Tuesday through Sunday! For custom pieces, fill out the form below and we'll get back to you within 24 hours. A deposit secures your artist.</p>
        <p>Bring reference images, inspiration boards, or just a vibe. We'll help you translate it into something you'll wear forever.</p>
        <div class="booking-price-box">
          <div class="price-row"><span class="price-label">Shop Minimum</span><span class="price-val">${studio.minimumCharge}</span></div>
          <div class="price-row"><span class="price-label">Hourly Rate</span><span class="price-val">${studio.hourlyRate}/hr</span></div>
          <div class="price-row"><span class="price-label">Booking Deposit</span><span class="price-val">${studio.depositAmount}</span></div>
          <div class="price-row"><span class="price-label">Walk-ins</span><span class="price-val" style="color:var(--teal)">Welcome ✓</span></div>
        </div>
      </div>
      <form class="booking-form" action="#" method="post" aria-label="Booking form" novalidate>
        <div>
          <label for="b-name">Your Name <span aria-label="required">*</span></label>
          <input type="text" id="b-name" name="name" placeholder="Full name" required autocomplete="name" />
        </div>
        <div class="form-row">
          <div>
            <label for="b-email">Email <span aria-label="required">*</span></label>
            <input type="email" id="b-email" name="email" placeholder="you@email.com" required autocomplete="email" />
          </div>
          <div>
            <label for="b-phone">Phone</label>
            <input type="tel" id="b-phone" name="phone" placeholder="Optional" autocomplete="tel" />
          </div>
        </div>
        <div>
          <label for="b-artist">Preferred Artist</label>
          <select id="b-artist" name="artist">
            <option value="">Any available</option>
            {studio.artists.map(a => <option value={a.name}>{a.name} — {a.specialty}</option>)}
          </select>
        </div>
        <div class="form-row">
          <div>
            <label for="b-size">Size</label>
            <select id="b-size" name="size">
              <option value="">—</option>
              <option value="xs">Tiny (under 2")</option>
              <option value="sm">Small (2–4")</option>
              <option value="md">Medium (4–8")</option>
              <option value="lg">Large / sleeve</option>
            </select>
          </div>
          <div>
            <label for="b-placement">Placement</label>
            <input type="text" id="b-placement" name="placement" placeholder="e.g. thigh, sleeve" />
          </div>
        </div>
        <div>
          <label for="b-style">Style</label>
          <select id="b-style" name="style">
            <option value="">Tell us your vibe</option>
            <option value="neotraditional">Neotraditional</option>
            <option value="watercolor">Watercolor</option>
            <option value="anime">Anime / Illustrative</option>
            <option value="popart">Pop Art</option>
            <option value="realism">Color Realism</option>
            <option value="other">Other / Mix</option>
          </select>
        </div>
        <div>
          <label for="b-desc">Describe Your Idea <span aria-label="required">*</span></label>
          <textarea id="b-desc" name="description" placeholder="What do you want? Colors, subjects, style, references — go wild!" rows="4" required></textarea>
        </div>
        <div>
          <label for="b-dates">When works for you?</label>
          <input type="text" id="b-dates" name="dates" placeholder="e.g. Any weekend in August" />
        </div>
        <button type="submit" class="btn-submit">🎨 Request Booking + ${studio.depositAmount} Deposit</button>
      </form>
    </div>
  </div>
</section>

<section id="faq" class="section faq-bg" aria-labelledby="faq-heading">
  <div class="section-inner" style="max-width:760px;">
    <span class="section-label">FAQ</span>
    <h2 class="section-title" id="faq-heading">Good Questions, Great Answers</h2>
    <div class="color-rule" aria-hidden="true"></div>
    <div class="faq-list">
      {studio.faqs.map(faq => (
        <details>
          <summary>{faq.question}</summary>
          <div class="faq-answer"><p>{faq.answer}</p></div>
        </details>
      ))}
    </div>
  </div>
</section>

<section id="location" class="section location-section" aria-labelledby="location-heading">
  <div class="section-inner">
    <div class="location-grid">
      <div>
        <span class="section-label">Come Visit</span>
        <h2 class="section-title" id="location-heading">Studio Location</h2>
        <div class="color-rule" aria-hidden="true"></div>
        <div class="contact-list">
          <div class="contact-item"><div class="contact-icon-wrap" aria-hidden="true">📍</div><div class="contact-text"><p>{studio.address}</p><p>{studio.city}</p><a href={studio.mapUrl} target="_blank" rel="noopener noreferrer" style="margin-top:0.3rem; display:inline-block; font-size:0.8rem;">Get Directions →</a></div></div>
          <div class="contact-item"><div class="contact-icon-wrap" aria-hidden="true">📞</div><div class="contact-text"><a href={`tel:${studio.phone}`}>{studio.phone}</a></div></div>
          <div class="contact-item"><div class="contact-icon-wrap" aria-hidden="true">✉️</div><div class="contact-text"><a href={`mailto:${studio.email}`}>{studio.email}</a></div></div>
          <div class="contact-item"><div class="contact-icon-wrap" aria-hidden="true">📸</div><div class="contact-text"><a href={`https://instagram.com/${studio.instagram.replace('@','')}`} target="_blank" rel="noopener noreferrer">{studio.instagram}</a></div></div>
        </div>
      </div>
      <div>
        <span class="section-label" style="display:block; margin-bottom:0.5rem;">Hours</span>
        <table class="hours-table" aria-label="Studio hours">
          <tbody>
            {studio.hours.map(h => (
              <tr>
                <td>{h.day}</td>
                <td class={h.open === 'Closed' ? 'closed' : ''}>{h.open === 'Closed' ? 'Closed' : `${h.open} – ${h.close}`}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>

<section id="instagram" class="section ig-bg" aria-labelledby="ig-heading">
  <div class="section-inner">
    <span class="section-label">Instagram</span>
    <h2 class="section-title" id="ig-heading">Follow the Color</h2>
    <div class="color-rule" aria-hidden="true"></div>
    <div class="ig-grid" role="list" aria-label="Instagram posts">
      {studio.igPosts.map(post => (
        <div class="ig-post" role="listitem">
          <a href={post.link} aria-label={`Instagram: ${post.alt}`} target="_blank" rel="noopener noreferrer">
            <img src={post.image} alt={post.alt} loading="lazy" width="300" height="300" />
          </a>
        </div>
      ))}
    </div>
    <div class="ig-follow">
      <a href={`https://instagram.com/${studio.instagram.replace('@','')}`} target="_blank" rel="noopener noreferrer">Follow {studio.instagram}</a>
    </div>
  </div>
</section>

<footer>
  <p class="footer-logo">Spectrum <em>Tattoo Co.</em></p>
  <p class="footer-tagline">Life's Too Short for Black Ink Only</p>
  <nav aria-label="Footer navigation">
    <ul class="footer-links" role="list">
      <li><a href="#portfolio">Portfolio</a></li>
      <li><a href="#artists">Artists</a></li>
      <li><a href="#booking">Book</a></li>
      <li><a href="#faq">FAQ</a></li>
      <li><a href="#location">Visit</a></li>
    </ul>
  </nav>
  <p class="footer-copy">&copy; 2024 Spectrum Tattoo Co. · {studio.address}, {studio.city} · {studio.phone}</p>
</footer>
</body>
</html>

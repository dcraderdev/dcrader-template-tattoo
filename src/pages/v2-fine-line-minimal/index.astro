---
import { Picture, getImage } from 'astro:assets';
import { studio } from '../../data/v2';
import { resolveImage } from '../../data/imageMap';
import ArtistGalleryHero from '../../components/tattoo/ArtistGalleryHero.astro';
import '../../styles/global.css';
const toRoman = (n: number) => ['I','II','III','IV','V','VI','VII','VIII'][n-1] ?? n;
const heroImg = resolveImage(studio.gallery[0].image);
const heroWidths = [540, 800, 1080];
const heroSrcset = (await Promise.all(
  heroWidths.map(async (w) => {
    const img = await getImage({ src: heroImg, width: w, format: 'webp' });
    return `${img.src} ${w}w`;
  })
)).join(', ');
const heroPreload = await getImage({ src: heroImg, width: 1080, format: 'webp' });
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title>{studio.name} — Fine-Line Tattoo · {studio.city}</title>
  <meta name="description" content={studio.description}/>
  <link rel="canonical" href={Astro.url.href}/>
  <meta property="og:title" content={`${studio.name} — Fine-Line Tattoo`}/>
  <meta property="og:description" content={studio.description}/>
  <meta property="og:image" content="/og-image.png"/>
  <meta property="og:url" content={Astro.url.href}/>
  <meta property="og:type" content="website"/>
  <meta name="twitter:card" content="summary_large_image"/>
  <meta name="twitter:title" content={`${studio.name} — Fine-Line Tattoo`}/>
  <meta name="twitter:description" content={studio.description}/>
  <meta name="twitter:image" content="/og-image.png"/>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Inter+Tight:ital,wght@0,100;0,200;0,300;0,400;0,500;1,200;1,300&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&display=swap" rel="stylesheet"/>
  <link rel="preload" as="image" fetchpriority="high" type="image/webp" href={heroPreload.src} imagesrcset={heroSrcset} imagesizes="(min-width: 768px) 60vw, 100vw"/>
  <style>
    :root{--w:#FAFAFA;--off:#F5F5F2;--b:#0D0D0D;--mid:#595959;--lt:#767676;--xlt:#E8E8E5;--rule:#E8E8E5;}
    *{box-sizing:border-box;margin:0;padding:0;}
    html{scroll-behavior:smooth;}
    body{background:var(--w);color:var(--b);font-family:'Cormorant Garamond',Georgia,serif;font-weight:300;}

    /* NAV — ultra-minimal, 3-part grid */
    nav{background:var(--w);border-bottom:1px solid var(--xlt);position:sticky;top:34px;z-index:100;}
    .nav-row{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1fr auto 1fr;align-items:center;padding:0 2rem;height:54px;}
    .nav-left{display:flex;gap:0;list-style:none;}
    .nav-right{display:flex;gap:0;justify-content:flex-end;list-style:none;align-items:center;}
    nav a{font-family:'Inter Tight',sans-serif;font-weight:300;font-size:0.65rem;letter-spacing:0.22em;text-transform:uppercase;color:var(--mid);text-decoration:none;padding:0.4rem 0.8rem;display:block;transition:color 0.2s;}
    nav a:hover,nav a:focus-visible{color:var(--b);}
    .nav-logo{font-family:'Cormorant Garamond',serif;font-weight:300;font-size:1rem;letter-spacing:0.4em;text-transform:uppercase;color:var(--b);text-decoration:none;white-space:nowrap;}
    .nav-book{font-family:'Inter Tight',sans-serif;font-weight:400;font-size:0.62rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--b)!important;border-bottom:1px solid var(--b);padding-bottom:1px!important;}

    /* HERO — typographic only, no photo */
    .hero{min-height:88vh;display:flex;flex-direction:column;justify-content:center;align-items:center;text-align:center;padding:5rem 2rem;position:relative;}
    .hero-rule-top{width:1px;height:80px;background:var(--xlt);margin:0 auto 3rem;}
    .hero-label{font-family:'Inter Tight',sans-serif;font-weight:200;font-size:0.6rem;letter-spacing:0.5em;text-transform:uppercase;color:var(--mid);margin-bottom:2rem;}
    .hero-h1{font-family:'Cormorant Garamond',serif;font-weight:300;font-style:italic;font-size:clamp(3rem,8vw,7rem);color:var(--b);line-height:1;margin-bottom:2rem;letter-spacing:-0.01em;}
    .hero-rule-mid{width:40px;height:1px;background:var(--b);margin:0 auto 2rem;}
    .hero-tagline{font-family:'Inter Tight',sans-serif;font-weight:200;font-size:0.82rem;letter-spacing:0.12em;color:var(--mid);max-width:400px;line-height:1.9;}
    .hero-ctas{margin-top:3rem;display:flex;gap:3rem;align-items:center;justify-content:center;}
    .btn-bk{font-family:'Inter Tight',sans-serif;font-weight:400;font-size:0.65rem;letter-spacing:0.22em;text-transform:uppercase;color:var(--b);text-decoration:none;background:var(--b);color:var(--w);padding:0.8rem 2.5rem;transition:opacity 0.2s;}
    .btn-bk:hover,.btn-bk:focus-visible{opacity:0.75;}
    .btn-lt{font-family:'Inter Tight',sans-serif;font-weight:300;font-size:0.62rem;letter-spacing:0.22em;text-transform:uppercase;color:var(--mid);text-decoration:none;border-bottom:1px solid var(--xlt);padding-bottom:2px;transition:color 0.2s,border-color 0.2s;}
    .btn-lt:hover,.btn-lt:focus-visible{color:var(--b);border-color:var(--b);}
    .hero-ledger{position:absolute;bottom:2.25rem;left:50%;transform:translateX(-50%);width:min(640px,calc(100% - 4rem));display:grid;gap:0;border-top:1px solid var(--xlt);border-bottom:1px solid var(--xlt);padding:0.4rem 0;}
    .hero-ledger .hl-row{display:grid;grid-template-columns:1fr auto;align-items:baseline;gap:1.25rem;padding:0.45rem 0.25rem;border-bottom:1px dotted var(--xlt);}
    .hero-ledger .hl-row:last-child{border-bottom:none;}
    .hero-ledger dt{font-family:'Inter Tight',sans-serif;font-weight:200;font-size:0.58rem;letter-spacing:0.28em;text-transform:uppercase;color:var(--mid);}
    .hero-ledger dd{font-family:'Cormorant Garamond',serif;font-weight:300;font-size:0.95rem;font-style:italic;color:#444;text-align:right;}
    .hero-ledger dd em{font-style:normal;font-family:'Cormorant Garamond',serif;font-weight:400;color:var(--b);font-size:1.05rem;padding-right:0.15em;}
    @media(max-width:560px){.hero-ledger{position:static;transform:none;margin:2.5rem auto 0;}.hero-ledger .hl-row{grid-template-columns:1fr;text-align:left;}.hero-ledger dd{text-align:left;}}

    /* SECTIONS */
    .section{padding:6rem 2rem;}
    .section-inner{max-width:1000px;margin:0 auto;}
    .section-num{font-family:'Inter Tight',sans-serif;font-weight:200;font-size:0.55rem;letter-spacing:0.4em;text-transform:uppercase;color:var(--lt);margin-bottom:0.75rem;display:block;}
    .section-h{font-family:'Cormorant Garamond',serif;font-weight:300;font-style:italic;font-size:clamp(2rem,4vw,3.5rem);color:var(--b);line-height:1.05;margin-bottom:0.5rem;}
    .thin-rule{width:40px;height:1px;background:var(--xlt);margin:1.25rem 0 3rem;}

    /* ARTISTS — horizontal list rows */
    .artist-bg{background:var(--off);border-top:1px solid var(--xlt);border-bottom:1px solid var(--xlt);}
    .artist-list{display:grid;gap:0;border:1px solid var(--xlt);}
    .artist-row{display:grid;grid-template-columns:200px 1fr;gap:0;border-bottom:1px solid var(--xlt);background:var(--w);}
    .artist-row:last-child{border-bottom:none;}
    .artist-row:hover{background:var(--off);}
    .artist-photo-col{overflow:hidden;}
    .artist-photo-col img{width:100%;height:220px;object-fit:cover;object-position:top;display:block;filter:grayscale(15%);transition:filter 0.4s;}
    .artist-row:hover .artist-photo-col img{filter:grayscale(0%);}
    .artist-info-col{padding:2rem 2.5rem;display:flex;flex-direction:column;justify-content:space-between;}
    .artist-num{font-family:'Inter Tight',sans-serif;font-weight:200;font-size:0.55rem;letter-spacing:0.4em;text-transform:uppercase;color:var(--lt);margin-bottom:0.5rem;}
    .artist-h{font-family:'Cormorant Garamond',serif;font-size:1.4rem;font-weight:400;color:var(--b);margin-bottom:0.2rem;}
    .artist-spec{font-family:'Inter Tight',sans-serif;font-weight:200;font-size:0.6rem;letter-spacing:0.22em;text-transform:uppercase;color:var(--mid);margin-bottom:1rem;}
    .artist-bio{font-family:'Cormorant Garamond',serif;font-size:0.95rem;color:#555;line-height:1.75;font-style:italic;margin-bottom:1rem;}
    .artist-foot{display:flex;justify-content:space-between;align-items:flex-end;}
    .artist-handle{font-family:'Inter Tight',sans-serif;font-size:0.62rem;color:var(--mid);}
    .artist-tags{display:flex;gap:0.5rem;flex-wrap:wrap;}
    .tag{font-family:'Inter Tight',sans-serif;font-weight:200;font-size:0.55rem;letter-spacing:0.18em;text-transform:uppercase;color:var(--mid);border:1px solid var(--xlt);padding:0.15rem 0.5rem;}
    @media(max-width:640px){.artist-row{grid-template-columns:1fr;}}

    /* MUSEUM GALLERY */
    .museum-gallery{display:grid;gap:5rem;margin-top:2rem;}
    .museum-item{display:grid;grid-template-columns:auto 1fr;gap:2rem;align-items:start;}
    .museum-item:nth-child(even){direction:rtl;}
    .museum-item:nth-child(even) > *{direction:ltr;}
    .museum-roman{font-family:'Cormorant Garamond',serif;font-size:1rem;font-weight:300;color:var(--mid);letter-spacing:0.1em;padding-top:0.5rem;min-width:2rem;}
    .museum-img{max-width:540px;width:100%;}
    .museum-img img{width:100%;display:block;aspect-ratio:4/3;object-fit:cover;filter:grayscale(8%);}
    .museum-caption{margin-top:1rem;}
    .museum-caption-title{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:1.1rem;color:var(--b);}
    .museum-caption-sub{font-family:'Inter Tight',sans-serif;font-weight:200;font-size:0.58rem;letter-spacing:0.22em;text-transform:uppercase;color:var(--lt);margin-top:0.35rem;}
    @media(max-width:700px){.museum-item{grid-template-columns:1fr;}.museum-item:nth-child(even){direction:ltr;}}

    /* SIGNATURE — featured single piece */
    .signature-bg{background:var(--w);border-top:1px solid var(--xlt);border-bottom:1px solid var(--xlt);}
    .sig-frame{display:grid;grid-template-columns:1fr 1.1fr;gap:5rem;align-items:center;margin-top:2.5rem;}
    @media(max-width:820px){.sig-frame{grid-template-columns:1fr;gap:3rem;}}
    .sig-img-wrap{position:relative;padding:1.5rem;background:var(--off);}
    .sig-img-wrap::before{content:'';position:absolute;inset:0;border:1px solid var(--xlt);pointer-events:none;}
    .sig-img-wrap img{display:block;width:100%;aspect-ratio:3/4;object-fit:cover;filter:grayscale(12%);}
    .sig-img-cap{font-family:'Inter Tight',sans-serif;font-weight:200;font-size:0.55rem;letter-spacing:0.35em;text-transform:uppercase;color:var(--lt);margin-top:1rem;text-align:right;}
    .sig-body{padding-right:1rem;}
    .sig-tag{font-family:'Inter Tight',sans-serif;font-weight:300;font-size:0.6rem;letter-spacing:0.4em;text-transform:uppercase;color:var(--mid);margin-bottom:1.25rem;}
    .sig-title{font-family:'Cormorant Garamond',serif;font-style:italic;font-weight:300;font-size:clamp(2rem,4.5vw,3.6rem);color:var(--b);line-height:1.05;margin-bottom:1.5rem;}
    .sig-rule{width:50px;height:1px;background:var(--b);margin-bottom:1.5rem;}
    .sig-prose{font-family:'Cormorant Garamond',serif;font-size:1.05rem;color:#555;line-height:1.85;margin-bottom:1.25rem;font-style:italic;}
    .sig-meta{display:grid;grid-template-columns:repeat(2,1fr);gap:1.25rem 2rem;margin-top:2rem;padding-top:1.5rem;border-top:1px solid var(--xlt);}
    .sig-meta dt{font-family:'Inter Tight',sans-serif;font-weight:300;font-size:0.55rem;letter-spacing:0.3em;text-transform:uppercase;color:var(--lt);margin-bottom:0.3rem;}
    .sig-meta dd{font-family:'Cormorant Garamond',serif;font-size:0.95rem;color:var(--b);line-height:1.4;}

    /* AFTERCARE */
    .aftercare-bg{background:var(--off);border-top:1px solid var(--xlt);}
    .aftercare-list{display:grid;gap:0;border:1px solid var(--xlt);margin-top:2rem;}
    .ac-item{display:grid;grid-template-columns:60px 1fr;border-bottom:1px solid var(--xlt);background:var(--w);}
    .ac-item:last-child{border-bottom:none;}
    .ac-num-col{border-right:1px solid var(--xlt);display:flex;align-items:center;justify-content:center;}
    .ac-num-txt{font-family:'Cormorant Garamond',serif;font-size:1.8rem;font-weight:300;color:var(--lt);}
    .ac-content{padding:1.5rem 2rem;}
    .ac-title{font-family:'Inter Tight',sans-serif;font-weight:400;font-size:0.68rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--b);margin-bottom:0.5rem;}
    .ac-body{font-family:'Cormorant Garamond',serif;font-size:0.95rem;color:#555;line-height:1.75;}

    /* BOOKING */
    .booking-bg{background:var(--b);}
    .booking-grid{display:grid;grid-template-columns:1fr 1fr;gap:5rem;}
    @media(max-width:768px){.booking-grid{grid-template-columns:1fr;}}
    .booking-copy{color:#B0B0B0;}
    .booking-copy .section-h{color:var(--w);}
    .booking-copy .section-num{color:#999;}
    .booking-copy .thin-rule{background:#444;}
    .booking-copy p{font-family:'Cormorant Garamond',serif;font-size:0.95rem;line-height:1.8;margin-bottom:1rem;font-style:italic;}
    .price-block{border-top:1px solid #2E2E2E;border-bottom:1px solid #2E2E2E;padding:1rem 0;margin-top:1.5rem;display:grid;gap:0.5rem;}
    .pr{display:flex;justify-content:space-between;font-family:'Inter Tight',sans-serif;font-weight:300;font-size:0.72rem;letter-spacing:0.06em;color:#B0B0B0;}
    .pr strong{color:var(--w);font-weight:400;}
    .bk-form{display:grid;gap:1.25rem;}
    .fl{display:block;font-family:'Inter Tight',sans-serif;font-weight:200;font-size:0.55rem;letter-spacing:0.3em;text-transform:uppercase;color:#A8A8A8;margin-bottom:0.3rem;}
    .fi{width:100%;background:transparent;border:none;border-bottom:1px solid #3A3A3A;color:var(--w);padding:0.5rem 0;font-family:'Cormorant Garamond',serif;font-size:0.95rem;outline:none;transition:border-color 0.2s;}
    .fi:focus{border-color:var(--w);}
    .fi::placeholder{color:#888;}
    .fi option{background:#111;}
    .fr{display:grid;grid-template-columns:1fr 1fr;gap:1.5rem;}
    .fs{background:var(--w);color:var(--b);padding:0.85rem 2rem;font-family:'Inter Tight',sans-serif;font-size:0.65rem;font-weight:400;letter-spacing:0.22em;text-transform:uppercase;border:none;cursor:pointer;width:100%;transition:opacity 0.2s;}
    .fs:hover,.fs:focus-visible{opacity:0.85;}

    /* FAQ */
    .faq-list{margin-top:2rem;}
    details{border-bottom:1px solid var(--xlt);}
    summary{padding:1.25rem 0;cursor:pointer;display:flex;justify-content:space-between;align-items:center;gap:1rem;list-style:none;font-family:'Cormorant Garamond',serif;font-style:italic;font-size:1.05rem;color:var(--b);}
    summary::-webkit-details-marker{display:none;}
    summary::after{content:'+';font-family:'Inter Tight',sans-serif;font-weight:200;font-size:1.1rem;color:var(--lt);flex-shrink:0;transition:transform 0.2s;}
    details[open] summary::after{transform:rotate(45deg);}
    .fq-ans{padding:0 0 1.25rem;font-family:'Cormorant Garamond',serif;font-size:0.95rem;color:var(--mid);line-height:1.8;}

    /* LOCATION */
    .loc-grid{display:grid;grid-template-columns:1fr 1fr;gap:4rem;}
    @media(max-width:700px){.loc-grid{grid-template-columns:1fr;}}
    .hours-tbl{width:100%;border-collapse:collapse;margin-top:1.5rem;}
    .hours-tbl tr{border-bottom:1px solid var(--xlt);}
    .hours-tbl td{padding:0.65rem 0;font-family:'Cormorant Garamond',serif;font-size:1rem;color:var(--mid);}
    .hours-tbl td:first-child{color:var(--b);}
    .hours-tbl .closed{color:var(--mid);font-style:italic;}
    .contact-list{margin-top:1.5rem;display:grid;gap:0.9rem;}
    .c-row{display:flex;gap:1rem;font-family:'Cormorant Garamond',serif;font-size:0.95rem;color:var(--mid);}
    .c-row a{color:var(--b);text-decoration:none;border-bottom:1px solid var(--xlt);}

    /* IG */
    .ig-strip{display:grid;grid-template-columns:repeat(6,1fr);gap:2px;margin-top:2rem;border:1px solid var(--xlt);}
    @media(max-width:640px){.ig-strip{grid-template-columns:repeat(3,1fr);}}
    .ig-cell{aspect-ratio:1;overflow:hidden;}
    .ig-cell img{width:100%;height:100%;object-fit:cover;display:block;filter:grayscale(20%);transition:filter 0.4s,transform 0.5s;}
    .ig-cell a:hover img{filter:grayscale(0%);transform:scale(1.05);}
    .ig-cell a{display:block;height:100%;}
    .ig-cell a:focus-visible{outline:1px solid var(--b);outline-offset:2px;}
    .ig-cta{text-align:center;margin-top:2.5rem;}
    .ig-cta a{font-family:'Inter Tight',sans-serif;font-weight:300;font-size:0.62rem;letter-spacing:0.25em;text-transform:uppercase;color:var(--b);text-decoration:none;border-bottom:1px solid var(--b);padding-bottom:2px;}

    /* FOOTER */
    footer{background:var(--off);border-top:1px solid var(--xlt);padding:4rem 2rem;text-align:center;}
    .foot-logo{font-family:'Cormorant Garamond',serif;font-weight:300;letter-spacing:0.45em;text-transform:uppercase;font-size:1.1rem;color:var(--b);}
    .foot-sub{font-family:'Inter Tight',sans-serif;font-weight:200;font-size:0.55rem;letter-spacing:0.3em;text-transform:uppercase;color:var(--mid);margin:0.5rem 0 2rem;}
    .foot-nav{display:flex;justify-content:center;gap:0;list-style:none;margin-bottom:2rem;flex-wrap:wrap;}
    .foot-nav a{font-family:'Inter Tight',sans-serif;font-weight:200;font-size:0.58rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--mid);text-decoration:none;padding:0.3rem 0.9rem;}
    .foot-nav a:hover{color:var(--b);}
    .foot-copy{font-family:'Inter Tight',sans-serif;font-weight:200;font-size:0.6rem;color:var(--mid);}
    .sr-only{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0}
    @media(max-width:480px){.fr{grid-template-columns:1fr;}}
  </style>
  <script src="/template-topheader.js" defer></script>
  <style>
    html { scroll-padding-top: 40px !important; }
    body { padding-top: 36px !important; }
    body > #dcrader-topheader, body > [data-dcrader-topheader] { padding-top: 0 !important; margin-top: -36px !important; }
  </style>
</head>
<body>

<nav aria-label="Main navigation">
  <div class="nav-row">
    <ul class="nav-left" role="list">
      <li><a href="#artists">Artists</a></li>
      <li><a href="#portfolio">Portfolio</a></li>
      <li><a href="#aftercare">Aftercare</a></li>
    </ul>
    <a class="nav-logo" href="/v2-fine-line-minimal">Linework Studio</a>
    <ul class="nav-right" role="list">
      <li><a href="#faq">FAQ</a></li>
      <li><a href="#location">Visit</a></li>
      <li><a href="#booking" class="nav-book">Inquire</a></li>
    </ul>
  </div>
</nav>

<!-- HERO — artist-gallery as hero -->
<ArtistGalleryHero studio={studio} />

<!-- LEDGER — practice ledger (formerly inside hero) -->
<aside class="section" aria-label="Studio practice ledger" style="padding-top:2rem;padding-bottom:2rem;">
  <div class="section-inner" style="max-width:780px;">
    <dl class="hero-ledger" aria-label="Studio practice — current ledger">
      <div class="hl-row"><dt>Average waitlist</dt><dd><em>nine</em> weeks</dd></div>
      <div class="hl-row"><dt>Sessions logged, 2024</dt><dd><em>412</em> &amp; counting</dd></div>
      <div class="hl-row"><dt>Pieces under 4cm</dt><dd><em>68%</em> of the book</dd></div>
      <div class="hl-row"><dt>Needles used</dt><dd>single &amp; 0.18mm round</dd></div>
    </dl>
  </div>
</aside>

<!-- ARTISTS — horizontal list -->
<section id="artists" class="section artist-bg" aria-labelledby="artists-h">
  <div class="section-inner">
    <span class="section-num">Section I</span>
    <h2 class="section-h" id="artists-h">The Specialists</h2>
    <div class="thin-rule" aria-hidden="true"></div>
    <div class="artist-list" role="list">
      {studio.artists.map((a, i) => (
        <article class="artist-row" role="listitem" aria-label={`Artist: ${a.name}`}>
          <div class="artist-photo-col">
            <Picture formats={['avif','webp']} src={resolveImage(a.image)} alt={`Portrait of ${a.name}`} loading="lazy" decoding="async" widths={[200, 400]} sizes="200px" width={400} height={440} />
          </div>
          <div class="artist-info-col">
            <div>
              <p class="artist-num">{toRoman(i+1)} of {studio.artists.length}</p>
              <h3 class="artist-h">{a.name}</h3>
              <p class="artist-spec">{a.specialty} · {a.yearsExp} years</p>
              <p class="artist-bio">{a.bio}</p>
            </div>
            <div class="artist-foot">
              <span class="artist-handle">{a.handle}</span>
              <div class="artist-tags" aria-label={`Styles: ${a.styles.join(', ')}`}>
                {a.styles.map(s => <span class="tag">{s}</span>)}
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- MUSEUM GALLERY -->
<section id="portfolio" class="section" aria-labelledby="gallery-h">
  <div class="section-inner">
    <span class="section-num">Section II</span>
    <h2 class="section-h" id="gallery-h">Collected Works</h2>
    <div class="thin-rule" aria-hidden="true"></div>
    <div class="museum-gallery" role="list" aria-label="Portfolio — museum catalog">
      {studio.gallery.slice(0,6).map((item, i) => (
        <figure class="museum-item" role="listitem">
          <span class="museum-roman" aria-hidden="true">{toRoman(i+1)}</span>
          <div>
            <div class="museum-img">
              <Picture formats={['avif','webp']} src={resolveImage(item.image)} alt={item.alt} loading={i === 0 ? 'eager' : 'lazy'} decoding="async" widths={[540, 800, 1080]} sizes="(min-width: 768px) 60vw, 100vw" width={1080} height={810} />
            </div>
            <div class="museum-caption">
              <p class="museum-caption-title">{item.alt.split('.')[0]}</p>
              <p class="museum-caption-sub">{item.artist} — {item.style}</p>
            </div>
          </div>
        </figure>
      ))}
    </div>
  </div>
</section>

<!-- SIGNATURE — featured single piece -->
<section id="signature" class="section signature-bg" aria-labelledby="sig-h">
  <div class="section-inner">
    <span class="section-num">Section III</span>
    <h2 class="section-h" id="sig-h">A Single Piece, At Length</h2>
    <div class="thin-rule" aria-hidden="true"></div>
    <div class="sig-frame">
      <figure class="sig-img-wrap">
        <Picture formats={['avif','webp']} src={resolveImage(studio.gallery[0].image)} alt={studio.gallery[0].alt} loading="lazy" decoding="async" widths={[480, 720, 960]} sizes="(min-width: 820px) 45vw, 100vw" width={960} height={1280} />
        <figcaption class="sig-img-cap">Plate IV — {studio.gallery[0].artist}, single-needle on forearm, eight hours across two sittings.</figcaption>
      </figure>
      <div class="sig-body">
        <p class="sig-tag">Signature work · 2024</p>
        <h3 class="sig-title">"Fern, unfurling slowly — a study in restraint."</h3>
        <div class="sig-rule" aria-hidden="true"></div>
        <p class="sig-prose">Sora began this piece in late winter from a pressed-fern specimen brought in by the client's grandmother. The line weight is held within a quarter-millimeter from stem to tip — no shading, no fill, only line.</p>
        <p class="sig-prose">Two sittings, four months apart, to allow the first pass to settle into the dermis before the finer fronds were committed. The result reads as botanical illustration, not tattoo. This is what we mean when we say <em>fine line</em>.</p>
        <dl class="sig-meta">
          <div><dt>Artist</dt><dd>{studio.artists[0].name}</dd></div>
          <div><dt>Placement</dt><dd>Inner forearm, 14cm × 5cm</dd></div>
          <div><dt>Technique</dt><dd>Single-needle, 0.18mm round liner</dd></div>
          <div><dt>Sessions</dt><dd>Two · ~8 hours total</dd></div>
        </dl>
      </div>
    </div>
  </div>
</section>

<!-- AFTERCARE -->
<section id="aftercare" class="section aftercare-bg" aria-labelledby="aftercare-h">
  <div class="section-inner">
    <span class="section-num">Section III</span>
    <h2 class="section-h" id="aftercare-h">Aftercare Protocol</h2>
    <div class="thin-rule" aria-hidden="true"></div>
    <div class="aftercare-list" role="list">
      {studio.aftercare.map(step => (
        <div class="ac-item" role="listitem">
          <div class="ac-num-col"><span class="ac-num-txt">{toRoman(step.step)}</span></div>
          <div class="ac-content">
            <p class="ac-title">{step.title}</p>
            <p class="ac-body">{step.body}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- BOOKING -->
<section id="booking" class="section booking-bg" aria-labelledby="booking-h">
  <div class="section-inner">
    <div class="booking-grid">
      <div class="booking-copy">
        <span class="section-num" style="color:#333">Section IV</span>
        <h2 class="section-h" id="booking-h">By Appointment Only</h2>
        <div class="thin-rule" style="background:#222;" aria-hidden="true"></div>
        <p>We do not accept walk-ins. Precision demands preparation. Submit an inquiry and your artist will respond within 48 hours.</p>
        <p>A ${studio.depositAmount} deposit is required to confirm your appointment. This is non-refundable and applied to your session.</p>
        <div class="price-block">
          <div class="pr"><span>Shop Minimum</span><strong>${studio.minimumCharge}</strong></div>
          <div class="pr"><span>Hourly Rate</span><strong>${studio.hourlyRate}/hr</strong></div>
          <div class="pr"><span>Booking Deposit</span><strong>${studio.depositAmount}</strong></div>
        </div>
      </div>
      <form class="bk-form" action="#" method="post" aria-label="Booking inquiry form" novalidate>
        <div><label class="fl" for="bn">Name *</label><input class="fi" type="text" id="bn" name="name" placeholder="Your name" required autocomplete="name"/></div>
        <div class="fr">
          <div><label class="fl" for="be">Email *</label><input class="fi" type="email" id="be" name="email" placeholder="you@email.com" required autocomplete="email"/></div>
          <div><label class="fl" for="bp">Phone</label><input class="fi" type="tel" id="bp" name="phone" placeholder="Optional" autocomplete="tel"/></div>
        </div>
        <div><label class="fl" for="ba">Artist preference</label>
          <select class="fi" id="ba" name="artist">
            <option value="">No preference</option>
            {studio.artists.map(a => <option value={a.name}>{a.name}</option>)}
          </select>
        </div>
        <div class="fr">
          <div><label class="fl" for="bsz">Size</label>
            <select class="fi" id="bsz" name="size">
              <option>Tiny (under 2")</option><option>Small (2–4")</option><option>Medium (4–8")</option><option>Large (8"+)</option>
            </select>
          </div>
          <div><label class="fl" for="bpl">Placement</label><input class="fi" type="text" id="bpl" name="placement" placeholder="e.g. inner wrist"/></div>
        </div>
        <div><label class="fl" for="bd">Your idea *</label><textarea class="fi" id="bd" name="description" rows="4" placeholder="Describe the work you have in mind..." required></textarea></div>
        <div><label class="fl" for="bdt">Availability</label><input class="fi" type="text" id="bdt" name="dates" placeholder="e.g. Saturdays, September onward"/></div>
        <button class="fs" type="submit">Send Inquiry + ${studio.depositAmount} Deposit</button>
      </form>
    </div>
  </div>
</section>

<!-- FAQ -->
<section id="faq" class="section" aria-labelledby="faq-h">
  <div class="section-inner" style="max-width:680px;">
    <span class="section-num">Section V</span>
    <h2 class="section-h" id="faq-h">Common Questions</h2>
    <div class="thin-rule" aria-hidden="true"></div>
    <div class="faq-list">
      {studio.faqs.map(f => (
        <details>
          <summary>{f.question}</summary>
          <div class="fq-ans"><p>{f.answer}</p></div>
        </details>
      ))}
    </div>
  </div>
</section>

<!-- LOCATION -->
<section id="location" class="section" style="background:var(--off);border-top:1px solid var(--xlt);" aria-labelledby="loc-h">
  <div class="section-inner">
    <span class="section-num">Section VI</span>
    <h2 class="section-h" id="loc-h">The Studio</h2>
    <div class="thin-rule" aria-hidden="true"></div>
    <div class="loc-grid">
      <div>
        <div class="contact-list">
          <div class="c-row"><span aria-hidden="true">—</span><div><p>{studio.address}</p><p>{studio.city}</p><a href={studio.mapUrl} target="_blank" rel="noopener noreferrer" style="font-family:'Inter Tight',sans-serif;font-size:0.6rem;letter-spacing:0.2em;text-transform:uppercase;margin-top:0.3rem;display:inline-block;">Directions</a></div></div>
          <div class="c-row"><span aria-hidden="true">—</span><a href={`tel:${studio.phone}`}>{studio.phone}</a></div>
          <div class="c-row"><span aria-hidden="true">—</span><a href={`mailto:${studio.email}`}>{studio.email}</a></div>
          <div class="c-row"><span aria-hidden="true">—</span><a href={`https://instagram.com/${studio.instagram.replace('@','')}`} target="_blank" rel="noopener noreferrer">{studio.instagram}</a></div>
        </div>
      </div>
      <div>
        <table class="hours-tbl" aria-label="Studio hours">
          <tbody>
            {studio.hours.map(h => (
              <tr>
                <td>{h.day}</td>
                <td class={h.open==='Closed'?'closed':''}>{h.open==='Closed'?'Closed':`${h.open} – ${h.close}`}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>

<!-- INSTAGRAM -->
<section id="instagram" class="section" aria-labelledby="ig-h">
  <div class="section-inner">
    <span class="section-num">Instagram</span>
    <h2 class="section-h" id="ig-h">{studio.instagram}</h2>
    <div class="thin-rule" aria-hidden="true"></div>
    <div class="ig-strip" role="list" aria-label="Instagram grid">
      {studio.igPosts.map(p => (
        <div class="ig-cell" role="listitem">
          <a href={p.link} aria-label={`Instagram: ${p.alt}`} target="_blank" rel="noopener noreferrer">
            <Picture formats={['avif','webp']} src={resolveImage(p.image)} alt={p.alt} loading="lazy" decoding="async" widths={[200, 400]} sizes="(min-width: 640px) 16vw, 33vw" width={400} height={400} />
          </a>
        </div>
      ))}
    </div>
    <div class="ig-cta">
      <a href={`https://instagram.com/${studio.instagram.replace('@','')}`} target="_blank" rel="noopener noreferrer">Follow on Instagram</a>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer>
  <p class="foot-logo">Linework Studio</p>
  <p class="foot-sub">Fine-line · Single-needle · By appointment only · San Diego, CA</p>
  <nav aria-label="Footer navigation">
    <ul class="foot-nav" role="list">
      <li><a href="#artists">I. Artists</a></li>
      <li><a href="#portfolio">II. Portfolio</a></li>
      <li><a href="#booking">IV. Book</a></li>
      <li><a href="#faq">V. FAQ</a></li>
      <li><a href="#location">VI. Visit</a></li>
    </ul>
  </nav>
  <p class="foot-copy">{studio.address}, {studio.city} · {studio.email}</p>
  <p style="margin-top:1.5rem;font-family:'Inter Tight',sans-serif;font-size:0.7rem;letter-spacing:0.15em;text-transform:uppercase;color:var(--mid);">Built by <a href="https://dcrader.dev" style="color:var(--b);text-decoration:none;border-bottom:1px solid var(--lt);">Donovan Crader · dcrader.dev</a></p>
</footer>
</body>
</html>

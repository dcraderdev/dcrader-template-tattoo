---
import { Picture, getImage } from 'astro:assets';
import { studio } from '../../data/v4';
import { resolveImage } from '../../data/imageMap';
import BookingWidgetHero from '../../components/tattoo/BookingWidgetHero.astro';
const base = import.meta.env.BASE_URL;
const heroImg = resolveImage(studio.heroImage);
const heroWidths = [768, 1280, 1920];
const heroSrcset = (await Promise.all(
  heroWidths.map(async (w) => {
    const img = await getImage({ src: heroImg, width: w, format: 'webp' });
    return `${img.src} ${w}w`;
  })
)).join(', ');
const heroPreload = await getImage({ src: heroImg, width: 1920, format: 'webp' });

function pad(n: number) { return n.toString().padStart(2, '0'); }
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{studio.name} — {studio.tagline}</title>
  <meta name="description" content={studio.description} />
  <link rel="canonical" href={Astro.url.href} />
  <meta property="og:title" content={`${studio.name} — ${studio.tagline}`} />
  <meta property="og:description" content={studio.description} />
  <meta property="og:image" content="/og-image.png" />
  <meta property="og:url" content={Astro.url.href} />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={`${studio.name} — ${studio.tagline}`} />
  <meta name="twitter:description" content={studio.description} />
  <meta name="twitter:image" content="/og-image.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href={`${base}styles/global.css`} />
  <link rel="preload" as="image" fetchpriority="high" type="image/webp" href={heroPreload.src} imagesrcset={heroSrcset} imagesizes="(min-width: 1024px) 50vw, 100vw"/>
  <style>
    :root {
      --black: #000000;
      --near-black: #0A0A0A;
      --dark: #111111;
      --mid-dark: #1C1C1C;
      --gray-80: #333333;
      --gray-60: #8A8A8A;
      --gray-40: #B0B0B0;
      --gray-20: #CCCCCC;
      --gray-10: #E8E8E8;
      --white: #FFFFFF;
      --mono: 'IBM Plex Mono', monospace;
      --sans: 'Inter', sans-serif;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; background: var(--black); color: var(--white); }
    body { font-family: var(--sans); background: var(--black); color: var(--white); }

    /* NAV */
    .nav {
      position: fixed; top: 34px; left: 0; right: 0; z-index: 100;
      background: var(--black);
      border-bottom: 1px solid var(--gray-80);
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 2rem; height: 56px;
    }
    .nav-logo {
      font-family: var(--mono); font-size: 0.75rem; font-weight: 600;
      letter-spacing: 0.2em; text-transform: uppercase; color: var(--white);
      text-decoration: none;
    }
    .nav-logo span { color: var(--gray-40); font-weight: 300; }
    .nav-spec {
      font-family: var(--mono); font-size: 0.65rem; color: var(--gray-40);
      letter-spacing: 0.05em;
    }
    .nav-links { display: flex; gap: 2rem; list-style: none; }
    .nav-links a {
      font-family: var(--mono); font-size: 0.65rem; color: var(--gray-40);
      text-decoration: none; letter-spacing: 0.1em; text-transform: uppercase;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--white); }
    .nav-book {
      font-family: var(--mono); font-size: 0.65rem; font-weight: 600;
      color: var(--black); background: var(--white);
      border: none; padding: 0.5rem 1.25rem; cursor: pointer;
      letter-spacing: 0.1em; text-transform: uppercase; text-decoration: none;
    }

    /* HERO */
    .hero {
      padding-top: 90px;
      display: grid;
      grid-template-columns: 1fr 1fr;
      min-height: 100vh;
    }
    .hero-image-panel {
      position: relative; overflow: hidden;
    }
    .hero-image-panel img {
      width: 100%; height: 100%; object-fit: cover;
      filter: grayscale(100%) contrast(1.1);
      display: block;
    }
    .hero-scan-line {
      position: absolute; top: 0; left: 0; right: 0; bottom: 0;
      background: repeating-linear-gradient(
        0deg,
        transparent,
        transparent 2px,
        rgba(0,0,0,0.03) 2px,
        rgba(0,0,0,0.03) 4px
      );
      pointer-events: none;
    }
    .hero-image-label {
      position: absolute; bottom: 1.5rem; left: 1.5rem;
      font-family: var(--mono); font-size: 0.6rem; color: var(--gray-40);
      letter-spacing: 0.1em; text-transform: uppercase;
    }
    .hero-info-panel {
      padding: 4rem 3rem;
      display: flex; flex-direction: column; justify-content: center;
      border-left: 1px solid var(--gray-80);
    }
    .hero-spec-tag {
      font-family: var(--mono); font-size: 0.6rem; color: var(--gray-40);
      letter-spacing: 0.15em; text-transform: uppercase; margin-bottom: 2rem;
    }
    .hero-spec-tag::before { content: '// '; }
    .hero-h1 {
      font-family: var(--mono); font-size: clamp(2rem, 4vw, 3.5rem);
      font-weight: 600; line-height: 1.05;
      letter-spacing: -0.02em; margin-bottom: 2rem;
      color: var(--white);
    }
    .hero-h1 .dim { color: var(--gray-60); font-weight: 300; }
    .hero-desc {
      font-family: var(--sans); font-size: 0.95rem; font-weight: 300;
      color: var(--gray-20); line-height: 1.7; margin-bottom: 3rem;
      max-width: 38ch;
    }
    .hero-record {
      border: 1px solid var(--gray-80); margin-bottom: 2.5rem;
      background: rgba(255,255,255,0.015);
      position: relative;
    }
    .hero-record::before {
      content: 'RECORD_03 // SESSION_LOG';
      position: absolute; top: -0.55rem; left: 1rem;
      font-family: var(--mono); font-size: 0.55rem; color: var(--gray-60);
      letter-spacing: 0.15em; background: var(--black); padding: 0 0.5rem;
    }
    .hero-record .rec-row {
      display: grid; grid-template-columns: 150px 1fr;
      gap: 1rem; align-items: baseline;
      padding: 0.65rem 1rem; border-bottom: 1px solid var(--gray-80);
    }
    .hero-record .rec-row:last-child { border-bottom: none; }
    .hero-record dt {
      font-family: var(--mono); font-size: 0.6rem; color: var(--gray-40);
      letter-spacing: 0.12em;
    }
    .hero-record dd {
      font-family: var(--mono); font-size: 0.9rem; color: var(--white);
      font-weight: 500;
    }
    .hero-record .rec-note {
      color: var(--gray-60); font-weight: 300; font-size: 0.7rem;
      margin-left: 0.5rem;
    }
    @media (max-width: 540px) {
      .hero-record .rec-row { grid-template-columns: 1fr; gap: 0.15rem; }
      .hero-record .rec-note { display: block; margin-left: 0; }
    }
    .hero-ctas { display: flex; gap: 1rem; }
    .btn-primary {
      font-family: var(--mono); font-size: 0.7rem; font-weight: 600;
      letter-spacing: 0.1em; text-transform: uppercase;
      background: var(--white); color: var(--black);
      border: none; padding: 0.875rem 2rem; cursor: pointer; text-decoration: none;
      display: inline-block;
    }
    .btn-secondary {
      font-family: var(--mono); font-size: 0.7rem; font-weight: 400;
      letter-spacing: 0.1em; text-transform: uppercase;
      background: transparent; color: var(--gray-40);
      border: 1px solid var(--gray-80); padding: 0.875rem 2rem;
      cursor: pointer; text-decoration: none; display: inline-block;
    }
    .btn-secondary:hover { color: var(--white); border-color: var(--white); }

    /* SECTION HEADER */
    .section-header {
      display: flex; align-items: baseline; gap: 1.5rem;
      margin-bottom: 3rem;
      border-bottom: 1px solid var(--gray-80); padding-bottom: 1rem;
    }
    .section-index {
      font-family: var(--mono); font-size: 0.65rem; color: var(--gray-60);
      letter-spacing: 0.1em; text-transform: uppercase;
      flex-shrink: 0;
    }
    .section-title {
      font-family: var(--mono); font-size: 1.1rem; font-weight: 500;
      letter-spacing: 0.05em; color: var(--white);
    }
    .section-subtitle {
      font-family: var(--mono); font-size: 0.65rem; color: var(--gray-60);
      letter-spacing: 0.05em; margin-left: auto;
    }

    /* PROCESS */
    .process-section { padding: 5rem 0; border-bottom: 1px solid var(--gray-80); }
    .process-grid {
      display: grid; grid-template-columns: 280px 1fr; gap: 0;
    }
    .process-sidebar {
      border-right: 1px solid var(--gray-80); padding-right: 3rem;
    }
    .process-label {
      font-family: var(--mono); font-size: 0.6rem; color: var(--gray-40);
      letter-spacing: 0.15em; text-transform: uppercase; margin-bottom: 1.5rem;
    }
    .process-label::before { content: '/* '; }
    .process-label::after { content: ' */'; }
    .process-body { padding-left: 3rem; }
    .process-steps { display: flex; flex-direction: column; gap: 0; }
    .process-step {
      display: grid; grid-template-columns: 120px 1fr;
      border-bottom: 1px solid var(--gray-80);
      padding: 1.5rem 0;
    }
    .step-key {
      font-family: var(--mono); font-size: 0.65rem; color: var(--gray-40);
      letter-spacing: 0.05em;
    }
    .step-val {
      font-family: var(--sans); font-size: 0.9rem; color: var(--white);
      font-weight: 300;
    }
    .step-val strong { font-weight: 500; color: var(--gray-20); }

    /* GALLERY */
    .gallery-section { padding: 5rem 0; border-bottom: 1px solid var(--gray-80); }
    .gallery-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 2px;
    }
    @media (max-width: 1024px) { .gallery-grid { grid-template-columns: repeat(3, 1fr); } }
    @media (max-width: 768px)  { .gallery-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 480px)  { .gallery-grid { grid-template-columns: 1fr; } }
    .gallery-item {
      position: relative; overflow: hidden;
      background: var(--mid-dark); cursor: pointer;
    }
    .gallery-item img {
      width: 100%; height: 100%; aspect-ratio: 3/4; object-fit: cover; display: block;
      filter: grayscale(100%) contrast(1.15) brightness(0.95);
      transition: filter 0.4s, transform 0.4s;
    }
    .gallery-item:hover img { filter: grayscale(100%) contrast(1.3) brightness(1.05); transform: scale(1.03); }
    .gallery-caption {
      position: absolute; bottom: 0; left: 0; right: 0;
      background: linear-gradient(transparent, rgba(0,0,0,0.9));
      padding: 2rem 1rem 1rem;
      opacity: 0; transition: opacity 0.3s;
    }
    .gallery-item:hover .gallery-caption { opacity: 1; }
    .gallery-caption-artist {
      font-family: var(--mono); font-size: 0.6rem; color: var(--gray-40);
      letter-spacing: 0.1em; text-transform: uppercase;
    }
    .gallery-caption-style {
      font-family: var(--mono); font-size: 0.75rem; color: var(--white);
      font-weight: 500;
    }
    .gallery-item-num {
      position: absolute; top: 0.75rem; right: 0.75rem;
      font-family: var(--mono); font-size: 0.55rem; color: rgba(255,255,255,0.4);
      letter-spacing: 0.05em;
    }

    /* ARTISTS */
    .artists-section { padding: 5rem 0; border-bottom: 1px solid var(--gray-80); }
    .artists-list { display: flex; flex-direction: column; gap: 0; }
    .artist-row {
      display: grid; grid-template-columns: 80px 220px 1fr 180px;
      align-items: start;
      border-bottom: 1px solid var(--gray-80); padding: 2.5rem 0;
      gap: 2rem;
    }
    .artist-index {
      font-family: var(--mono); font-size: 0.65rem; color: var(--gray-60);
      padding-top: 0.25rem;
    }
    .artist-photo {
      width: 100%; aspect-ratio: 1; object-fit: cover;
      filter: grayscale(100%) contrast(1.2); display: block;
    }
    .artist-info {}
    .artist-name {
      font-family: var(--mono); font-size: 1.25rem; font-weight: 600;
      color: var(--white); margin-bottom: 0.25rem;
    }
    .artist-handle {
      font-family: var(--mono); font-size: 0.65rem; color: var(--gray-40);
      margin-bottom: 0.75rem; display: block;
    }
    .artist-specialty {
      font-family: var(--sans); font-size: 0.8rem; color: var(--gray-20);
      text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.75rem;
    }
    .artist-bio {
      font-family: var(--sans); font-size: 0.85rem; color: var(--gray-40);
      line-height: 1.7; font-weight: 300;
    }
    .artist-specs {
      display: flex; flex-direction: column; gap: 0.75rem;
    }
    .spec-row {
      display: flex; justify-content: space-between;
      padding-bottom: 0.75rem; border-bottom: 1px solid var(--gray-80);
    }
    .spec-row:last-child { border-bottom: none; }
    .spec-key {
      font-family: var(--mono); font-size: 0.6rem; color: var(--gray-60);
      letter-spacing: 0.08em; text-transform: uppercase;
    }
    .spec-val {
      font-family: var(--mono); font-size: 0.7rem; color: var(--white);
      font-weight: 500;
    }

    /* TECHNICAL */
    .technical-section { padding: 5rem 0; border-bottom: 1px solid var(--gray-80); }
    .technical-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2px; }
    .tech-block {
      border: 1px solid var(--gray-80); padding: 2rem;
      display: flex; flex-direction: column;
    }
    .tech-block-label {
      font-family: var(--mono); font-size: 0.6rem; color: var(--gray-40);
      letter-spacing: 0.15em; text-transform: uppercase; margin-bottom: 1.5rem;
    }
    .tech-block-title {
      font-family: var(--mono); font-size: 1rem; font-weight: 600;
      color: var(--white); margin-bottom: 1rem;
    }
    .tech-block-body {
      font-family: var(--sans); font-size: 0.85rem; color: var(--gray-40);
      line-height: 1.7; font-weight: 300; flex: 1;
    }
    .tech-block-footer {
      margin-top: 1.5rem; padding-top: 1rem; border-top: 1px solid var(--gray-80);
      font-family: var(--mono); font-size: 0.6rem; color: var(--gray-60);
    }

    /* AFTERCARE */
    .aftercare-section { padding: 5rem 0; border-bottom: 1px solid var(--gray-80); }
    .aftercare-list { display: flex; flex-direction: column; gap: 0; }
    .aftercare-item {
      display: grid; grid-template-columns: 80px 200px 1fr;
      align-items: start; gap: 2rem;
      border-bottom: 1px solid var(--gray-80); padding: 2rem 0;
    }
    .aftercare-num {
      font-family: var(--mono); font-size: 3rem; font-weight: 600;
      color: var(--gray-80); line-height: 1;
    }
    .aftercare-title {
      font-family: var(--mono); font-size: 0.8rem; font-weight: 500;
      color: var(--white); text-transform: uppercase; letter-spacing: 0.05em;
      padding-top: 0.5rem;
    }
    .aftercare-body {
      font-family: var(--sans); font-size: 0.9rem; color: var(--gray-40);
      line-height: 1.7; font-weight: 300; padding-top: 0.25rem;
    }

    /* BOOKING */
    .booking-section { padding: 5rem 0; border-bottom: 1px solid var(--gray-80); }
    .booking-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; }
    .booking-info {}
    .booking-intro {
      font-family: var(--mono); font-size: 0.65rem; color: var(--gray-40);
      letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 1.5rem;
    }
    .booking-statement {
      font-family: var(--mono); font-size: 1.4rem; font-weight: 300;
      color: var(--white); line-height: 1.4; margin-bottom: 2rem;
    }
    .booking-details { display: flex; flex-direction: column; gap: 0; }
    .booking-detail {
      display: flex; justify-content: space-between;
      padding: 1rem 0; border-bottom: 1px solid var(--gray-80);
    }
    .detail-key {
      font-family: var(--mono); font-size: 0.65rem; color: var(--gray-60);
      letter-spacing: 0.08em; text-transform: uppercase;
    }
    .detail-val {
      font-family: var(--mono); font-size: 0.75rem; color: var(--white);
    }
    .booking-form { display: flex; flex-direction: column; gap: 0; }
    .form-row {
      display: flex; flex-direction: column;
      border-bottom: 1px solid var(--gray-80); padding: 1rem 0;
    }
    .form-label {
      font-family: var(--mono); font-size: 0.55rem; color: var(--gray-60);
      letter-spacing: 0.15em; text-transform: uppercase; margin-bottom: 0.5rem;
    }
    .form-input {
      font-family: var(--mono); font-size: 0.85rem; color: var(--white);
      background: transparent; border: none; outline: none;
      padding: 0.25rem 0; width: 100%;
    }
    .form-input::placeholder { color: var(--gray-60); }
    .form-input:focus { border-bottom: 1px solid var(--white); margin-bottom: -1px; }
    .form-select {
      font-family: var(--mono); font-size: 0.85rem; color: var(--white);
      background: transparent; border: none; outline: none;
      padding: 0.25rem 0; width: 100%; appearance: none;
      cursor: pointer;
    }
    .form-select option { background: var(--dark); }
    textarea.form-input { resize: none; min-height: 80px; }
    .form-submit {
      margin-top: 2rem;
      font-family: var(--mono); font-size: 0.7rem; font-weight: 600;
      letter-spacing: 0.15em; text-transform: uppercase;
      background: var(--white); color: var(--black);
      border: none; padding: 1rem 2rem; cursor: pointer; width: 100%;
    }

    /* FAQ */
    .faq-section { padding: 5rem 0; border-bottom: 1px solid var(--gray-80); }
    .faq-list { display: flex; flex-direction: column; gap: 0; }
    .faq-item {
      border-bottom: 1px solid var(--gray-80);
    }
    .faq-item summary {
      display: flex; justify-content: space-between; align-items: center;
      padding: 1.5rem 0; cursor: pointer; list-style: none;
    }
    .faq-item summary::-webkit-details-marker { display: none; }
    .faq-q {
      font-family: var(--mono); font-size: 0.85rem; font-weight: 500;
      color: var(--white); max-width: 60ch;
    }
    .faq-toggle {
      font-family: var(--mono); font-size: 1rem; color: var(--gray-40);
      width: 24px; text-align: center; transition: transform 0.2s;
      flex-shrink: 0;
    }
    .faq-item[open] .faq-toggle { transform: rotate(45deg); color: var(--white); }
    .faq-answer {
      font-family: var(--sans); font-size: 0.9rem; color: var(--gray-40);
      line-height: 1.7; font-weight: 300;
      padding: 0 0 1.5rem;
      max-width: 70ch;
    }

    /* LOCATION */
    .location-section { padding: 5rem 0; border-bottom: 1px solid var(--gray-80); }
    .location-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; }
    .hours-table { display: flex; flex-direction: column; gap: 0; }
    .hours-row {
      display: grid; grid-template-columns: 140px 1fr;
      padding: 0.75rem 0; border-bottom: 1px solid var(--gray-80);
    }
    .hours-day {
      font-family: var(--mono); font-size: 0.65rem; color: var(--gray-40);
      letter-spacing: 0.05em;
    }
    .hours-time {
      font-family: var(--mono); font-size: 0.65rem; color: var(--white);
    }
    .hours-time.closed { color: var(--gray-60); }
    .contact-block { display: flex; flex-direction: column; gap: 1.5rem; }
    .contact-item {}
    .contact-label {
      font-family: var(--mono); font-size: 0.55rem; color: var(--gray-60);
      letter-spacing: 0.15em; text-transform: uppercase; margin-bottom: 0.25rem;
    }
    .contact-value {
      font-family: var(--mono); font-size: 0.85rem; color: var(--white);
      text-decoration: none;
    }
    .contact-value:hover { color: var(--gray-20); }

    /* INSTAGRAM */
    .ig-section { padding: 5rem 0; border-bottom: 1px solid var(--gray-80); }
    .ig-grid { display: grid; grid-template-columns: repeat(6, 1fr); gap: 2px; }
    .ig-post { display: block; aspect-ratio: 1; overflow: hidden; position: relative; }
    .ig-post img {
      width: 100%; height: 100%; object-fit: cover;
      filter: grayscale(100%) contrast(1.1);
      transition: filter 0.3s, transform 0.3s;
    }
    .ig-post:hover img { filter: grayscale(50%) contrast(1.2); transform: scale(1.05); }
    .ig-post-overlay {
      position: absolute; inset: 0;
      background: rgba(0,0,0,0.6);
      display: flex; align-items: center; justify-content: center;
      opacity: 0; transition: opacity 0.3s;
    }
    .ig-post:hover .ig-post-overlay { opacity: 1; }
    .ig-handle {
      font-family: var(--mono); font-size: 0.6rem; color: var(--white);
      letter-spacing: 0.1em;
    }

    /* FOOTER */
    footer {
      padding: 3rem 2rem; border-top: 1px solid var(--gray-80);
      display: grid; grid-template-columns: 1fr auto 1fr; align-items: center;
      gap: 2rem;
    }
    .footer-left {
      font-family: var(--mono); font-size: 0.6rem; color: var(--gray-60);
      letter-spacing: 0.05em;
    }
    .footer-center {
      font-family: var(--mono); font-size: 0.7rem; font-weight: 600;
      color: var(--white); letter-spacing: 0.2em; text-align: center;
    }
    .footer-right {
      font-family: var(--mono); font-size: 0.6rem; color: var(--gray-60);
      text-align: right;
    }

    /* STUDIO INTERIOR — equipment / film-grain strip */
    .studio-section {
      padding: 6rem 0; border-bottom: 1px solid var(--gray-80);
      background: var(--near-black);
      position: relative;
    }
    .studio-section::before {
      content: ''; position: absolute; inset: 0; pointer-events: none;
      background-image:
        repeating-linear-gradient(0deg, transparent 0 2px, rgba(255,255,255,0.012) 2px 3px),
        radial-gradient(ellipse at 30% 20%, rgba(255,255,255,0.025) 0%, transparent 60%);
      opacity: 0.9;
      mix-blend-mode: screen;
    }
    .studio-strip {
      display: grid;
      grid-template-columns: 1.4fr 1fr 1fr;
      grid-template-rows: repeat(2, 240px);
      gap: 2px;
      margin-top: 2.5rem;
    }
    .studio-cell {
      position: relative; overflow: hidden;
      background: var(--mid-dark);
      border: 1px solid var(--gray-80);
    }
    .studio-cell.tall { grid-row: span 2; }
    .studio-cell img {
      width: 100%; height: 100%; object-fit: cover;
      filter: grayscale(100%) contrast(1.15) brightness(0.82);
      transition: filter 0.4s, transform 0.5s;
    }
    .studio-cell:hover img { filter: grayscale(85%) contrast(1.2) brightness(0.92); transform: scale(1.03); }
    .studio-cell-meta {
      position: absolute; top: 0.75rem; left: 0.75rem;
      font-family: var(--mono); font-size: 0.55rem; letter-spacing: 0.18em;
      text-transform: uppercase; color: var(--gray-20);
      background: rgba(0,0,0,0.6); padding: 0.25rem 0.5rem;
      border: 1px solid var(--gray-80);
    }
    .studio-cell-cap {
      position: absolute; bottom: 0; left: 0; right: 0;
      padding: 1rem; background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, transparent 100%);
    }
    .studio-cell-cap h4 {
      font-family: var(--mono); font-size: 0.7rem; font-weight: 600;
      color: var(--white); letter-spacing: 0.08em; text-transform: uppercase;
      margin-bottom: 0.25rem;
    }
    .studio-cell-cap p {
      font-family: var(--sans); font-size: 0.72rem; font-weight: 300;
      color: var(--gray-40); line-height: 1.5;
    }
    .studio-cell.placeholder {
      display: flex; align-items: center; justify-content: center;
      background:
        linear-gradient(135deg, var(--mid-dark) 0%, var(--near-black) 100%);
    }
    .studio-cell.placeholder::after {
      content: ''; position: absolute; inset: 0;
      background-image:
        repeating-linear-gradient(45deg, transparent 0 6px, rgba(255,255,255,0.02) 6px 7px);
    }
    .studio-cell.placeholder .ph-content {
      position: relative; z-index: 1; text-align: center; padding: 1rem;
    }
    .studio-cell.placeholder .ph-key {
      font-family: var(--mono); font-size: 0.55rem; letter-spacing: 0.2em;
      color: var(--gray-60); text-transform: uppercase; margin-bottom: 0.5rem;
    }
    .studio-cell.placeholder .ph-val {
      font-family: var(--mono); font-size: 0.95rem; color: var(--gray-20);
      font-weight: 500; letter-spacing: 0.08em;
    }
    .studio-cell.placeholder .ph-sub {
      font-family: var(--sans); font-size: 0.7rem; color: var(--gray-60);
      font-weight: 300; margin-top: 0.4rem; max-width: 22ch;
      margin-left: auto; margin-right: auto; line-height: 1.5;
    }

    /* CONTAINER */
    .container { max-width: 1200px; margin: 0 auto; padding: 0 2rem; }

    @media (max-width: 768px) {
      .hero { grid-template-columns: 1fr; }
      .hero-image-panel { height: 50vh; }
      .gallery-grid { grid-template-columns: 1fr 1fr; }
      .gallery-item.wide { grid-column: span 2; }
      .artist-row { grid-template-columns: 1fr; }
      .booking-grid { grid-template-columns: 1fr; }
      .location-grid { grid-template-columns: 1fr; }
      .ig-grid { grid-template-columns: repeat(3, 1fr); }
      .technical-grid { grid-template-columns: 1fr; }
      .process-grid { grid-template-columns: 1fr; }
      .studio-strip { grid-template-columns: 1fr 1fr; grid-template-rows: repeat(3, 200px); }
      .studio-cell.tall { grid-row: span 1; }
    }
  </style>
  <script src="/template-topheader.js" defer></script>
  <style>
    html { scroll-padding-top: 40px !important; }
    body { padding-top: 36px !important; }
    body > #dcrader-topheader, body > [data-dcrader-topheader] { padding-top: 0 !important; margin-top: -36px !important; }
  </style>
</head>
<body>
  <a href="#main" class="sr-only">Skip to main content</a>

  <!-- NAV -->
  <nav class="nav" role="navigation" aria-label="Main navigation">
    <a href={`${base}`} class="nav-logo">← all<span>variants</span></a>
    <a href={`${base}v4-black-grey-realism`} class="nav-logo">{studio.name}<span>.ink</span></a>
    <div style="display:flex;align-items:center;gap:2rem;">
      <ul class="nav-links" role="list">
        <li><a href="#gallery">Gallery</a></li>
        <li><a href="#artists">Artists</a></li>
        <li><a href="/v4-black-grey-realism/process">Process</a></li>
        <li><a href="#booking">Book</a></li>
      </ul>
      <a href="#booking" class="nav-book">Consult</a>
    </div>
  </nav>

  <!-- HERO -->
  <main id="main">
    <BookingWidgetHero studio={studio} heroImg={heroImg} />

    <!-- PROCESS -->
    <section class="process-section" id="process" aria-labelledby="process-heading">
      <div class="container">
        <div class="section-header">
          <span class="section-index">01</span>
          <h2 class="section-title" id="process-heading">HOW WE WORK</h2>
          <span class="section-subtitle">PROCESS DOCUMENTATION</span>
        </div>
        <div class="process-grid">
          <div class="process-sidebar">
            <p class="process-label">Studio protocol</p>
            <p style="font-family: var(--sans); font-size: 0.85rem; color: var(--gray-40); line-height: 1.8; font-weight: 300;">
              Realism is not applied art — it's extracted from reference. Every piece begins with high-resolution photography. Every shadow is mapped before the needle touches skin.
            </p>
          </div>
          <div class="process-body">
            <div class="process-steps">
              <div class="process-step">
                <span class="step-key">STEP_01</span>
                <p class="step-val"><strong>Reference submission</strong><br />High-resolution photo, RAW preferred. We reject pixelated or poorly lit reference — quality in determines quality out.</p>
              </div>
              <div class="process-step">
                <span class="step-key">STEP_02</span>
                <p class="step-val"><strong>Consultation</strong><br />In-person or video. We discuss placement, sizing, skin tone variables, and expected long-term shift of black and grey ink.</p>
              </div>
              <div class="process-step">
                <span class="step-key">STEP_03</span>
                <p class="step-val"><strong>Deposit + stencil</strong><br />${studio.depositAmount} secures your slot. Custom stencil is prepared in advance — we do not improvise realism.</p>
              </div>
              <div class="process-step">
                <span class="step-key">STEP_04</span>
                <p class="step-val"><strong>Execution</strong><br />Session length varies 4–8 hours for major pieces. We build layers: lightest grays first, deepest blacks last.</p>
              </div>
              <div class="process-step">
                <span class="step-key">STEP_05</span>
                <p class="step-val"><strong>Touchup review</strong><br />Complex realism returns at 4–6 months for shadow deepening and highlight refinement.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- GALLERY -->
    <section class="gallery-section" id="gallery" aria-labelledby="gallery-heading">
      <div class="container">
        <div class="section-header">
          <span class="section-index">02</span>
          <h2 class="section-title" id="gallery-heading">PORTFOLIO</h2>
          <span class="section-subtitle">{studio.gallery.length} WORKS SHOWN</span>
        </div>
      </div>
      <div class="container">
        <div class="gallery-grid" role="list" aria-label="Portfolio gallery">
          {studio.gallery.map((item, i) => (
            <div class="gallery-item" role="listitem">
              <Picture formats={['avif','webp']} src={resolveImage(item.image)} alt={item.alt} loading="lazy" decoding="async" widths={[300, 600, 800]} sizes="(min-width: 1024px) 25vw, (min-width: 768px) 33vw, 50vw" width={600} height={800} />
              <div class="gallery-item-num" aria-hidden="true">{pad(i+1)}/{pad(studio.gallery.length)}</div>
              <div class="gallery-caption">
                <div class="gallery-caption-artist">{item.artist}</div>
                <div class="gallery-caption-style">{item.style}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ARTISTS -->
    <section class="artists-section" id="artists" aria-labelledby="artists-heading">
      <div class="container">
        <div class="section-header">
          <span class="section-index">03</span>
          <h2 class="section-title" id="artists-heading">SPECIALISTS</h2>
          <span class="section-subtitle">{studio.artists.length} ARTISTS</span>
        </div>
        <ul class="artists-list" role="list">
          {studio.artists.map((artist, i) => (
            <li class="artist-row" role="listitem">
              <div class="artist-index" aria-hidden="true">
                <span>{pad(i+1)}</span><br />
                <span style="color: var(--gray-80)">of {pad(studio.artists.length)}</span>
              </div>
              <Picture formats={['avif','webp']} src={resolveImage(artist.image)} alt={`Portrait of ${artist.name}`} class="artist-photo" loading="lazy" decoding="async" widths={[220, 440]} sizes="220px" width={440} height={440} />
              <div class="artist-info">
                <h3 class="artist-name">{artist.name}</h3>
                <span class="artist-handle">{artist.handle}</span>
                <p class="artist-specialty">{artist.specialty}</p>
                <p class="artist-bio">{artist.bio}</p>
              </div>
              <div class="artist-specs" role="list" aria-label={`${artist.name} specifications`}>
                <div class="spec-row" role="listitem">
                  <span class="spec-key">EXP</span>
                  <span class="spec-val">{artist.yearsExp} yr</span>
                </div>
                {artist.styles.map(s => (
                  <div class="spec-row" role="listitem">
                    <span class="spec-key">SPEC</span>
                    <span class="spec-val">{s}</span>
                  </div>
                ))}
              </div>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- TECHNICAL -->
    <section class="technical-section" aria-labelledby="technical-heading">
      <div class="container">
        <div class="section-header">
          <span class="section-index">04</span>
          <h2 class="section-title" id="technical-heading">TECHNICAL PARAMETERS</h2>
          <span class="section-subtitle">REALISM METHODOLOGY</span>
        </div>
        <div class="technical-grid">
          <div class="tech-block">
            <span class="tech-block-label">NEEDLE_CONFIGURATION</span>
            <h3 class="tech-block-title">Round liners + magnums</h3>
            <p class="tech-block-body">Realism demands both — tight round liners for detail work and edges, curved magnums for seamless gradient blending across large gray areas. We don't use tribal or flat techniques.</p>
            <div class="tech-block-footer">GEAR: Cheyenne Hawk + FK Irons</div>
          </div>
          <div class="tech-block">
            <span class="tech-block-label">INK_SPECTRUM</span>
            <h3 class="tech-block-title">Black to white, 9 tonal steps</h3>
            <p class="tech-block-body">We work a strict tonal palette: pure black anchor, seven intermediate washes, distilled water highlights. No color. Color is a different discipline and we don't pretend otherwise.</p>
            <div class="tech-block-footer">INK: Eternal / Quantum Black Series</div>
          </div>
          <div class="tech-block">
            <span class="tech-block-label">SKIN_VARIABLES</span>
            <h3 class="tech-block-title">Fitzpatrick scale assessment</h3>
            <p class="tech-block-body">Realism reads differently across skin tones. We assess Fitzpatrick scale at consultation and adjust tonal compression accordingly. Lighter skin allows wider contrast range; darker skin requires careful highlight management.</p>
            <div class="tech-block-footer">ASSESSED: at consultation</div>
          </div>
          <div class="tech-block">
            <span class="tech-block-label">LONGEVITY_FACTORS</span>
            <h3 class="tech-block-title">UV degrades black and grey</h3>
            <p class="tech-block-body">Black ink grays toward middle tones over time. UV exposure accelerates this dramatically. We design with long-term aging in mind — contrast slightly higher at execution, knowing the 10-year pull toward midtone.</p>
            <div class="tech-block-footer">EXPECTED SHIFT: 5–10yr horizon</div>
          </div>
        </div>
      </div>
    </section>

    <!-- STUDIO INTERIOR & STATION GALLERY -->
    <section class="studio-section" id="studio" aria-labelledby="studio-heading">
      <div class="container">
        <div class="section-header">
          <span class="section-index">05</span>
          <h2 class="section-title" id="studio-heading">THE FLOOR</h2>
          <span class="section-subtitle">STATION DOCUMENTATION / STERILE PROTOCOL</span>
        </div>
        <p style="font-family: var(--sans); font-size: 0.9rem; color: var(--gray-40); line-height: 1.8; font-weight: 300; max-width: 70ch; margin-bottom: 0.5rem;">
          Realism is a clean discipline. Every station is photographed monthly for our internal log, every autoclave cycle is dated and filed. We don't romanticize the shop floor — we document it.
        </p>
        <div class="studio-strip" role="list" aria-label="Studio interior and equipment documentation">
          <div class="studio-cell tall" role="listitem">
            <Picture formats={['avif','webp']} src={resolveImage(studio.gallery[0].image)} alt="Cassandra Vane's primary station — Cheyenne Hawk rotary, single-use grips, ink cups taped down" loading="lazy" decoding="async" widths={[600, 900, 1200]} sizes="(min-width: 768px) 50vw, 100vw" width={1200} height={1600} />
            <span class="studio-cell-meta" aria-hidden="true">STATION_01 / 35mm</span>
            <div class="studio-cell-cap">
              <h4>Cassandra's station, north wall</h4>
              <p>Cheyenne Hawk Pen, custom RCA, daylight-balanced 5000K overhead. The only color in the room.</p>
            </div>
          </div>
          <div class="studio-cell placeholder" role="listitem" aria-label="Sterilization specification">
            <div class="ph-content">
              <p class="ph-key">AUTOCLAVE / STATIM 2000</p>
              <p class="ph-val">132°C / 6 min</p>
              <p class="ph-sub">Spore-tested weekly. Logs available on request.</p>
            </div>
          </div>
          <div class="studio-cell" role="listitem">
            <Picture formats={['avif','webp']} src={resolveImage(studio.gallery[3].image)} alt="Jordan Ash's machine drawer — magnums and round liners sorted by gauge" loading="lazy" decoding="async" widths={[400, 600]} sizes="(min-width: 768px) 25vw, 50vw" width={600} height={600} />
            <span class="studio-cell-meta" aria-hidden="true">DRAWER_03</span>
            <div class="studio-cell-cap">
              <h4>Sorted: gauge ascending</h4>
              <p>Round liners 03 → 14, magnums 09 → 23 curved. Single-use, dated, never re-sleeved.</p>
            </div>
          </div>
          <div class="studio-cell placeholder" role="listitem" aria-label="Ink inventory">
            <div class="ph-content">
              <p class="ph-key">INK_LOG / 09-23</p>
              <p class="ph-val">Eternal · Quantum</p>
              <p class="ph-sub">Black series only. Batch numbers recorded against every client.</p>
            </div>
          </div>
          <div class="studio-cell placeholder" role="listitem" aria-label="Lighting specification">
            <div class="ph-content">
              <p class="ph-key">LIGHTING / CRI95+</p>
              <p class="ph-val">5000K, dimmable</p>
              <p class="ph-sub">Calibrated monthly against a Datacolor reference card.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- AFTERCARE -->
    <section class="aftercare-section" id="aftercare" aria-labelledby="aftercare-heading">
      <div class="container">
        <div class="section-header">
          <span class="section-index">06</span>
          <h2 class="section-title" id="aftercare-heading">AFTERCARE PROTOCOL</h2>
          <span class="section-subtitle">REQUIRED READING</span>
        </div>
        <ul class="aftercare-list" role="list">
          {studio.aftercare.map(item => (
            <li class="aftercare-item" role="listitem">
              <span class="aftercare-num" aria-hidden="true">{pad(item.step)}</span>
              <h3 class="aftercare-title">{item.title}</h3>
              <p class="aftercare-body">{item.body}</p>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- BOOKING -->
    <section class="booking-section" id="booking" aria-labelledby="booking-heading">
      <div class="container">
        <div class="section-header">
          <span class="section-index">07</span>
          <h2 class="section-title" id="booking-heading">REQUEST CONSULTATION</h2>
          <span class="section-subtitle">NO WALK-INS</span>
        </div>
        <div class="booking-grid">
          <div class="booking-info">
            <p class="booking-intro">Consultation protocol</p>
            <p class="booking-statement">Every piece is pre-planned. Every reference is reviewed. Every session is confirmed in advance.</p>
            <div class="booking-details">
              <div class="booking-detail">
                <span class="detail-key">Deposit</span>
                <span class="detail-val">${studio.depositAmount} (applied to total)</span>
              </div>
              <div class="booking-detail">
                <span class="detail-key">Minimum</span>
                <span class="detail-val">${studio.minimumCharge}</span>
              </div>
              <div class="booking-detail">
                <span class="detail-key">Rate</span>
                <span class="detail-val">${studio.hourlyRate}/hr</span>
              </div>
              <div class="booking-detail">
                <span class="detail-key">Walk-ins</span>
                <span class="detail-val">Never accepted</span>
              </div>
              <div class="booking-detail">
                <span class="detail-key">Age requirement</span>
                <span class="detail-val">18+ with valid ID</span>
              </div>
            </div>
          </div>
          <form class="booking-form" aria-label="Booking inquiry form" novalidate>
            <div class="form-row">
              <label class="form-label" for="name">name</label>
              <input type="text" id="name" name="name" class="form-input" placeholder="Full name" autocomplete="name" />
            </div>
            <div class="form-row">
              <label class="form-label" for="email">email</label>
              <input type="email" id="email" name="email" class="form-input" placeholder="your@email.com" autocomplete="email" />
            </div>
            <div class="form-row">
              <label class="form-label" for="artist">preferred artist</label>
              <select id="artist" name="artist" class="form-select">
                <option value="">— select —</option>
                {studio.artists.map(a => <option value={a.name}>{a.name}</option>)}
              </select>
            </div>
            <div class="form-row">
              <label class="form-label" for="concept">concept + reference description</label>
              <textarea id="concept" name="concept" class="form-input" placeholder="Describe your subject, sizing, and placement. Attach reference images via email after submitting." rows={4}></textarea>
            </div>
            <button type="submit" class="form-submit">Submit Inquiry</button>
          </form>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="faq-section" id="faq" aria-labelledby="faq-heading">
      <div class="container">
        <div class="section-header">
          <span class="section-index">08</span>
          <h2 class="section-title" id="faq-heading">COMMON QUERIES</h2>
        </div>
        <ul class="faq-list" role="list">
          {studio.faqs.map(faq => (
            <li role="listitem">
              <details class="faq-item">
                <summary>
                  <span class="faq-q">{faq.question}</span>
                  <span class="faq-toggle" aria-hidden="true">+</span>
                </summary>
                <p class="faq-answer">{faq.answer}</p>
              </details>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- INSTAGRAM -->
    <section class="ig-section" aria-labelledby="ig-heading">
      <div class="container">
        <div class="section-header">
          <span class="section-index">09</span>
          <h2 class="section-title" id="ig-heading">INSTAGRAM</h2>
          <span class="section-subtitle">{studio.instagram}</span>
        </div>
      </div>
      <div class="container">
        <div class="ig-grid" role="list" aria-label="Instagram posts">
          {studio.igPosts.map(post => (
            <a href={post.link} class="ig-post" target="_blank" rel="noopener noreferrer" role="listitem" aria-label={post.alt}>
              <Picture formats={['avif','webp']} src={resolveImage(post.image)} alt={post.alt} loading="lazy" decoding="async" widths={[200, 400]} sizes="(min-width: 640px) 16vw, 33vw" width={400} height={400} />
              <div class="ig-post-overlay"><span class="ig-handle">{studio.instagram}</span></div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- LOCATION -->
    <section class="location-section" id="location" aria-labelledby="location-heading">
      <div class="container">
        <div class="section-header">
          <span class="section-index">10</span>
          <h2 class="section-title" id="location-heading">LOCATION + HOURS</h2>
        </div>
        <div class="location-grid">
          <div>
            <h3 style="font-family: var(--mono); font-size: 0.65rem; color: var(--gray-60); letter-spacing: 0.15em; text-transform: uppercase; margin-bottom: 1.5rem;">OPERATING_HOURS</h3>
            <div class="hours-table" role="list">
              {studio.hours.map(h => (
                <div class="hours-row" role="listitem">
                  <span class="hours-day">{h.day.toUpperCase()}</span>
                  <span class={`hours-time${h.open === 'Closed' ? ' closed' : ''}`}>
                    {h.open === 'Closed' ? 'CLOSED' : `${h.open} – ${h.close}`}
                  </span>
                </div>
              ))}
            </div>
          </div>
          <div class="contact-block">
            <h3 style="font-family: var(--mono); font-size: 0.65rem; color: var(--gray-60); letter-spacing: 0.15em; text-transform: uppercase; margin-bottom: 1.5rem;">CONTACT_INFO</h3>
            <div class="contact-item">
              <div class="contact-label">Address</div>
              <a href={studio.mapUrl} class="contact-value" target="_blank" rel="noopener noreferrer">{studio.address}<br />{studio.city}</a>
            </div>
            <div class="contact-item">
              <div class="contact-label">Phone</div>
              <a href={`tel:${studio.phone}`} class="contact-value">{studio.phone}</a>
            </div>
            <div class="contact-item">
              <div class="contact-label">Email</div>
              <a href={`mailto:${studio.email}`} class="contact-value">{studio.email}</a>
            </div>
            <div class="contact-item">
              <div class="contact-label">Instagram</div>
              <span class="contact-value">{studio.instagram}</span>
            </div>
            <div class="contact-item" style="margin-top: 2rem;">
              <p style="font-family: var(--mono); font-size: 0.65rem; color: var(--gray-60); line-height: 1.8;">
                // Realism is never walk-in.<br />
                // Prepare your reference first.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer>
    <div class="footer-left">&copy; {new Date().getFullYear()} {studio.name}. San Diego, CA.</div>
    <div class="footer-center">{studio.name}</div>
    <div class="footer-right">{studio.tagline}</div>

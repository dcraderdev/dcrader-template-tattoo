---
import { studio } from '../../data/v4';
import '../../styles/global.css';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{studio.name} — Black &amp; Grey Realism, {studio.city}</title>
  <meta name="description" content={studio.description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <style>
    :root {
      --black: #000000;
      --near-black: #0A0A0A;
      --surface: #111111;
      --surface2: #1A1A1A;
      --mid: #333333;
      --gray: #777777;
      --light: #AAAAAA;
      --white: #F5F5F5;
      --pure-white: #FFFFFF;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { background: var(--black); color: var(--white); font-family: 'Inter', system-ui, sans-serif; font-weight: 300; }

    /* Nav */
    .nav { background: var(--black); border-bottom: 1px solid var(--mid); position: sticky; top: 0; z-index: 100; }
    .nav-inner { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; display: flex; align-items: center; justify-content: space-between; min-height: 60px; }
    .nav-logo { font-family: 'Bebas Neue', sans-serif; font-size: 1.35rem; letter-spacing: 0.18em; color: var(--white); text-decoration: none; }
    .nav-links { display: flex; gap: 0; list-style: none; flex-wrap: wrap; }
    .nav-links a { color: var(--gray); text-decoration: none; font-size: 0.68rem; letter-spacing: 0.18em; text-transform: uppercase; font-weight: 500; padding: 0.5rem 0.8rem; display: block; transition: color 0.2s; }
    .nav-links a:hover, .nav-links a:focus-visible { color: var(--white); }
    .nav-cta { background: var(--white) !important; color: var(--black) !important; padding: 0.4rem 1.1rem !important; font-weight: 600 !important; }
    .nav-cta:hover, .nav-cta:focus-visible { opacity: 0.85; }

    /* Hero */
    .hero { position: relative; min-height: 100vh; display: flex; align-items: flex-end; overflow: hidden; }
    .hero-bg { position: absolute; inset: 0; background-image: linear-gradient(to top, rgba(0,0,0,0.98) 0%, rgba(0,0,0,0.5) 50%, rgba(0,0,0,0.3) 100%), url('https://images.unsplash.com/photo-1570968915860-54d5c301fa9f?w=1920&q=85&auto=format&fit=crop'); background-size: cover; background-position: center top; filter: grayscale(100%) contrast(1.2); }
    .hero-content { position: relative; width: 100%; padding: 0 1.5rem 4rem; }
    .hero-inner { max-width: 1200px; margin: 0 auto; }
    .hero-eyebrow { font-size: 0.65rem; letter-spacing: 0.35em; text-transform: uppercase; color: var(--gray); font-weight: 500; margin-bottom: 1rem; display: block; }
    .hero h1 { font-family: 'Bebas Neue', sans-serif; font-size: clamp(4rem, 12vw, 10rem); color: var(--white); line-height: 0.9; letter-spacing: 0.04em; margin-bottom: 1.5rem; text-shadow: 0 0 60px rgba(255,255,255,0.05); }
    .hero h1 em { display: block; font-style: normal; color: var(--gray); font-size: 0.45em; letter-spacing: 0.08em; }
    .hero-tagline { font-size: 0.9rem; color: var(--gray); max-width: 500px; line-height: 1.75; margin-bottom: 2.5rem; font-weight: 300; }
    .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; align-items: center; }
    .btn-primary { background: var(--white); color: var(--black); padding: 0.9rem 2.5rem; font-family: 'Inter', sans-serif; font-size: 0.72rem; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; text-decoration: none; transition: opacity 0.2s; }
    .btn-primary:hover, .btn-primary:focus-visible { opacity: 0.85; }
    .btn-ghost { background: transparent; color: var(--white); padding: 0.9rem 2rem; font-family: 'Inter', sans-serif; font-size: 0.72rem; font-weight: 400; letter-spacing: 0.15em; text-transform: uppercase; text-decoration: none; border: 1px solid var(--mid); transition: border-color 0.2s; }
    .btn-ghost:hover, .btn-ghost:focus-visible { border-color: var(--white); }
    .hero-scroll { display: flex; gap: 3rem; margin-top: 3rem; border-top: 1px solid var(--mid); padding-top: 2rem; }
    .hero-stat { }
    .hero-stat .val { font-family: 'Bebas Neue', sans-serif; font-size: 2rem; color: var(--white); display: block; letter-spacing: 0.05em; }
    .hero-stat .lbl { font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gray); }

    /* Section */
    .section { padding: 6rem 1.5rem; }
    .section-inner { max-width: 1200px; margin: 0 auto; }
    .section-label { font-size: 0.6rem; letter-spacing: 0.3em; text-transform: uppercase; color: var(--gray); font-weight: 500; margin-bottom: 0.5rem; display: block; }
    .section-title { font-family: 'Bebas Neue', sans-serif; font-size: clamp(2.5rem, 5vw, 4.5rem); color: var(--white); line-height: 0.95; letter-spacing: 0.04em; margin-bottom: 0.75rem; }
    .white-rule { width: 40px; height: 1px; background: var(--mid); margin: 1.25rem 0 3rem; }

    /* Artists */
    .artists-bg { background: var(--surface); }
    .artist-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1px; background: var(--mid); }
    .artist-card { background: var(--near-black); overflow: hidden; }
    .artist-img { width: 100%; height: 320px; object-fit: cover; object-position: top; display: block; filter: grayscale(100%) contrast(1.15); }
    .artist-info { padding: 2rem; }
    .artist-name { font-family: 'Bebas Neue', sans-serif; font-size: 1.6rem; color: var(--white); letter-spacing: 0.06em; margin-bottom: 0.25rem; }
    .artist-specialty { font-size: 0.62rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--gray); margin-bottom: 1rem; font-weight: 500; }
    .artist-bio { font-size: 0.85rem; color: var(--light); line-height: 1.7; margin-bottom: 0.75rem; font-weight: 300; }
    .artist-handle { font-size: 0.75rem; color: var(--mid); }
    .style-tags { display: flex; gap: 0.4rem; flex-wrap: wrap; margin-top: 0.75rem; }
    .style-tag { border: 1px solid var(--mid); color: var(--gray); font-size: 0.58rem; letter-spacing: 0.12em; text-transform: uppercase; padding: 0.2rem 0.55rem; font-weight: 500; }
    .years-badge { display: inline-block; background: var(--mid); color: var(--white); font-size: 0.6rem; letter-spacing: 0.15em; text-transform: uppercase; padding: 0.2rem 0.6rem; margin-top: 0.5rem; font-weight: 600; }

    /* Gallery */
    .gallery-bg { background: var(--near-black); }
    .masonry-grid { columns: 2; column-gap: 4px; }
    @media (min-width: 640px) { .masonry-grid { columns: 3; } }
    @media (min-width: 1024px) { .masonry-grid { columns: 4; } }
    .masonry-item { break-inside: avoid; margin-bottom: 4px; overflow: hidden; position: relative; }
    .masonry-item img { width: 100%; display: block; filter: grayscale(100%) contrast(1.1); transition: transform 0.5s, filter 0.4s; }
    .masonry-item:hover img { transform: scale(1.03); filter: grayscale(80%) contrast(1.15); }
    .masonry-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, transparent 50%); opacity: 0; transition: opacity 0.3s; display: flex; align-items: flex-end; padding: 0.75rem; }
    .masonry-item:hover .masonry-overlay { opacity: 1; }
    .masonry-cap { color: var(--light); font-size: 0.65rem; letter-spacing: 0.1em; text-transform: uppercase; font-weight: 500; }

    /* Aftercare */
    .aftercare-bg { background: var(--surface); }
    .aftercare-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1px; background: var(--mid); margin-top: 3rem; }
    .aftercare-card { background: var(--near-black); padding: 2rem; }
    .aftercare-num { font-family: 'Bebas Neue', sans-serif; font-size: 4rem; color: var(--mid); line-height: 1; margin-bottom: 0.75rem; }
    .aftercare-title { font-size: 0.72rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--white); font-weight: 600; margin-bottom: 0.65rem; }
    .aftercare-body { font-size: 0.83rem; color: var(--gray); line-height: 1.75; font-weight: 300; }

    /* Booking */
    .booking-bg { background: var(--black); border-top: 1px solid var(--mid); border-bottom: 1px solid var(--mid); }
    .booking-grid { display: grid; grid-template-columns: 1fr; gap: 4rem; }
    @media (min-width: 768px) { .booking-grid { grid-template-columns: 1fr 1fr; } }
    .booking-info p { font-size: 0.88rem; color: var(--gray); line-height: 1.8; margin-bottom: 1rem; font-weight: 300; }
    .booking-price-box { border: 1px solid var(--mid); padding: 1.5rem; margin-top: 1.5rem; display: grid; gap: 0.5rem; }
    .booking-price-box p { font-size: 0.82rem; color: var(--gray); margin: 0; }
    .booking-price-box strong { color: var(--white); font-weight: 500; }
    .booking-form { display: grid; gap: 1.5rem; }
    label { display: block; font-size: 0.58rem; letter-spacing: 0.25em; text-transform: uppercase; color: var(--mid); font-weight: 600; margin-bottom: 0.3rem; }
    input, select, textarea { width: 100%; background: transparent; border: none; border-bottom: 1px solid var(--mid); color: var(--white); padding: 0.6rem 0; font-family: 'Inter', sans-serif; font-size: 0.88rem; font-weight: 300; outline: none; transition: border-color 0.2s; }
    input:focus, select:focus, textarea:focus { border-color: var(--white); }
    input::placeholder, textarea::placeholder { color: var(--mid); }
    select option { background: var(--surface); }
    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
    .btn-submit { background: var(--white); color: var(--black); padding: 0.9rem 2rem; font-family: 'Inter', sans-serif; font-size: 0.72rem; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; border: none; cursor: pointer; transition: opacity 0.2s; width: 100%; margin-top: 0.5rem; }
    .btn-submit:hover, .btn-submit:focus-visible { opacity: 0.85; }

    /* FAQ */
    .faq-bg { background: var(--surface); }
    .faq-list { margin-top: 2rem; }
    details { border-bottom: 1px solid var(--mid); }
    summary { padding: 1.25rem 0; cursor: pointer; font-family: 'Bebas Neue', sans-serif; font-size: 1.15rem; color: var(--white); list-style: none; display: flex; justify-content: space-between; align-items: center; gap: 1rem; letter-spacing: 0.06em; }
    summary::-webkit-details-marker { display: none; }
    summary::after { content: '+'; font-family: 'Inter', sans-serif; font-size: 1.5rem; font-weight: 200; color: var(--mid); flex-shrink: 0; transition: transform 0.2s; }
    details[open] summary::after { transform: rotate(45deg); color: var(--white); }
    .faq-answer { padding: 0 0 1.25rem; font-size: 0.85rem; color: var(--gray); line-height: 1.8; font-weight: 300; }

    /* Location */
    .location-grid { display: grid; grid-template-columns: 1fr; gap: 3rem; }
    @media (min-width: 768px) { .location-grid { grid-template-columns: 1fr 1fr; } }
    .hours-table { width: 100%; border-collapse: collapse; margin-top: 1.5rem; }
    .hours-table tr { border-bottom: 1px solid var(--mid); }
    .hours-table td { padding: 0.65rem 0; font-size: 0.85rem; color: var(--gray); font-weight: 300; }
    .hours-table td:first-child { color: var(--white); font-weight: 500; letter-spacing: 0.04em; }
    .hours-table .closed { color: var(--mid); }
    .contact-list { margin-top: 1.5rem; display: grid; gap: 1rem; }
    .contact-item { display: flex; gap: 1rem; font-size: 0.85rem; color: var(--gray); font-weight: 300; }
    .contact-item a { color: var(--white); text-decoration: none; }

    /* IG */
    .ig-section { background: var(--near-black); }
    .ig-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 3px; margin-top: 2rem; }
    @media (min-width: 640px) { .ig-grid { grid-template-columns: repeat(6, 1fr); } }
    .ig-post { aspect-ratio: 1; overflow: hidden; }
    .ig-post img { width: 100%; height: 100%; object-fit: cover; display: block; filter: grayscale(100%) contrast(1.1); transition: transform 0.4s, filter 0.3s; }
    .ig-post a:hover img { transform: scale(1.05); filter: grayscale(60%); }
    .ig-post a { display: block; height: 100%; }
    .ig-post a:focus-visible { outline: 2px solid var(--white); outline-offset: 2px; }
    .ig-follow { text-align: center; margin-top: 2rem; }
    .ig-follow a { color: var(--white); font-size: 0.68rem; letter-spacing: 0.22em; text-transform: uppercase; text-decoration: none; border: 1px solid var(--mid); padding: 0.8rem 2rem; display: inline-block; transition: border-color 0.2s; font-weight: 500; }
    .ig-follow a:hover, .ig-follow a:focus-visible { border-color: var(--white); }

    /* Footer */
    footer { background: var(--black); border-top: 1px solid var(--mid); padding: 3rem 1.5rem; text-align: center; }
    .footer-logo { font-family: 'Bebas Neue', sans-serif; font-size: 2rem; color: var(--white); letter-spacing: 0.15em; margin-bottom: 0.25rem; }
    .footer-tagline { font-size: 0.6rem; letter-spacing: 0.28em; text-transform: uppercase; color: var(--mid); margin-bottom: 1.5rem; font-weight: 500; }
    .footer-links { display: flex; gap: 1.5rem; justify-content: center; flex-wrap: wrap; margin-bottom: 1.5rem; list-style: none; }
    .footer-links a { color: var(--mid); font-size: 0.62rem; text-decoration: none; letter-spacing: 0.18em; text-transform: uppercase; font-weight: 500; transition: color 0.2s; }
    .footer-links a:hover { color: var(--white); }
    .footer-copy { font-size: 0.7rem; color: var(--mid); }
    @media (max-width: 480px) { .form-row { grid-template-columns: 1fr; } }
    .sr-only { position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0 }
  </style>
</head>
<body>

<nav class="nav" aria-label="Main navigation">
  <div class="nav-inner">
    <a href="/v4-black-grey-realism" class="nav-logo">Shadow Collective</a>
    <ul class="nav-links" role="list">
      <li><a href="#portfolio">Portfolio</a></li>
      <li><a href="#artists">Artists</a></li>
      <li><a href="#aftercare">Aftercare</a></li>
      <li><a href="#faq">FAQ</a></li>
      <li><a href="#location">Location</a></li>
      <li><a href="#booking" class="nav-cta">Book</a></li>
    </ul>
  </div>
</nav>

<section id="hero" aria-label="Hero — Shadow Collective">
  <div class="hero">
    <div class="hero-bg" role="img" aria-label={studio.heroAlt}></div>
    <div class="hero-content">
      <div class="hero-inner">
        <span class="hero-eyebrow">Black &amp; Grey Realism · San Diego, CA · Est. 2012</span>
        <h1>Shadow<em>Collective</em></h1>
        <p class="hero-tagline">{studio.tagline}<br/><br/>Every piece is a study in light, shadow, and photographic fidelity.</p>
        <div class="hero-actions">
          <a href="#booking" class="btn-primary">Book a Session</a>
          <a href="#portfolio" class="btn-ghost">View Portfolio</a>
        </div>
        <div class="hero-scroll" aria-label="Studio stats">
          <div class="hero-stat"><span class="val">3</span><span class="lbl">Realism Artists</span></div>
          <div class="hero-stat"><span class="val">${studio.minimumCharge}</span><span class="lbl">Minimum</span></div>
          <div class="hero-stat"><span class="val">${studio.hourlyRate}</span><span class="lbl">Per Hour</span></div>
          <div class="hero-stat"><span class="val">0</span><span class="lbl">Color Used</span></div>
        </div>
      </div>
    </div>
  </div>
</section>

<section id="artists" class="section artists-bg" aria-labelledby="artists-heading">
  <div class="section-inner">
    <span class="section-label">The Artists</span>
    <h2 class="section-title" id="artists-heading">Masters of Shadow</h2>
    <div class="white-rule" aria-hidden="true"></div>
    <div class="artist-grid" role="list">
      {studio.artists.map(artist => (
        <article class="artist-card" role="listitem" aria-label={`Artist: ${artist.name}`}>
          <img src={artist.image} alt={`Portrait of ${artist.name}`} class="artist-img" loading="lazy" width="400" height="320" />
          <div class="artist-info">
            <h3 class="artist-name">{artist.name}</h3>
            <p class="artist-specialty">{artist.specialty}</p>
            <p class="artist-bio">{artist.bio}</p>
            <p class="artist-handle">{artist.handle}</p>
            <div class="style-tags" aria-label={`Styles: ${artist.styles.join(', ')}`}>
              {artist.styles.map(s => <span class="style-tag">{s}</span>)}
            </div>
            <p class="years-badge">{artist.yearsExp} years</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<section id="portfolio" class="section gallery-bg" aria-labelledby="gallery-heading">
  <div class="section-inner">
    <span class="section-label">Portfolio</span>
    <h2 class="section-title" id="gallery-heading">The Work</h2>
    <div class="white-rule" aria-hidden="true"></div>
    <div class="masonry-grid" role="list" aria-label="Portfolio gallery">
      {studio.gallery.map(item => (
        <figure class="masonry-item" role="listitem">
          <img src={item.image} alt={item.alt} loading="lazy" width="600" height="500" />
          <div class="masonry-overlay" aria-hidden="true">
            <p class="masonry-cap">{item.artist} · {item.style}</p>
          </div>
          <figcaption class="sr-only">{item.alt} — by {item.artist}</figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<section id="aftercare" class="section aftercare-bg" aria-labelledby="aftercare-heading">
  <div class="section-inner">
    <span class="section-label">Aftercare</span>
    <h2 class="section-title" id="aftercare-heading">Protect the Investment</h2>
    <div class="white-rule" aria-hidden="true"></div>
    <div class="aftercare-grid" role="list">
      {studio.aftercare.map(step => (
        <div class="aftercare-card" role="listitem">
          <div class="aftercare-num" aria-hidden="true">0{step.step}</div>
          <h3 class="aftercare-title">{step.title}</h3>
          <p class="aftercare-body">{step.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<section id="booking" class="section booking-bg" aria-labelledby="booking-heading">
  <div class="section-inner">
    <div class="booking-grid">
      <div class="booking-info">
        <span class="section-label">Book a Session</span>
        <h2 class="section-title" id="booking-heading">Work With Us</h2>
        <div class="white-rule" aria-hidden="true"></div>
        <p>All sessions require a consultation. Submit your reference images and concept below and your artist will respond within 48–72 hours with a quote and availability.</p>
        <p>A ${studio.depositAmount} deposit secures your date and is applied to the final cost. Realism requires quality references—the better your reference, the better your tattoo.</p>
        <div class="booking-price-box">
          <p><strong>Minimum</strong> — ${studio.minimumCharge}</p>
          <p><strong>Hourly Rate</strong> — ${studio.hourlyRate}/hr</p>
          <p><strong>Booking Deposit</strong> — ${studio.depositAmount}</p>
          <p><strong>Walk-ins</strong> — Not accepted</p>
        </div>
      </div>
      <form class="booking-form" action="#" method="post" aria-label="Booking form" novalidate>
        <div>
          <label for="b-name">Name <span aria-label="required">*</span></label>
          <input type="text" id="b-name" name="name" placeholder="Your name" required autocomplete="name" />
        </div>
        <div class="form-row">
          <div>
            <label for="b-email">Email <span aria-label="required">*</span></label>
            <input type="email" id="b-email" name="email" placeholder="you@email.com" required autocomplete="email" />
          </div>
          <div>
            <label for="b-phone">Phone</label>
            <input type="tel" id="b-phone" name="phone" placeholder="Optional" autocomplete="tel" />
          </div>
        </div>
        <div>
          <label for="b-artist">Artist</label>
          <select id="b-artist" name="artist">
            <option value="">No preference</option>
            {studio.artists.map(a => <option value={a.name}>{a.name}</option>)}
          </select>
        </div>
        <div class="form-row">
          <div>
            <label for="b-size">Size</label>
            <select id="b-size" name="size">
              <option value="">—</option>
              <option value="sm">Small (under hand)</option>
              <option value="md">Medium (hand-sized)</option>
              <option value="lg">Large (half sleeve)</option>
              <option value="xl">Full sleeve / back</option>
            </select>
          </div>
          <div>
            <label for="b-placement">Placement</label>
            <input type="text" id="b-placement" name="placement" placeholder="e.g. upper arm" />
          </div>
        </div>
        <div>
          <label for="b-desc">Describe Your Concept <span aria-label="required">*</span></label>
          <textarea id="b-desc" name="description" placeholder="Subject, mood, reference images you can link or describe, existing tattoos nearby..." rows="4" required></textarea>
        </div>
        <div>
          <label for="b-dates">Availability</label>
          <input type="text" id="b-dates" name="dates" placeholder="e.g. Any Saturday, Fall 2024" />
        </div>
        <button type="submit" class="btn-submit">Request Session + ${studio.depositAmount} Deposit</button>
      </form>
    </div>
  </div>
</section>

<section id="faq" class="section faq-bg" aria-labelledby="faq-heading">
  <div class="section-inner" style="max-width:760px;">
    <span class="section-label">FAQ</span>
    <h2 class="section-title" id="faq-heading">Common Questions</h2>
    <div class="white-rule" aria-hidden="true"></div>
    <div class="faq-list">
      {studio.faqs.map(faq => (
        <details>
          <summary>{faq.question}</summary>
          <div class="faq-answer"><p>{faq.answer}</p></div>
        </details>
      ))}
    </div>
  </div>
</section>

<section id="location" class="section" aria-labelledby="location-heading">
  <div class="section-inner">
    <div class="location-grid">
      <div>
        <span class="section-label">Find Us</span>
        <h2 class="section-title" id="location-heading">Location</h2>
        <div class="white-rule" aria-hidden="true"></div>
        <div class="contact-list">
          <div class="contact-item"><span aria-hidden="true">—</span><div><p>{studio.address}</p><p>{studio.city}</p><a href={studio.mapUrl} target="_blank" rel="noopener noreferrer" style="font-size:0.7rem; letter-spacing:0.15em; text-transform:uppercase; margin-top:0.3rem; display:inline-block; font-weight:500;">Directions</a></div></div>
          <div class="contact-item"><span aria-hidden="true">—</span><a href={`tel:${studio.phone}`}>{studio.phone}</a></div>
          <div class="contact-item"><span aria-hidden="true">—</span><a href={`mailto:${studio.email}`}>{studio.email}</a></div>
          <div class="contact-item"><span aria-hidden="true">—</span><a href={`https://instagram.com/${studio.instagram.replace('@','')}`} target="_blank" rel="noopener noreferrer">{studio.instagram}</a></div>
        </div>
      </div>
      <div>
        <span class="section-label" style="display:block; margin-bottom:0.5rem;">Hours</span>
        <table class="hours-table" aria-label="Studio hours">
          <tbody>
            {studio.hours.map(h => (
              <tr>
                <td>{h.day}</td>
                <td class={h.open === 'Closed' ? 'closed' : ''}>{h.open === 'Closed' ? 'Closed' : `${h.open} – ${h.close}`}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>

<section id="instagram" class="section ig-section" aria-labelledby="ig-heading">
  <div class="section-inner">
    <span class="section-label">Instagram</span>
    <h2 class="section-title" id="ig-heading">{studio.instagram}</h2>
    <div class="white-rule" aria-hidden="true"></div>
    <div class="ig-grid" role="list" aria-label="Instagram posts">
      {studio.igPosts.map(post => (
        <div class="ig-post" role="listitem">
          <a href={post.link} aria-label={`Instagram: ${post.alt}`} target="_blank" rel="noopener noreferrer">
            <img src={post.image} alt={post.alt} loading="lazy" width="300" height="300" />
          </a>
        </div>
      ))}
    </div>
    <div class="ig-follow">
      <a href={`https://instagram.com/${studio.instagram.replace('@','')}`} target="_blank" rel="noopener noreferrer">Follow on Instagram</a>
    </div>
  </div>
</section>

<footer>
  <p class="footer-logo">Shadow Collective</p>
  <p class="footer-tagline">Hyperrealism · No Color · No Compromise</p>
  <nav aria-label="Footer navigation">
    <ul class="footer-links" role="list">
      <li><a href="#portfolio">Portfolio</a></li>
      <li><a href="#artists">Artists</a></li>
      <li><a href="#booking">Book</a></li>
      <li><a href="#faq">FAQ</a></li>
      <li><a href="#location">Location</a></li>
    </ul>
  </nav>
  <p class="footer-copy">&copy; 2024 Shadow Collective · {studio.address}, {studio.city}</p>
</footer>
</body>
</html>

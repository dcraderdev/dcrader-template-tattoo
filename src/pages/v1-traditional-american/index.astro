---
import { Picture, getImage } from 'astro:assets';
import { studio } from '../../data/v1';
import { resolveImage } from '../../data/imageMap';
import '../../styles/global.css';
const romanFAQ = ['I','II','III','IV','V','VI'];
const heroImg = resolveImage(studio.heroImage);
const heroWidths = [768, 1280, 1920];
const heroSrcset = (await Promise.all(
  heroWidths.map(async (w) => {
    const img = await getImage({ src: heroImg, width: w, format: 'webp' });
    return `${img.src} ${w}w`;
  })
)).join(', ');
const heroPreload = await getImage({ src: heroImg, width: 1920, format: 'webp' });
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title>{studio.name} — Traditional American Tattoo · {studio.city}</title>
  <meta name="description" content={studio.description}/>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Teko:wght@400;500;600;700&family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&display=swap" rel="stylesheet"/>
  <link rel="preload" as="image" fetchpriority="high" type="image/webp" href={heroPreload.src} imagesrcset={heroSrcset} imagesizes="100vw"/>
  <style>
    :root{--red:#7A0000;--red2:#A00000;--cream:#FFF5DC;--cream2:#F5E6C0;--gold:#C8860A;--gold2:#E8A020;--dark:#160500;--ink:#2A1200;}
    *{box-sizing:border-box;margin:0;padding:0;}
    html{scroll-behavior:smooth;}
    body{background:var(--cream);color:var(--ink);font-family:'EB Garamond',Georgia,serif;}

    /* ── NAV ── */
    nav{background:var(--dark);border-bottom:4px solid var(--gold);position:sticky;top:0;z-index:100;}
    .nav-inner{max-width:1200px;margin:0 auto;display:grid;grid-template-columns:1fr auto 1fr;align-items:center;padding:0 1.5rem;min-height:64px;}
    .nav-links-left,.nav-links-right{display:flex;gap:0;list-style:none;}
    .nav-links-right{justify-content:flex-end;}
    nav a{color:rgba(255,245,220,0.7);text-decoration:none;font-family:'Teko',sans-serif;font-size:1rem;letter-spacing:0.12em;text-transform:uppercase;padding:0.5rem 0.9rem;display:block;transition:color 0.2s;}
    nav a:hover,nav a:focus-visible{color:var(--gold);}
    .nav-logo-block{text-align:center;text-decoration:none;display:block;}
    .nav-logo-main{font-family:'Teko',sans-serif;font-size:1.6rem;font-weight:700;letter-spacing:0.08em;color:var(--cream);line-height:1;text-transform:uppercase;}
    .nav-logo-sub{font-family:'EB Garamond',serif;font-size:0.65rem;letter-spacing:0.35em;color:var(--gold);text-transform:uppercase;}
    .nav-book{background:var(--red)!important;color:var(--cream)!important;font-weight:600;}
    .nav-book:hover{background:var(--red2)!important;color:var(--cream)!important;}

    /* ── HERO ── */
    .hero{position:relative;min-height:94vh;display:flex;align-items:center;overflow:hidden;background:var(--dark);}
    .hero-img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;filter:sepia(40%) contrast(1.1) brightness(0.55);}
    .hero-grid-overlay{position:absolute;inset:0;background-image:repeating-linear-gradient(0deg,transparent,transparent 59px,rgba(200,134,10,0.07) 60px),repeating-linear-gradient(90deg,transparent,transparent 59px,rgba(200,134,10,0.07) 60px);}
    .hero-content{position:relative;width:100%;max-width:1200px;margin:0 auto;padding:3rem 1.5rem;display:grid;grid-template-columns:1fr 420px;gap:3rem;align-items:center;}
    @media(max-width:900px){.hero-content{grid-template-columns:1fr;}}
    .hero-left{}
    .hero-est{font-family:'EB Garamond',serif;font-size:0.75rem;letter-spacing:0.35em;text-transform:uppercase;color:var(--gold);margin-bottom:1rem;display:flex;align-items:center;gap:0.75rem;}
    .hero-est::before,.hero-est::after{content:'';flex:0 0 30px;height:1px;background:var(--gold);}
    .hero-h1{font-family:'Teko',sans-serif;font-size:clamp(4rem,9vw,8rem);font-weight:700;color:var(--cream);line-height:0.92;letter-spacing:0.02em;text-transform:uppercase;text-shadow:3px 3px 0 var(--red);}
    .hero-amp{color:var(--gold);}
    .hero-tagline{font-family:'EB Garamond',serif;font-style:italic;font-size:clamp(1rem,2vw,1.35rem);color:var(--cream2);max-width:480px;line-height:1.6;margin:1.5rem 0 2.5rem;}
    .hero-ctas{display:flex;gap:1rem;flex-wrap:wrap;}
    .btn-red{background:var(--red);color:var(--cream);font-family:'Teko',sans-serif;font-size:1.05rem;font-weight:600;letter-spacing:0.15em;text-transform:uppercase;text-decoration:none;padding:0.7rem 2rem;border:2px solid var(--red);transition:all 0.2s;}
    .btn-red:hover,.btn-red:focus-visible{background:var(--red2);border-color:var(--red2);}
    .btn-cream{background:transparent;color:var(--cream);font-family:'Teko',sans-serif;font-size:1.05rem;font-weight:600;letter-spacing:0.15em;text-transform:uppercase;text-decoration:none;padding:0.7rem 2rem;border:2px solid rgba(255,245,220,0.5);transition:all 0.2s;}
    .btn-cream:hover,.btn-cream:focus-visible{border-color:var(--cream);}
    .hero-panel{background:rgba(22,5,0,0.85);border:2px solid var(--gold);padding:2rem;backdrop-filter:blur(4px);}
    .hero-panel-title{font-family:'Teko',sans-serif;font-size:1.1rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--gold);margin-bottom:1.25rem;text-align:center;}
    /* ── DIVIDERS ── */
    .divider{display:flex;align-items:center;justify-content:center;gap:1.25rem;padding:1.5rem 0;color:var(--gold);}
    .divider-line{flex:1;height:1px;background:var(--gold);opacity:0.3;max-width:200px;}
    .divider svg{flex-shrink:0;}

    /* ── SECTIONS ── */
    .section{padding:5rem 1.5rem;}
    .section-inner{max-width:1200px;margin:0 auto;}
    .eyebrow{font-family:'EB Garamond',serif;font-size:0.72rem;letter-spacing:0.3em;text-transform:uppercase;color:var(--red);margin-bottom:0.5rem;display:block;}
    .section-h{font-family:'Teko',sans-serif;font-size:clamp(2.5rem,5vw,4.5rem);font-weight:700;color:var(--dark);line-height:0.95;text-transform:uppercase;}
    .gold-bar{width:60px;height:4px;background:var(--gold);margin:1rem 0 2.5rem;}

    /* ── ARTISTS ── */
    .artists-bg{background:var(--dark);}
    .artists-bg .section-h,.artists-bg .eyebrow ~ .section-h{color:var(--cream);}
    .artists-bg .eyebrow{color:var(--gold2);}
    .artist-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:0;border:2px solid var(--gold);}
    @media(max-width:700px){.artist-grid{grid-template-columns:1fr;}}
    .artist-card{border-right:1px solid rgba(200,134,10,0.3);overflow:hidden;}
    .artist-card:last-child{border-right:none;}
    .artist-photo-wrap{position:relative;height:340px;overflow:hidden;}
    .artist-photo{width:100%;height:100%;object-fit:cover;object-position:top;filter:sepia(25%) contrast(1.1);transition:transform 0.5s,filter 0.4s;}
    .artist-card:hover .artist-photo{transform:scale(1.04);filter:sepia(5%) contrast(1.1);}
    .artist-photo-overlay{position:absolute;bottom:0;left:0;right:0;background:linear-gradient(to top,rgba(22,5,0,0.95) 0%,transparent 60%);}
    .artist-name-over{position:absolute;bottom:1rem;left:1.25rem;right:1.25rem;}
    .artist-name-over h3{font-family:'Teko',sans-serif;font-size:1.6rem;font-weight:700;color:var(--cream);letter-spacing:0.05em;text-transform:uppercase;line-height:1;}
    .artist-name-over p{font-family:'EB Garamond',serif;font-style:italic;font-size:0.85rem;color:var(--gold);}
    .artist-body{padding:1.25rem;}
    .artist-bio{font-size:0.9rem;color:#b89060;line-height:1.7;margin-bottom:0.75rem;}
    .artist-handle{font-size:0.75rem;color:var(--gold);opacity:0.7;}
    .artist-tags{display:flex;gap:0.4rem;flex-wrap:wrap;margin-top:0.75rem;}
    .tag{background:rgba(200,134,10,0.12);color:var(--gold);border:1px solid rgba(200,134,10,0.25);font-family:'Teko',sans-serif;font-size:0.75rem;letter-spacing:0.1em;text-transform:uppercase;padding:0.15rem 0.5rem;}
    .years{display:inline-block;background:var(--red);color:var(--cream);font-family:'Teko',sans-serif;font-size:0.8rem;letter-spacing:0.1em;text-transform:uppercase;padding:0.15rem 0.55rem;margin-top:0.5rem;}

    /* ── FLASH SHEET GALLERY ── */
    .gallery-bg{background:var(--cream2);}
    .flash-sheet{display:grid;grid-template-columns:repeat(4,1fr);gap:4px;border:4px solid var(--dark);}
    @media(max-width:640px){.flash-sheet{grid-template-columns:repeat(2,1fr);}}
    .flash-cell{position:relative;aspect-ratio:1;overflow:hidden;background:var(--dark);}
    .flash-cell img{width:100%;height:100%;object-fit:cover;display:block;filter:sepia(15%) contrast(1.1);transition:transform 0.4s,filter 0.3s;}
    .flash-cell:hover img{transform:scale(1.06);filter:sepia(0%) contrast(1.15);}
    .flash-label{position:absolute;bottom:0;left:0;right:0;background:linear-gradient(to top,rgba(22,5,0,0.9) 0%,transparent 100%);padding:0.6rem 0.5rem 0.4rem;text-align:center;}
    .flash-label span{font-family:'EB Garamond',serif;font-style:italic;font-size:0.75rem;color:var(--gold);}
    .flash-note{text-align:center;margin-top:1.25rem;font-family:'EB Garamond',serif;font-style:italic;font-size:0.9rem;color:#7a5020;}

    /* ── AFTERCARE ── */
    .aftercare-list{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:0;border:1px solid rgba(122,0,0,0.2);}
    .aftercare-item{padding:2rem 1.75rem;border-right:1px solid rgba(122,0,0,0.15);border-bottom:1px solid rgba(122,0,0,0.15);position:relative;}
    .ac-num{font-family:'Teko',sans-serif;font-size:4.5rem;font-weight:700;color:rgba(122,0,0,0.08);line-height:1;position:absolute;top:1rem;right:1.25rem;}
    .ac-title{font-family:'Teko',sans-serif;font-size:1.3rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:var(--dark);margin-bottom:0.5rem;}
    .ac-body{font-size:0.88rem;color:#6A4020;line-height:1.7;}

    /* ── BOOKING ── */
    .booking-bg{background:var(--red);}
    .booking-bg .section-h{color:var(--cream);}
    .booking-bg .eyebrow{color:var(--gold2);}
    .booking-bg .gold-bar{background:var(--cream);}
    .booking-grid{display:grid;grid-template-columns:1fr 1fr;gap:4rem;}
    @media(max-width:768px){.booking-grid{grid-template-columns:1fr;}}
    .booking-copy{color:var(--cream2);}
    .booking-copy p{line-height:1.75;margin-bottom:1rem;font-size:0.95rem;}
    .price-table{border:1px solid rgba(200,134,10,0.35);margin-top:1.5rem;}
    .price-row{display:flex;justify-content:space-between;padding:0.6rem 1rem;border-bottom:1px solid rgba(200,134,10,0.2);font-size:0.88rem;color:#d4b090;}
    .price-row:last-child{border-bottom:none;}
    .price-row strong{color:var(--gold2);}
    .booking-form{display:grid;gap:1.1rem;}
    .f-label{display:block;font-family:'Teko',sans-serif;font-size:0.85rem;letter-spacing:0.15em;text-transform:uppercase;color:var(--gold2);margin-bottom:0.3rem;}
    .f-input{width:100%;background:rgba(255,255,255,0.06);border:1px solid rgba(200,134,10,0.3);color:var(--cream);padding:0.65rem 0.9rem;font-family:'EB Garamond',serif;font-size:0.95rem;outline:none;transition:border-color 0.2s;}
    .f-input:focus{border-color:var(--gold2);}
    .f-input::placeholder{color:rgba(255,245,220,0.3);}
    .f-input option{background:var(--dark);}
    .f-row{display:grid;grid-template-columns:1fr 1fr;gap:1rem;}
    .f-submit{background:var(--gold);color:var(--dark);font-family:'Teko',sans-serif;font-size:1.1rem;font-weight:700;letter-spacing:0.2em;text-transform:uppercase;border:none;cursor:pointer;padding:0.85rem 2rem;width:100%;transition:background 0.2s;margin-top:0.5rem;}
    .f-submit:hover,.f-submit:focus-visible{background:var(--gold2);}

    /* ── FAQ ── */
    .faq-outer{border:1px solid rgba(122,0,0,0.2);}
    details{border-bottom:1px solid rgba(122,0,0,0.15);}
    details:last-child{border-bottom:none;}
    summary{padding:1.25rem 1.5rem;cursor:pointer;display:flex;justify-content:space-between;align-items:center;gap:1rem;list-style:none;font-family:'Teko',sans-serif;font-size:1.2rem;font-weight:600;letter-spacing:0.06em;text-transform:uppercase;color:var(--dark);}
    summary::-webkit-details-marker{display:none;}
    summary::after{content:'✦';color:var(--red);font-size:0.9rem;flex-shrink:0;transition:transform 0.3s;}
    details[open] summary::after{transform:rotate(45deg);}
    summary:hover{background:rgba(122,0,0,0.03);}
    .faq-ans{padding:0 1.5rem 1.25rem;font-size:0.92rem;color:#6A4020;line-height:1.75;}

    /* ── LOCATION ── */
    .location-bg{background:var(--dark);}
    .location-bg .section-h{color:var(--cream);}
    .location-bg .eyebrow{color:var(--gold);}
    .location-grid{display:grid;grid-template-columns:1fr 1fr;gap:3rem;}
    @media(max-width:700px){.location-grid{grid-template-columns:1fr;}}
    .hours-tbl{width:100%;border-collapse:collapse;margin-top:1.5rem;}
    .hours-tbl tr{border-bottom:1px solid rgba(200,134,10,0.15);}
    .hours-tbl td{padding:0.6rem 0;font-size:0.9rem;color:#b89060;}
    .hours-tbl td:first-child{color:var(--cream);font-family:'Teko',sans-serif;font-size:1rem;letter-spacing:0.06em;text-transform:uppercase;}
    .hours-tbl .closed{color:#4a3020;font-style:italic;}
    .contact-stack{margin-top:1.5rem;display:grid;gap:0.9rem;}
    .contact-row{display:flex;gap:0.75rem;font-size:0.9rem;color:#b89060;}
    .c-icon{color:var(--gold);flex-shrink:0;width:1.2rem;}
    .contact-row a{color:var(--gold);text-decoration:none;}

    /* ── ACCOLADES (awards/conventions ribbon) ── */
    .accolades-bg{background:var(--dark);border-top:4px solid var(--gold);border-bottom:4px solid var(--gold);position:relative;}
    .accolades-bg::before,.accolades-bg::after{content:'';position:absolute;left:0;right:0;height:6px;background:repeating-linear-gradient(45deg,var(--gold) 0 8px,var(--dark) 8px 16px);}
    .accolades-bg::before{top:4px;}
    .accolades-bg::after{bottom:4px;}
    .accolades-inner{max-width:1200px;margin:0 auto;padding:5rem 1.5rem 4rem;}
    .accolades-head{text-align:center;margin-bottom:3rem;}
    .accolades-eyebrow{font-family:'EB Garamond',serif;font-size:0.75rem;letter-spacing:0.35em;text-transform:uppercase;color:var(--gold);display:flex;align-items:center;justify-content:center;gap:0.75rem;margin-bottom:0.75rem;}
    .accolades-eyebrow::before,.accolades-eyebrow::after{content:'';flex:0 0 40px;height:1px;background:var(--gold);opacity:0.6;}
    .accolades-h{font-family:'Teko',sans-serif;font-size:clamp(2.5rem,5vw,4.5rem);font-weight:700;color:var(--cream);text-transform:uppercase;letter-spacing:0.02em;text-shadow:3px 3px 0 var(--red);line-height:0.95;}
    .accolades-sub{font-family:'EB Garamond',serif;font-style:italic;font-size:0.95rem;color:#b89060;margin-top:0.75rem;max-width:540px;margin-left:auto;margin-right:auto;line-height:1.6;}
    .accolades-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:1.5rem;}
    @media(max-width:760px){.accolades-grid{grid-template-columns:1fr;}}
    .accolade{display:grid;grid-template-columns:80px 1fr auto;gap:1.25rem;align-items:center;border:2px solid var(--gold);background:rgba(200,134,10,0.05);padding:1.25rem 1.5rem;position:relative;}
    .accolade::before{content:'';position:absolute;inset:4px;border:1px solid rgba(200,134,10,0.25);pointer-events:none;}
    .acc-medal{width:64px;height:64px;border-radius:50%;background:radial-gradient(circle at 30% 30%,var(--gold2),var(--gold) 55%,#5a3a04 100%);display:flex;align-items:center;justify-content:center;font-family:'Teko',sans-serif;font-size:1.1rem;font-weight:700;color:var(--dark);letter-spacing:0.05em;text-align:center;line-height:1;box-shadow:inset 0 0 0 3px rgba(22,5,0,0.55),0 0 0 2px var(--dark);position:relative;}
    .acc-medal::after{content:'';position:absolute;left:50%;top:100%;transform:translateX(-50%);border-left:8px solid transparent;border-right:8px solid transparent;border-top:14px solid var(--red);}
    .acc-body h3{font-family:'Teko',sans-serif;font-size:1.35rem;font-weight:600;color:var(--cream);letter-spacing:0.06em;text-transform:uppercase;line-height:1.1;}
    .acc-body p{font-family:'EB Garamond',serif;font-style:italic;font-size:0.85rem;color:#b89060;line-height:1.55;margin-top:0.2rem;}
    .acc-year{font-family:'Teko',sans-serif;font-size:1.8rem;font-weight:700;color:var(--gold);letter-spacing:0.04em;}

    /* ── INSTAGRAM ── */
    .ig-grid{display:grid;grid-template-columns:repeat(6,1fr);gap:3px;margin-top:2rem;border:3px solid var(--gold);}
    @media(max-width:640px){.ig-grid{grid-template-columns:repeat(3,1fr);}}
    .ig-cell{aspect-ratio:1;overflow:hidden;}
    .ig-cell img{width:100%;height:100%;object-fit:cover;display:block;filter:sepia(20%);transition:filter 0.3s,transform 0.4s;}
    .ig-cell a:hover img,.ig-cell a:focus-visible img{filter:sepia(0%);transform:scale(1.05);}
    .ig-cell a{display:block;height:100%;}
    .ig-cell a:focus-visible{outline:2px solid var(--gold);outline-offset:2px;}
    .ig-follow{text-align:center;margin-top:1.75rem;}
    .ig-follow a{font-family:'Teko',sans-serif;font-size:1rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--dark);text-decoration:none;border:2px solid var(--dark);padding:0.65rem 2rem;display:inline-block;transition:all 0.2s;}
    .ig-follow a:hover,.ig-follow a:focus-visible{background:var(--dark);color:var(--cream);}

    /* ── FOOTER ── */
    footer{background:#0D0300;border-top:4px solid var(--gold);padding:3rem 1.5rem;text-align:center;}
    .footer-logo{font-family:'Teko',sans-serif;font-size:2.5rem;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;color:var(--cream);}
    .footer-logo span{color:var(--gold);}
    .footer-est{font-family:'EB Garamond',serif;font-style:italic;font-size:0.85rem;letter-spacing:0.2em;color:#5a3010;margin:0.5rem 0 1.25rem;}
    .footer-nav{display:flex;justify-content:center;gap:0;list-style:none;flex-wrap:wrap;margin-bottom:1.25rem;}
    .footer-nav a{font-family:'Teko',sans-serif;font-size:0.95rem;letter-spacing:0.15em;text-transform:uppercase;color:#5a3010;text-decoration:none;padding:0.3rem 0.9rem;transition:color 0.2s;}
    .footer-nav a:hover{color:var(--gold);}
    .footer-copy{font-size:0.72rem;color:#2a1000;font-family:'EB Garamond',serif;}
    .sr-only{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0}
    @media(max-width:480px){.f-row{grid-template-columns:1fr;}}
  </style>
  <script src="/template-topheader.js" defer></script>
</head>
<body>

<nav aria-label="Main navigation">
  <div class="nav-inner">
    <ul class="nav-links-left" role="list">
      <li><a href="#portfolio">Portfolio</a></li>
      <li><a href="#artists">Artists</a></li>
      <li><a href="#aftercare">Aftercare</a></li>
    </ul>
    <a href="/dcrader-template-tattoo/v1-traditional-american" class="nav-logo-block" aria-label="{studio.name} home">
      <div class="nav-logo-main">Iron <span style="color:var(--gold);">&</span> Rose</div>
      <div class="nav-logo-sub">San Diego · Est. 2004</div>
    </a>
    <ul class="nav-links-right" role="list">
      <li><a href="#faq">FAQ</a></li>
      <li><a href="#location">Location</a></li>
      <li><a href="#booking" class="nav-book">Book Now</a></li>
    </ul>
  </div>
</nav>

<!-- HERO -->
<section id="hero" aria-label="Hero">
  <div class="hero">
    <Picture formats={['avif','webp']} class="hero-img" src={heroImg} alt={studio.heroAlt} loading="eager" fetchpriority="high" widths={[768, 1280, 1920]} sizes="100vw" width={1920} height={1280} />
    <div class="hero-grid-overlay" aria-hidden="true"></div>
    <div class="hero-content">
      <div class="hero-left">
        <p class="hero-est" aria-label="Established">Est. 2004 · American Traditional · San Diego</p>
        <h1 class="hero-h1">Iron<br/><span class="hero-amp">&amp;</span><br/>Rose</h1>
        <p class="hero-tagline">Since before your grandfather got his first tattoo. Bold outlines, saturated primaries, flash that outlasts a lifetime.</p>
        <div class="hero-ctas">
          <a href="#booking" class="btn-red">Book a Session</a>
          <a href="#portfolio" class="btn-cream">View Flash</a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- DIVIDER -->
<div class="divider" aria-hidden="true">
  <div class="divider-line"></div>
  <svg viewBox="0 0 80 22" fill="var(--gold)" width="80" height="22" role="img" aria-label="Decorative swallow">
    <path d="M40,11 C32,4 16,1 2,5 C9,8 17,9 21,11 C17,14 9,15 2,18 C16,22 32,18 40,11Z"/>
    <path d="M40,11 C48,4 64,1 78,5 C71,8 63,9 59,11 C63,14 71,15 78,18 C64,22 48,18 40,11Z"/>
    <ellipse cx="40" cy="11" rx="4" ry="5.5"/>
  </svg>
  <svg viewBox="0 0 28 36" fill="none" stroke="var(--gold)" stroke-width="1.8" stroke-linecap="round" width="28" height="36" role="img" aria-label="Decorative anchor">
    <circle cx="14" cy="5.5" r="3.5"/>
    <line x1="14" y1="9" x2="14" y2="31"/>
    <line x1="5" y1="15" x2="23" y2="15"/>
    <path d="M7,27 Q7,31 14,31 Q21,31 21,27"/>
  </svg>
  <svg viewBox="0 0 80 22" fill="var(--gold)" width="80" height="22" role="img" aria-label="Decorative swallow">
    <path d="M40,11 C32,4 16,1 2,5 C9,8 17,9 21,11 C17,14 9,15 2,18 C16,22 32,18 40,11Z"/>
    <path d="M40,11 C48,4 64,1 78,5 C71,8 63,9 59,11 C63,14 71,15 78,18 C64,22 48,18 40,11Z"/>
    <ellipse cx="40" cy="11" rx="4" ry="5.5"/>
  </svg>
  <div class="divider-line"></div>
</div>

<!-- ARTISTS -->
<section id="artists" class="section artists-bg" aria-labelledby="artists-h">
  <div class="section-inner">
    <span class="eyebrow">The Artists</span>
    <h2 class="section-h" id="artists-h">The Hands<br/>Behind the Work</h2>
    <div class="gold-bar" aria-hidden="true"></div>
    <div class="artist-grid" role="list">
      {studio.artists.map(a => (
        <article class="artist-card" role="listitem" aria-label={`Artist: ${a.name}`}>
          <div class="artist-photo-wrap">
            <Picture formats={['avif','webp']} class="artist-photo" src={resolveImage(a.image)} alt={`Portrait of ${a.name}, ${a.specialty}`} loading="lazy" decoding="async" widths={[300, 600]} sizes="(min-width: 768px) 33vw, 100vw" width={600} height={510} />

            <div class="artist-photo-overlay" aria-hidden="true"></div>
            <div class="artist-name-over">
              <h3>{a.name}</h3>
              <p>{a.specialty}</p>
            </div>
          </div>
          <div class="artist-body">
            <p class="artist-bio">{a.bio}</p>
            <p class="artist-handle">{a.handle}</p>
            <div class="artist-tags" aria-label={`Styles: ${a.styles.join(', ')}`}>
              {a.styles.map(s => <span class="tag">{s}</span>)}
            </div>
            <p class="years">{a.yearsExp} Yrs</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- FLASH SHEET GALLERY -->
<section id="portfolio" class="section gallery-bg" aria-labelledby="gallery-h">
  <div class="section-inner">
    <span class="eyebrow">The Flash</span>
    <h2 class="section-h" id="gallery-h">Portfolio &amp; Flash Sheet</h2>
    <div class="gold-bar" aria-hidden="true"></div>
    <div class="flash-sheet" role="list" aria-label="Tattoo flash sheet gallery">
      {studio.gallery.map(item => (
        <figure class="flash-cell" role="listitem">
          <Picture formats={['avif','webp']} src={resolveImage(item.image)} alt={item.alt} loading="lazy" decoding="async" widths={[400, 600]} sizes="(min-width: 1024px) 25vw, 50vw" width={600} height={600} />
          <div class="flash-label" aria-hidden="true"><span>{item.style}</span></div>
          <figcaption class="sr-only">{item.alt} — by {item.artist}</figcaption>
        </figure>
      ))}
    </div>
    <p class="flash-note" aria-label="Flash availability note">All flash available for walk-in sessions. Custom designs by appointment.</p>
  </div>
</section>

<!-- DIVIDER -->
<div class="divider" aria-hidden="true">
  <div class="divider-line"></div>
  <svg viewBox="0 0 20 24" fill="var(--gold)" width="20" height="24"><polygon points="10,1 12.5,7.5 19.5,8.5 14.5,13.5 16,20.5 10,17 4,20.5 5.5,13.5 0.5,8.5 7.5,7.5"/></svg>
  <svg viewBox="0 0 20 24" fill="var(--red)" width="20" height="24"><polygon points="10,1 12.5,7.5 19.5,8.5 14.5,13.5 16,20.5 10,17 4,20.5 5.5,13.5 0.5,8.5 7.5,7.5"/></svg>
  <svg viewBox="0 0 20 24" fill="var(--gold)" width="20" height="24"><polygon points="10,1 12.5,7.5 19.5,8.5 14.5,13.5 16,20.5 10,17 4,20.5 5.5,13.5 0.5,8.5 7.5,7.5"/></svg>
  <div class="divider-line"></div>
</div>

<!-- ACCOLADES — awards / conventions ribbon -->
<section id="accolades" class="accolades-bg" aria-labelledby="accolades-h">
  <div class="accolades-inner">
    <div class="accolades-head">
      <p class="accolades-eyebrow">Honors &amp; Conventions</p>
      <h2 class="accolades-h" id="accolades-h">Earned, Not Bought</h2>
      <p class="accolades-sub">Two decades of conventions, magazine spreads, and judged competitions. We don't chase trophies — but we don't leave them on the table either.</p>
    </div>
    <div class="accolades-grid" role="list" aria-label="Awards and convention honors">
      <div class="accolade" role="listitem">
        <div class="acc-medal" aria-hidden="true">BEST<br/>TRAD</div>
        <div class="acc-body">
          <h3>Best Traditional · Star of Texas</h3>
          <p>Awarded to Rex "Ironhand" Valdez — large color panther, day three.</p>
        </div>
        <div class="acc-year">'23</div>
      </div>
      <div class="accolade" role="listitem">
        <div class="acc-medal" aria-hidden="true">2ND<br/>OF<br/>DAY</div>
        <div class="acc-body">
          <h3>2nd of Day · Golden State Tattoo Expo</h3>
          <p>Dee Marsh's rose-and-dagger sleeve, Pasadena Convention Center.</p>
        </div>
        <div class="acc-year">'22</div>
      </div>
      <div class="accolade" role="listitem">
        <div class="acc-medal" aria-hidden="true">FEAT<br/>URED</div>
        <div class="acc-body">
          <h3>Featured Studio · Inked Magazine</h3>
          <p>Six-page spread on the Sailor Jerry revival in Southern California.</p>
        </div>
        <div class="acc-year">'21</div>
      </div>
      <div class="accolade" role="listitem">
        <div class="acc-medal" aria-hidden="true">BEST<br/>NAUT</div>
        <div class="acc-body">
          <h3>Best Nautical · San Diego Tattoo Convention</h3>
          <p>Sailor M's full-back clipper ship, judged out of 84 entries.</p>
        </div>
        <div class="acc-year">'19</div>
      </div>
      <div class="accolade" role="listitem">
        <div class="acc-medal" aria-hidden="true">JUDGE</div>
        <div class="acc-body">
          <h3>Head Judge · West Coast Traditional</h3>
          <p>Rex invited to chair the traditional category panel three years running.</p>
        </div>
        <div class="acc-year">'18</div>
      </div>
      <div class="accolade" role="listitem">
        <div class="acc-medal" aria-hidden="true">TATT<br/>OODO</div>
        <div class="acc-body">
          <h3>Top 100 American Traditional · Tattoodo</h3>
          <p>Shop-wide listing, voted across editor and reader categories.</p>
        </div>
        <div class="acc-year">'17</div>
      </div>
    </div>
  </div>
</section>

<!-- AFTERCARE -->
<section id="aftercare" class="section" aria-labelledby="aftercare-h">
  <div class="section-inner">
    <span class="eyebrow">Tattoo Aftercare</span>
    <h2 class="section-h" id="aftercare-h">Protect Your Investment</h2>
    <div class="gold-bar" aria-hidden="true"></div>
    <div class="aftercare-list" role="list">
      {studio.aftercare.map(step => (
        <div class="aftercare-item" role="listitem">
          <div class="ac-num" aria-hidden="true">0{step.step}</div>
          <h3 class="ac-title">{step.title}</h3>
          <p class="ac-body">{step.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- BOOKING -->
<section id="booking" class="section booking-bg" aria-labelledby="booking-h">
  <div class="section-inner">
    <div class="booking-grid">
      <div class="booking-copy">
        <span class="eyebrow">Book a Session</span>
        <h2 class="section-h" id="booking-h">Let's Make Something That Lasts</h2>
        <div class="gold-bar" style="background:var(--cream);margin-top:1rem;" aria-hidden="true"></div>
        <p>Fill out the form. We'll confirm within 48 hours. Walk-ins welcome Tue–Sun — call ahead to check availability.</p>
        <p>A ${studio.depositAmount} non-refundable deposit secures your spot and goes toward your final cost. No deposit, no appointment.</p>
        <div class="price-table">
          <div class="price-row"><span>Shop Minimum</span><strong>${studio.minimumCharge}</strong></div>
          <div class="price-row"><span>Hourly Rate</span><strong>${studio.hourlyRate}/hr</strong></div>
          <div class="price-row"><span>Booking Deposit</span><strong>${studio.depositAmount}</strong></div>
          <div class="price-row"><span>Walk-ins</span><strong>Tue–Sun</strong></div>
        </div>
      </div>
      <form class="booking-form" action="#" method="post" aria-label="Booking form" novalidate>
        <div><label class="f-label" for="b-name">Full Name *</label><input class="f-input" type="text" id="b-name" name="name" placeholder="Your name" required autocomplete="name"/></div>
        <div class="f-row">
          <div><label class="f-label" for="b-email">Email *</label><input class="f-input" type="email" id="b-email" name="email" placeholder="you@email.com" required autocomplete="email"/></div>
          <div><label class="f-label" for="b-phone">Phone</label><input class="f-input" type="tel" id="b-phone" name="phone" placeholder="(619) 555-0000" autocomplete="tel"/></div>
        </div>
        <div><label class="f-label" for="b-artist">Preferred Artist</label>
          <select class="f-input" id="b-artist" name="artist">
            <option value="">Any artist</option>
            {studio.artists.map(a => <option value={a.name}>{a.name} — {a.specialty}</option>)}
          </select>
        </div>
        <div class="f-row">
          <div><label class="f-label" for="b-size">Size</label>
            <select class="f-input" id="b-size" name="size">
              <option>Small (coin)</option><option>Medium (hand)</option><option>Large (half sleeve)</option><option>Full sleeve / back</option>
            </select>
          </div>
          <div><label class="f-label" for="b-placement">Placement</label><input class="f-input" type="text" id="b-placement" name="placement" placeholder="e.g. forearm"/></div>
        </div>
        <div><label class="f-label" for="b-desc">Describe Your Idea *</label><textarea class="f-input" id="b-desc" name="description" rows="4" placeholder="Flash, custom, or bring your own..." required></textarea></div>
        <div><label class="f-label" for="b-dates">Preferred Dates</label><input class="f-input" type="text" id="b-dates" name="dates" placeholder="e.g. Weekends in June"/></div>
        <button class="f-submit" type="submit">Request Appointment + ${studio.depositAmount} Deposit</button>
      </form>
    </div>
  </div>
</section>

<!-- FAQ -->
<section id="faq" class="section" aria-labelledby="faq-h">
  <div class="section-inner" style="max-width:800px;">
    <span class="eyebrow">Common Questions</span>
    <h2 class="section-h" id="faq-h">You Asked, We Answered</h2>
    <div class="gold-bar" aria-hidden="true"></div>
    <div class="faq-outer">
      {studio.faqs.map(f => (
        <details>
          <summary>{f.question}</summary>
          <div class="faq-ans"><p>{f.answer}</p></div>
        </details>
      ))}
    </div>
  </div>
</section>

<!-- LOCATION -->
<section id="location" class="section location-bg" aria-labelledby="location-h">
  <div class="section-inner">
    <div class="location-grid">
      <div>
        <span class="eyebrow">Find Us</span>
        <h2 class="section-h" id="location-h">Studio Location</h2>
        <div class="gold-bar" aria-hidden="true"></div>
        <div class="contact-stack">
          <div class="contact-row"><span class="c-icon" aria-hidden="true">📍</span><div><p>{studio.address}</p><p>{studio.city}</p><a href={studio.mapUrl} target="_blank" rel="noopener noreferrer" style="font-family:'Teko',sans-serif;font-size:0.9rem;letter-spacing:0.12em;text-transform:uppercase;margin-top:0.3rem;display:inline-block;">Get Directions →</a></div></div>
          <div class="contact-row"><span class="c-icon" aria-hidden="true">📞</span><a href={`tel:${studio.phone}`}>{studio.phone}</a></div>
          <div class="contact-row"><span class="c-icon" aria-hidden="true">✉️</span><a href={`mailto:${studio.email}`}>{studio.email}</a></div>
          <div class="contact-row"><span class="c-icon" aria-hidden="true">📸</span><a href={`https://instagram.com/${studio.instagram.replace('@','')}`} target="_blank" rel="noopener noreferrer">{studio.instagram}</a></div>
        </div>
      </div>
      <div>
        <span class="eyebrow" style="display:block;margin-bottom:0.5rem;">Hours</span>
        <table class="hours-tbl" aria-label="Studio hours">
          <tbody>
            {studio.hours.map(h => (
              <tr>
                <td>{h.day}</td>
                <td class={h.open==='Closed'?'closed':''}>{h.open==='Closed'?'Closed':`${h.open} – ${h.close}`}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>

<!-- INSTAGRAM -->
<section id="instagram" class="section" aria-labelledby="ig-h">
  <div class="section-inner">
    <span class="eyebrow">Follow the Work</span>
    <h2 class="section-h" id="ig-h">On Instagram</h2>
    <div class="gold-bar" aria-hidden="true"></div>
    <div class="ig-grid" role="list" aria-label="Instagram feed">
      {studio.igPosts.map(p => (
        <div class="ig-cell" role="listitem">
          <a href={p.link} aria-label={`Instagram: ${p.alt}`} target="_blank" rel="noopener noreferrer">
            <Picture formats={['avif','webp']} src={resolveImage(p.image)} alt={p.alt} loading="lazy" decoding="async" widths={[200, 400]} sizes="(min-width: 1024px) 16vw, 33vw" width={300} height={300} />
          </a>
        </div>
      ))}
    </div>
    <div class="ig-follow">
      <a href={`https://instagram.com/${studio.instagram.replace('@','')}`} target="_blank" rel="noopener noreferrer">Follow {studio.instagram}</a>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer>
  <p class="footer-logo">Iron <span>&amp;</span> Rose</p>
  <p class="footer-est">"Since before your grandfather got his first tattoo."</p>
  <nav aria-label="Footer navigation">
    <ul class="footer-nav" role="list">
      <li><a href="#portfolio">Portfolio</a></li>
      <li><a href="#artists">Artists</a></li>
      <li><a href="#booking">Book</a></li>
      <li><a href="#faq">FAQ</a></li>
      <li><a href="#location">Location</a></li>
    </ul>
  </nav>
  <p class="footer-copy">&copy; 2024 Iron &amp; Rose Tattoo · {studio.address}, {studio.city} · {studio.phone}</p>
</footer>
</body>
</html>

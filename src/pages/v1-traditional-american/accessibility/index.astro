---
import { studio } from '../../../data/v1';
import '../../../styles/global.css';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title>Accessibility Statement — {studio.name}</title>
  <meta name="description" content={`Accessibility statement for ${studio.name}. Committed to WCAG 2.1 AA compliance.`}/>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Teko:wght@400;500;600;700&family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet"/>
  <style>
    :root{--red:#7A0000;--cream:#FFF5DC;--gold:#C8860A;--dark:#160500;--ink:#2A1200;}
    *{box-sizing:border-box;margin:0;padding:0;}
    body{background:var(--cream);color:var(--ink);font-family:'EB Garamond',Georgia,serif;line-height:1.7;}
    .skip-link{position:absolute;top:-100px;left:0;background:var(--gold);color:var(--dark);padding:0.75rem 1.25rem;font-weight:700;text-decoration:none;z-index:9999;}
    .skip-link:focus{top:0;}
    *:focus-visible{outline:3px solid var(--gold)!important;outline-offset:2px;}
    nav{background:var(--dark);border-bottom:4px solid var(--gold);padding:1rem 1.5rem;}
    nav a{color:var(--cream);text-decoration:none;font-family:'Teko',sans-serif;letter-spacing:0.12em;text-transform:uppercase;}
    main{max-width:760px;margin:0 auto;padding:4rem 1.5rem;}
    h1{font-family:'Teko',sans-serif;font-size:clamp(2.5rem,5vw,4rem);color:var(--dark);text-transform:uppercase;margin-bottom:1rem;letter-spacing:0.02em;}
    .gold-bar{width:60px;height:4px;background:var(--gold);margin:1rem 0 2rem;}
    h2{font-family:'Teko',sans-serif;font-size:1.6rem;color:var(--dark);text-transform:uppercase;margin:2rem 0 0.75rem;letter-spacing:0.06em;}
    p{margin-bottom:1rem;font-size:1.05rem;}
    a{color:var(--red);text-decoration:underline;text-underline-offset:2px;}
    a:hover,a:focus-visible{color:var(--dark);}
    .updated{font-style:italic;color:#6A4020;font-size:0.95rem;margin-top:2rem;border-top:1px solid rgba(122,0,0,0.2);padding-top:1.5rem;}
    footer{background:#0D0300;color:#E8C896;padding:2rem 1.5rem;text-align:center;font-size:0.85rem;}
    footer a{color:#FFD994;text-decoration:underline;}
  </style>
</head>
<body>
<a href="#main-content" class="skip-link">Skip to main content</a>
<nav aria-label="Main navigation">
  <a href="/v1-traditional-american/">&larr; Back to {studio.name}</a>
</nav>
<main id="main-content">
  <h1>Accessibility Statement</h1>
  <div class="gold-bar" aria-hidden="true"></div>
  <p>{studio.name} is committed to ensuring digital accessibility for people of all abilities. We strive to conform to WCAG 2.1 Level AA standards and continuously improve the user experience for everyone.</p>

  <h2>Need Help?</h2>
  <p>If you experience any difficulty accessing this website, or need accommodations, please contact us at <a href={`mailto:accessibility@ironandrosetattoo.com`}>accessibility@ironandrosetattoo.com</a> or <a href={`tel:${studio.phone}`}>{studio.phone}</a> and we will work to provide the information or service through alternative communication.</p>

  <h2>Our Commitment</h2>
  <p>This site is reviewed regularly. We aim to meet or exceed Web Content Accessibility Guidelines 2.1 Level AA. If you encounter content that is not accessible, please let us know so we can address it.</p>

  <p class="updated">Last updated: 2026-05-17</p>
</main>
<footer>
  <p>&copy; 2024 {studio.name} · <a href="/v1-traditional-american/">Home</a></p>
</footer>
</body>
</html>
